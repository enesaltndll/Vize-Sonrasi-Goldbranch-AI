@{
    ViewData["Title"] = "AI Geliştirici Asistanı";
}
<div class="container-fluid py-4 fade-in-up">
    <div class="row g-4 justify-content-center">
        <!-- 🧪 LABORATORY SIDEBAR (SYSTEMS) -->
        <div class="col-lg-4 col-xl-3">
            <!-- Lab Status Panel -->
            <div class="card bg-dark border-0 shadow-lg mb-4 hover-wow" style="border-radius:24px; border-left: 4px solid var(--gb-accent-cyan) !important;">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="lab-pulse"></div>
                        <div>
                            <h5 class="text-light fw-bold mb-0">Lab Durumu</h5>
                            <span class="text-info smallest fw-bold uppercase letter-spacing-2">Sistem Stabil</span>
                        </div>
                    </div>
                    
                    <p class="text-muted small mb-0">Kodlama asistanı en son geliştirme verileriyle senkronize edildi.</p>
                </div>
            </div>

            <!-- AI Configuration Panel -->
            <div class="card bg-dark border-0 shadow-lg mb-4 glass-card" style="border-radius:24px;">
                <div class="card-body p-4">
                    <h6 class="text-light fw-bold mb-3 d-flex align-items-center gap-2">
                        <i class="fa-solid fa-sliders text-warning"></i> @L.Get("AiProviderSettings")
                    </h6>
                    
                    <div class="mb-3">
                        <label class="text-muted smallest mb-2 uppercase fw-bold">Sağlayıcı</label>
                        <select id="aiProviderRes" class="form-select bg-dark text-light border-secondary" style="border-radius:12px; font-size: 0.9rem;">
                            <option value="default">🔄 @L.Get("AiProviderDefault")</option>
                            <option value="openai">🟢 OpenAI (GPT-4o)</option>
                            <option value="gemini">🔵 Google Gemini</option>
                            <option value="anthropic">🟠 Anthropic Claude</option>
                            <option value="sambanova">⚡ SambaNova</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted smallest mb-2 uppercase fw-bold">API Anahtarı</label>
                        <input type="password" id="aiApiKeyRes" class="form-control bg-dark text-light border-secondary" style="border-radius:12px;" placeholder="****">
                    </div>

                    <div class="d-flex gap-2">
                        <button id="testAiBtnRes" class="btn btn-outline-info w-100 rounded-pill py-2 smallest fw-bold">
                            <i class="fa-solid fa-bolt me-1"></i> Test
                        </button>
                        <button id="saveAiBtnRes" class="btn btn-warning w-100 text-dark rounded-pill py-2 smallest fw-bold">
                            <i class="fa-solid fa-check me-1"></i> Kaydet
                        </button>
                    </div>
                    <div id="aiTestResultRes" class="mt-3 small d-none text-center"></div>
                </div>
            </div>

            <!-- Research Presets -->
            <div class="card bg-dark border-0 shadow-lg glass-card" style="border-radius:24px;">
                <div class="card-body p-4">
                    <h6 class="text-light fw-bold mb-3">Hızlı Analiz Birimleri</h6>
                    <div class="d-flex flex-column gap-2">
                        <button class="btn btn-sm btn-dark text-start py-2 px-3 border-secondary research-preset-btn" data-prompt="Lütfen şu kodu incele ve güvenlik/performans açısından kritik hataları bul:\n\n" style="border-radius:12px;">
                            <i class="fa-solid fa-magnifying-glass-chart text-info me-2"></i> @L.Get("CodeReview")
                        </button>
                        <button class="btn btn-sm btn-dark text-start py-2 px-3 border-secondary research-preset-btn" data-prompt="Şu kodda hata alıyorum, nedenini açıklar mısın?\n\n" style="border-radius:12px;">
                            <i class="fa-solid fa-bug text-danger me-2"></i> @L.Get("BugFinder")
                        </button>
                        <button class="btn btn-sm btn-dark text-start py-2 px-3 border-secondary research-preset-btn" data-prompt="Bu kodun çalışma hızını nasıl 10 kat artırabilirim?\n\n" style="border-radius:12px;">
                            <i class="fa-solid fa-gauge-high text-success me-2"></i> @L.Get("PerformanceBoost")
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 🧪 NEURAL SANDBOX (CHAT) -->
        <div class="col-lg-8 col-xl-7">
            <div class="card bg-dark border-0 shadow-lg h-100 glass-card" style="border-radius:28px; background: rgba(13, 17, 23, 0.8) !important;">
                <div class="card-header bg-transparent border-0 p-4 pb-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="text-light fw-bold mb-0">AI <span class="text-info">Labaratuvarı</span></h4>
                        <span class="badge rounded-pill px-3 py-2" style="background: rgba(34,211,238,0.1); color:#22d3ee; border:1px solid rgba(34,211,238,0.2);">
                            <i class="fa-solid fa-network-wired me-1"></i> Sinirsel Bağlantı Aktif
                        </span>
                    </div>
                </div>
                <div class="card-body p-4 d-flex flex-column" style="min-height: 600px;">
                    
                    <!-- History Container -->
                    <div id="chatHistory" class="flex-grow-1 overflow-auto pe-2 mb-4 d-flex flex-column gap-3" style="max-height: 550px;">
                        <!-- İlk Mesaj (Sistem) -->
                        <div class="d-flex gap-3 fade-in-up">
                            <div class="flex-shrink-0">
                                <span class="d-flex align-items-center justify-content-center rounded-circle shadow-glow-cyan" style="width:40px;height:40px;background:linear-gradient(135deg,#0ea5e9,#0284c7); border:none;">
                                    <i class="fa-solid fa-bolt text-white"></i>
                                </span>
                            </div>
                            <div class="p-3 rounded-4 bg-dark shadow-sm" style="border:1px solid rgba(255,255,255,0.08); border-top-left-radius: 0 !important; color:#e2e8f0; font-size: 0.95rem; max-width: 85%;">
                                Araştırma Lab'e hoş geldin şef. Bugün hangi teknolojiyi parçalıyoruz? Kodunu buraya yapıştır veya sol taraftaki analiz birimlerini kullan.
                            </div>
                        </div>
                    </div>

                    <!-- Input Alanı -->
                    <div class="mt-auto pt-3 border-top border-secondary">
                        <div class="position-relative">
                            <textarea id="aiInput" class="form-control bg-dark text-light shadow-sm pe-5" 
                                      style="border:1px solid rgba(34,211,238,0.3); border-radius:20px; min-height:80px; max-height: 300px; resize:none; padding:18px; line-height:1.6;" 
                                      placeholder="Sorunuzu veya kod bölmesini buraya bırakın..."></textarea>
                                      
                            <button id="aiSendBtn" class="btn position-absolute top-50 translate-middle-y end-0 me-3 rounded-circle shadow-lg d-flex align-items-center justify-content-center glow-btn-cyan"
                                    style="width:50px;height:50px;background:linear-gradient(135deg,#0ea5e9,#0284c7);color:white;border:none;transition:all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);">
                                <i class="fa-solid fa-paper-plane"></i>
                            </button>
                        </div>
                        <div class="text-center mt-3">
                            <small class="text-muted" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                                <i class="fa-solid fa-shield-halved me-1"></i> Lab verileri kurum içi sunucuda işlenir ve güvenlidir.
                            </small>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Scrollbar */
    #chatHistory::-webkit-scrollbar { width: 6px; }
    #chatHistory::-webkit-scrollbar-track { background: rgba(255,255,255,0.02); border-radius: 3px; }
    #chatHistory::-webkit-scrollbar-thumb { background: rgba(34,211,238,0.2); border-radius: 3px; }
    #chatHistory::-webkit-scrollbar-thumb:hover { background: rgba(34,211,238,0.5); }
    
    /* Markdown Styles (Generated dynamically) */
    .ai-response pre { 
        background-color: #0d1117 !important; 
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        padding: 1rem;
        margin: 1rem 0;
        overflow-x: auto;
    }
    .ai-response code { 
        font-family: 'JetBrains Mono', 'Consolas', monospace; 
        color: #e2e8f0;
        font-size: 0.85rem;
    }
    .ai-response p { margin-bottom: 0.5rem; }
    .ai-response ul { margin-bottom: 0.5rem; }
</style>

<!-- Marked.js for Markdown parsing -->
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const sendBtn = document.getElementById("aiSendBtn");
            const inputField = document.getElementById("aiInput");
            const chatHistory = document.getElementById("chatHistory");

            let isWaiting = false;

            // AI Ayarları yükle
            fetch("/Ai/GetAiSettings").then(r => r.json()).then(data => {
                if (data.success) {
                    document.getElementById("aiProviderRes").value = data.provider || "default";
                    if (data.model) document.getElementById("aiModelRes").value = data.model;
                }
            }).catch(() => {});

            // AI Test
            document.getElementById("testAiBtnRes").addEventListener("click", async function () {
                const rd = document.getElementById("aiTestResultRes");
                rd.classList.remove("d-none");
                rd.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-1"></i> Test ediliyor...';
                rd.className = "mt-2 small text-muted";
                try {
                    const res = await fetch("/Ai/TestAiConnection", {
                        method: "POST", headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ provider: document.getElementById("aiProviderRes").value, apiKey: document.getElementById("aiApiKeyRes").value, model: document.getElementById("aiModelRes").value })
                    });
                    const d = await res.json();
                    rd.innerHTML = d.message;
                    rd.className = d.success ? "mt-2 small text-success" : "mt-2 small text-danger";
                } catch (e) { rd.innerHTML = "❌ " + e.message; rd.className = "mt-2 small text-danger"; }
            });

            // AI Kaydet
            document.getElementById("saveAiBtnRes").addEventListener("click", async function () {
                const rd = document.getElementById("aiTestResultRes");
                try {
                    const res = await fetch("/Ai/SaveAiSettings", {
                        method: "POST", headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ provider: document.getElementById("aiProviderRes").value, apiKey: document.getElementById("aiApiKeyRes").value, model: document.getElementById("aiModelRes").value })
                    });
                    const d = await res.json();
                    rd.classList.remove("d-none");
                    rd.innerHTML = d.success ? "✅ Kaydedildi!" : "❌ " + d.message;
                    rd.className = d.success ? "mt-2 small text-success" : "mt-2 small text-danger";
                } catch (e) { rd.classList.remove("d-none"); rd.innerHTML = "❌ " + e.message; rd.className = "mt-2 small text-danger"; }
            });

            // Enter ile Gönder (Shift+Enter alt satır)
            inputField.addEventListener("keydown", function(e) {
                if(e.key === "Enter" && !e.shiftKey) {
                    e.preventDefault();
                    sendMessage();
                }
            });

            sendBtn.addEventListener("click", sendMessage);

            // Araştırma Birimleri (Presets)
            document.querySelectorAll(".research-preset-btn").forEach(btn => {
                btn.addEventListener("click", function() {
                    const prompt = this.getAttribute("data-prompt");
                    inputField.value = prompt;
                    inputField.focus();
                    
                    // Smooth visual feedback
                    inputField.style.height = inputField.scrollHeight + "px";
                    
                    GB.toast({ title: 'Analiz Birimi Hazır', text: 'Analiz şablonu yüklendi. Kodunu ekleyip gönderebilirsin.', icon: 'info', timer: 1500 });
                });
            });

            async function sendMessage() {
                const text = inputField.value.trim();
                if(!text || isWaiting) return;

                // 1. Yazılanı UI'ye User Mesajı Olarak Ekle
                appendUserMessage(text);
                inputField.value = "";
                inputField.style.height = "60px"; // Reset height
                scrollToBottom();

                // 2. Bekleme Göstergesi
                isWaiting = true;
                sendBtn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i>';
                const loadingId = appendLoadingIndicator();
                scrollToBottom();

                // 3. API İstek
                try {
                    const response = await fetch("/Ai/AskResearch", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ question: text })
                    });
                    
                    const data = await response.json();
                    
                    removeElement(loadingId);

                    if (data.success) {
                        appendAiMessage(data.answer);
                    } else {
                        appendErrorMessage(data.error || "Sunucu hatası.");
                    }
                } catch(err) {
                    removeElement(loadingId);
                    appendErrorMessage("Bağlantı kurulamadı: " + err.message);
                } finally {
                    isWaiting = false;
                    sendBtn.innerHTML = '<i class="fa-solid fa-paper-plane"></i>';
                    scrollToBottom();
                }
            }

            function appendUserMessage(text) {
                const id = "msg_" + Date.now();
                const html = `
                    <div class="d-flex gap-3 justify-content-end fade-in-up" id="${id}">
                        <div class="p-3 rounded-4 shadow-sm" style="background:#2d3748; border-top-right-radius: 0 !important; color:#f8fafc; font-size: 0.95rem; max-width: 80%;">
                            ${escapeHtml(text)}
                        </div>
                        <div class="flex-shrink-0">
                            <span class="d-flex align-items-center justify-content-center rounded-circle bg-secondary text-white" style="width:40px;height:40px;">
                                <i class="fa-solid fa-user"></i>
                            </span>
                        </div>
                    </div>
                `;
                chatHistory.insertAdjacentHTML('beforeend', html);
                return id;
            }

            function appendAiMessage(markdownResult) {
                const id = "msg_" + Date.now();
                // Parse markdown securely
                const parsedHtml = marked.parse(markdownResult);
                
                const html = `
                    <div class="d-flex gap-3 fade-in-up" id="${id}">
                        <div class="flex-shrink-0">
                            <span class="d-flex align-items-center justify-content-center rounded-circle" style="width:40px;height:40px;background:linear-gradient(135deg,#0ea5e9,#0284c7);border:none;">
                                <i class="fa-solid fa-brain text-white"></i>
                            </span>
                        </div>
                        <div class="p-3 rounded-4 bg-dark ai-response w-100" style="border:1px solid rgba(34,211,238,0.2); border-top-left-radius: 0 !important; color:#e2e8f0; font-size: 0.95rem; overflow-x: auto;">
                            ${parsedHtml}
                        </div>
                    </div>
                `;
                chatHistory.insertAdjacentHTML('beforeend', html);
                return id;
            }

            function appendErrorMessage(errorMsg) {
                const html = `
                    <div class="d-flex justify-content-center my-2 fade-in-up">
                        <span class="badge bg-danger rounded-pill px-3 py-2"><i class="fa-solid fa-triangle-exclamation me-1"></i> ${escapeHtml(errorMsg)}</span>
                    </div>
                `;
                chatHistory.insertAdjacentHTML('beforeend', html);
            }

            function appendLoadingIndicator() {
                const id = "loading_" + Date.now();
                const html = `
                    <div class="d-flex gap-3 fade-in-up" id="${id}">
                        <div class="flex-shrink-0">
                            <span class="d-flex align-items-center justify-content-center rounded-circle outline-glow" style="width:40px;height:40px;background:rgba(34,211,238,0.1);border:1px solid rgba(34,211,238,0.3);">
                                <i class="fa-solid fa-circle-notch fa-spin text-info"></i>
                            </span>
                        </div>
                        <div class="p-3 rounded-4 bg-dark text-muted d-flex align-items-center" style="border:1px solid rgba(255,255,255,0.05); border-top-left-radius: 0 !important; font-size: 0.9rem;">
                            AI kodu analiz ediyor ve düşünüyor...
                        </div>
                    </div>
                `;
                chatHistory.insertAdjacentHTML('beforeend', html);
                return id;
            }

            function removeElement(id) {
                const el = document.getElementById(id);
                if(el) el.remove();
            }

            function scrollToBottom() {
                chatHistory.scrollTop = chatHistory.scrollHeight;
            }

            function escapeHtml(unsafe) {
                return unsafe
                     .replace(/&/g, "&amp;")
                     .replace(/</g, "&lt;")
                     .replace(/>/g, "&gt;")
                     .replace(/"/g, "&quot;")
                     .replace(/'/g, "&#039;")
                     .replace(/\n/g, "<br>");
            }
        });
    </script>
}
