
@{
    ViewData["Title"] = L.Get("AIPrioritize");
}

<div class="mb-4 fade-in-up">
    <div class="d-flex align-items-center justify-content-between mb-2">
        <div class="d-flex align-items-center">
            <div class="icon-circle bg-primary bg-opacity-10 text-primary me-3">
                <i class="fa-solid fa-brain"></i>
            </div>
            <div>
                <h2 class="fw-bold mb-0">@L.Get("AiStrategyRadar")</h2>
                <p class="text-muted mb-0">@L.Get("AiStrategyDesc") <b>@ViewBag.OriginalCount</b></p>
            </div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span id="aiProviderBadge" class="badge rounded-pill px-3 py-2" style="background:rgba(168,85,247,0.1);border:1px solid rgba(168,85,247,0.3);color:#c084fc;font-size:0.7rem;">
                <i class="fa-solid fa-microchip me-1"></i><span id="providerName">Varsayılan</span>
            </span>
            <a href="/Ai/Research" class="btn btn-sm rounded-pill px-3" style="background:rgba(168,85,247,0.05);border:1px solid rgba(168,85,247,0.2);color:#c084fc;font-size:0.7rem;">
                <i class="fa-solid fa-gear me-1"></i>@L.Get("AiProviderSettings")
            </a>
        </div>
    </div>
</div>

<script>
    fetch("/Ai/GetAiSettings").then(r => r.json()).then(data => {
        if (data.success && data.provider && data.provider !== "default") {
            const names = { openai: "OpenAI", gemini: "Gemini", anthropic: "Claude", cohere: "Cohere", sambanova: "SambaNova" };
            const el = document.getElementById("providerName");
            if (el) el.textContent = names[data.provider] || data.provider;
        }
    }).catch(() => {});
</script>

<div class="row fade-in-up" style="animation-delay: 0.15s;">
    <div class="col-12">
        <div class="card bg-dark border-0 shadow-lg" style="border: 1px solid rgba(168, 85, 247, 0.3) !important;">
            <div class="card-header border-0 bg-transparent p-4 pb-0">
                <h5 class="text-purple fw-bold" style="color: #c084fc;"><i class="fa-solid fa-list-ol me-2"></i> @L.Get("AiAdvice")</h5>
            </div>
            <div class="card-body p-4 pt-2">
                <div class="ai-response-content bg-body-secondary bg-opacity-10 rounded-4 p-4" style="line-height: 1.8; font-size: 1.05rem;">
                    @Html.Raw(Markdig.Markdown.ToHtml((string)ViewBag.AiResponse ?? L.Get("AiNoResponse")))
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 p-4 pt-0">
                <a asp-controller="Task" asp-action="Index" class="btn btn-outline-light rounded-pill"><i class="fa-solid fa-arrow-left me-2"></i> @L.Get("BackToBoard")</a>
            </div>
        </div>
    </div>
</div>

<style>
    .ai-response-content table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
        margin-bottom: 20px;
    }
    .ai-response-content th {
        background-color: rgba(168, 85, 247, 0.2);
        color: #c084fc;
        padding: 12px;
        text-align: left;
        border-bottom: 2px solid rgba(168, 85, 247, 0.5);
    }
    .ai-response-content td {
        padding: 12px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .ai-response-content tr:hover {
        background-color: rgba(255, 255, 255, 0.02);
    }
</style>
