@{
    Layout = null;
    int currentXP = ViewBag.CurrentXP ?? 0;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Zen Modu 2.0 - GoldBranch AI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --gold: #fbbf24;
            --gold-glow: rgba(251, 191, 36, 0.4);
            --bg-dark: #0a0a0c;
            --panel-bg: rgba(255, 255, 255, 0.03);
            --border: rgba(251, 191, 36, 0.15);
        }

        body, html {
            margin: 0; padding: 0; height: 100%; overflow: hidden;
            background: var(--bg-dark); font-family: 'Inter', sans-serif; color: #fff;
        }

        #zenWrapper {
            display: grid;
            grid-template-rows: 70px 1fr;
            height: 100vh;
            background: radial-gradient(circle at top right, #1a1a1a 0%, #000 100%);
        }

        /* Top Header */
        header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 30px; border-bottom: 1px solid var(--border);
            background: rgba(0,0,0,0.5); backdrop-filter: blur(10px); z-index: 100;
        }

        .xp-badge {
            background: linear-gradient(135deg, #7c3aed, #a855f7);
            padding: 6px 16px; border-radius: 20px; font-weight: 700;
            font-size: 0.9rem; box-shadow: 0 0 15px rgba(124, 58, 237, 0.3);
            display: flex; align-items: center; gap: 8px;
        }

        .mola-timer {
            font-family: 'JetBrains Mono', monospace; color: var(--gold);
            font-size: 1.1rem; letter-spacing: 1px;
        }

        /* Main Grid */
        main {
            display: grid; grid-template-columns: 1.2fr 1fr; gap: 20px;
            padding: 20px; overflow: hidden;
        }

        .zen-panel {
            background: var(--panel-bg); border: 1px solid var(--border);
            border-radius: 24px; display: flex; flex-direction: column;
            overflow: hidden; position: relative;
        }

        /* YouTube Section */
        #ytPanel { padding: 15px; }
        .search-box { position: relative; margin-bottom: 15px; }
        #zenYouTubeUrl {
            background: rgba(255,255,255,0.05); border: 1px solid var(--border);
            color: #fff; border-radius: 12px; padding: 12px 15px; width: 100%;
        }

        /* Snake Game Section */
        #gamePanel { 
            display: flex; align-items: center; justify-content: center;
            background: url('https://www.transparenttextures.com/patterns/carbon-fibre.png'), #000;
        }
        #gameCanvas {
            border: 2px solid var(--gold); box-shadow: 0 0 30px var(--gold-glow);
            background: #000;
        }
        .game-overlay {
            position: absolute; inset: 0; background: rgba(0,0,0,0.8);
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            z-index: 10;
        }

        /* Animations */
        @@keyframes goldPulse {
            0% { box-shadow: 0 0 10px var(--gold-glow); }
            50% { box-shadow: 0 0 30px var(--gold-glow); }
            100% { box-shadow: 0 0 10px var(--gold-glow); }
        }

        .gold-text { color: var(--gold); text-shadow: 0 0 10px var(--gold-glow); }

        .hover-bg:hover { background: rgba(255,255,255,0.05); }
    </style>
</head>
<body>

    <div id="zenWrapper">
        <header>
            <div class="d-flex align-items-center gap-3">
                <a asp-controller="Task" asp-action="Dashboard" class="btn btn-danger btn-sm rounded-pill px-3 fw-bold shadow">
                    <i class="fa-solid fa-power-off me-1"></i> Zen'den Çık
                </a>
                <div class="mola-timer" id="sessionTimerWrapper">
                    <i class="fa-solid fa-clock opacity-50 me-2"></i>
                    <span id="sessionTimer">00:00</span>
                </div>
            </div>

            <div class="navbar-brand fw-bold m-0" style="font-size:1.2rem; color:var(--gold);">
                <i class="fa-solid fa-leaf me-2"></i>ZEN 2.0
            </div>

            <div class="d-flex align-items-center gap-3">
                <div class="xp-badge" id="xpCounter">
                    <i class="fa-solid fa-star"></i>
                    <span>@currentXP XP</span>
                </div>
            </div>
        </header>

        <main>
            <!-- LEFT: Video & Music -->
            <div class="zen-panel" id="ytPanel">
                <div class="search-box">
                    <input id="zenYouTubeUrl" type="text" placeholder="Şarkı veya Video Ara...">
                    <button id="zenYouTubeLoad" class="btn position-absolute top-50 end-0 translate-middle-y me-2" style="color:var(--gold);">
                        <i class="fa-solid fa-search"></i>
                    </button>
                    <!-- Floating Results -->
                    <div id="zenYouTubeResults" class="dropdown-menu w-100 shadow-lg" style="display:none; background:#1c1c24; border:1px solid var(--border); max-height: 300px; overflow-y: auto;">
                        <div id="zenYouTubeList" class="p-2"></div>
                    </div>
                </div>

                <div class="mb-3 d-flex gap-2 align-items-center">
                    <button class="btn btn-sm btn-outline-warning rounded-pill px-3" onclick="loadRadio('https://www.youtube.com/embed/5qap5aO4i9A?autoplay=1')">🎧 Lofi Radyo</button>
                    <button class="btn btn-sm btn-warning rounded-pill px-3 fw-bold" onclick="loadRadio('https://www.youtube.com/embed/videoseries?list=PLbH8t4I558_6e2oYlE_sF2OQk8dO6F5H1&autoplay=1')">👑 Kral Pop</button>
                    <button class="btn btn-sm btn-outline-info rounded-pill px-3" onclick="loadRadio('https://www.youtube.com/embed/videoseries?list=PLx0sYbCqOb8TBPRdmBHs5Iftvv9TPboYG&autoplay=1')">🎸 Akustik</button>
                    <button id="btnToggleYTSize" class="btn btn-sm btn-dark rounded-pill ms-auto" title="Görünümü Genişlet/Daralt">
                        <i class="fa-solid fa-expand"></i>
                    </button>
                </div>
                <div id="ytContainer" style="flex:1; border-radius:16px; overflow:hidden; background:#000; transition: all 0.5s ease;">
                    <iframe id="zenYouTubeIframe" style="width:100%; height:100%; border:0;" src="https://www.youtube.com/embed/videoseries?list=PLbH8t4I558_6e2oYlE_sF2OQk8dO6F5H1&autoplay=1&modestbranding=1&rel=0" allow="autoplay; encrypted-media"></iframe>
                </div>
            </div>

            <!-- RIGHT: Game -->
            <div class="zen-panel" id="gamePanel">
                <div id="gameUI" class="game-overlay">
                    <div class="d-flex gap-3 mb-4">
                        <button class="btn btn-outline-warning game-select-btn active" data-game="snake">🐍 FOCUS SNAKE</button>
                        <button class="btn btn-outline-info game-select-btn" data-game="pong">🏓 PING PONG</button>
                    </div>
                    
                    <h2 class="gold-text fw-bold mb-1" id="gameTitleDisplay">FOCUS SNAKE</h2>
                    <div id="scoreStats" class="mb-3 text-center" style="display:none;">
                        <div class="small text-muted mb-1">OYUN BİTTİ</div>
                        <div class="h4 gold-text mb-0" id="lastScore">0</div>
                        <div class="small text-white-50">Son Skor</div>
                        <hr class="my-2 border-secondary" style="opacity:0.2;">
                        <div class="h5 text-warning mb-0" id="highScoreText">0</div>
                        <div class="small text-white-50">En Yüksek Skor</div>
                    </div>
                    <p class="text-muted small mb-4 text-center" id="gameDescDisplay">Her skor <b class="text-warning">+25 XP</b> kazandırır.<br>Oyun bittiğinde puanın kaydedilir.</p>
                    <button id="startGameBtn" class="btn px-5 py-2 rounded-pill fw-bold" style="background:var(--gold); color:#000; box-shadow: 0 0 20px var(--gold-glow);">
                        OYUNA BAŞLA
                    </button>
                    <div class="mt-4 text-center">
                        <small class="text-muted d-block mb-2">Kontroller</small>
                        <div class="d-flex gap-2 justify-content-center" id="gameControlsDisplay">
                            <span class="badge border border-secondary px-2">W-A-S-D</span>
                            <span class="text-muted">veya</span>
                            <span class="badge border border-secondary px-2">Yön Tuşları</span>
                        </div>
                    </div>
                </div>
                <canvas id="gameCanvas"></canvas>
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

    <script>
        function loadRadio(url) {
            document.getElementById('zenYouTubeIframe').src = url;
        }

        document.addEventListener("DOMContentLoaded", () => {
            // TIMER & CORE VARS
            let seconds = 0;
            const timerEl = document.getElementById('sessionTimer');
            
            // FRENZY FOCUS & ACHIEVEMENTS
            let sessionStartTime = Date.now();
            let hasFocusMasterTriggered = false;

            function triggerAchievement(title, sub, icon) {
                if (window.parent && window.parent.triggerAchievementSplash) {
                    window.parent.triggerAchievementSplash(title, sub, icon);
                } else if (typeof triggerAchievementSplash !== 'undefined') {
                    triggerAchievementSplash(title, sub, icon);
                }
            }

            function toggleFrenzyFocus(active) {
                const body = document.body;
                if (active) {
                    body.classList.add('frenzy-active');
                    startNeuralStream();
                } else {
                    body.classList.remove('frenzy-active');
                    stopNeuralStream();
                }
            }

            // --- NEURAL STREAM (MATRIX EFFECT) ---
            let neuralInterval = null;
            function startNeuralStream() {
                if (neuralInterval) return;
                const canvas = document.createElement('canvas');
                canvas.id = 'neuralStreamCanvas';
                canvas.style.position = 'fixed'; canvas.style.inset = '0';
                canvas.style.zIndex = '4'; canvas.style.opacity = '0.4';
                canvas.style.pointerEvents = 'none';
                document.body.appendChild(canvas);

                const ctx = canvas.getContext('2d');
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;

                const hex = "0123456789ABCDEF";
                const fontSize = 16;
                const columns = canvas.width / fontSize;
                const drops = [];
                for(let x = 0; x < columns; x++) drops[x] = 1;

                neuralInterval = setInterval(() => {
                    ctx.fillStyle = "rgba(0, 0, 0, 0.05)";
                    ctx.fillRect(0, 0, canvas.width, canvas.height);
                    ctx.fillStyle = "#fbbf24"; // Gold rain
                    ctx.font = fontSize + "px monospace";

                    for(let i = 0; i < drops.length; i++) {
                        const text = hex.charAt(Math.floor(Math.random() * hex.length));
                        ctx.fillText(text, i * fontSize, drops[i] * fontSize);
                        if(drops[i] * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
                        drops[i]++;
                    }
                }, 33);
            }

            function stopNeuralStream() {
                clearInterval(neuralInterval);
                neuralInterval = null;
                const c = document.getElementById('neuralStreamCanvas');
                if (c) c.remove();
            }

            // STYLE INJECTION FOR FRENZY
            const frenzyStyles = document.createElement('style');
            frenzyStyles.innerHTML = `
                body.frenzy-active {
                    background: #000 !important;
                }
                body.frenzy-active #zenWrapper {
                    background: radial-gradient(circle at center, #1a0f00 0%, #000 100%);
                }
                body.frenzy-active #gameCanvas {
                    border-color: #ef4444;
                    box-shadow: 0 0 50px rgba(239, 68, 68, 0.6);
                }
                body.frenzy-active .mola-timer {
                    color: #ef4444; text-shadow: 0 0 10px #ef4444;
                }
                .combo-text {
                    position: absolute; color: #fbbf24; font-weight: 900; font-size: 2.5rem;
                    text-shadow: 0 0 30px #fbbf24; pointer-events: none; z-index: 1000;
                    animation: comboPop 0.8s ease-out forwards; font-family: 'JetBrains Mono';
                }
                @@keyframes comboPop {
                    0% { transform: translate(-50%, -50%) scale(0.3); opacity: 0; }
                    40% { transform: translate(-50%, -80px) scale(1.3); opacity: 1; }
                    100% { transform: translate(-50%, -150px) scale(1); opacity: 0; }
                }
            `;
            document.head.appendChild(frenzyStyles);

            // TIMER LOOP
            setInterval(() => {
                seconds++;
                const m = Math.floor(seconds / 60).toString().padStart(2, '0');
                const s = (seconds % 60).toString().padStart(2, '0');
                timerEl.textContent = `${m}:${s}`;

                // ODAK USTASI (5 dk durursa)
                if (seconds >= 300 && !hasFocusMasterTriggered) {
                    hasFocusMasterTriggered = true;
                    // Note: In real app, we'd sync this badge to DB too
                    triggerAchievement("Odak Ustası", "5 dakikadır kesintisiz derin odaktasın!", "🧘");
                }
            }, 1000);

            // XP & SCORE SYSTEM
            let userXP = @currentXP;
            let highScore = @(ViewBag.HighScore ?? 0);
            let comboCount = 0;
            let lastEatTime = 0;

            function updateXP(amount) {
                const t = Date.now();
                if (t - lastEatTime < 3000) { // 3 saniye içinde yerse kombo
                    comboCount++;
                    if (comboCount >= 3) toggleFrenzyFocus(true);
                } else {
                    comboCount = 0;
                    toggleFrenzyFocus(false);
                }
                lastEatTime = t;

                let multiplier = comboCount >= 5 ? 2 : 1;
                let finalAmount = amount * multiplier;
                
                userXP += finalAmount;
                document.getElementById('xpCounter').querySelector('span').textContent = `${userXP} XP`;
                
                // Visual Combo Text
                if (comboCount > 1) {
                    const comboEl = document.createElement('div');
                    comboEl.className = 'combo-text';
                    comboEl.textContent = `${comboCount}X COMBO!`;
                    comboEl.style.left = '50%'; comboEl.style.top = '20%';
                    document.body.appendChild(comboEl);
                    setTimeout(() => comboEl.remove(), 600);
                }

                fetch('/Zen/EarnXP', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ amount: finalAmount })
                }).then(r => r.json()).then(data => {
                    if (data.badgeEarned) {
                        // 🏆 ACHIEVEMENT SPLASH — Yeni Rozet Kazanıldı!
                        Swal.fire({
                            title: `${data.badgeIcon} YENİ ROZET!`,
                            html: `<span style="color:#fbbf24;font-weight:900;font-size:1.5rem;">${data.badgeName}</span><br><span class="text-muted">Bu rozet başarı kartına eklendi!</span>`,
                            background: '#0d1117', color: '#fbbf24',
                            confirmButtonColor: '#fbbf24',
                            confirmButtonText: 'Muhteşem!'
                        });
                        confetti({ particleCount: 400, spread: 140, origin: { y: 0.4 }, colors: ['#fbbf24', '#ef4444', '#22d3ee', '#a78bfa'] });
                    }
                }).catch(() => {});

                confetti({ 
                    particleCount: 20, spread: 60, origin: { y: 0.1 }, 
                    colors: [comboCount >= 3 ? '#ef4444' : '#fbbf24'],
                    zIndex: 2000
                });
            }

            async function syncHighScoreToDB(score) {
                try {
                    const response = await fetch('/Zen/UpdateHighScore', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ score: score })
                    });
                    const data = await response.json();
                    if (data.success && data.rewardGranted) {
                        Swal.fire({
                            title: '🏆 ÖZEL AYRICALIK KAZANDIN!',
                            text: data.rewardMessage,
                            icon: 'success',
                            background: '#0d1117', color: '#fbbf24',
                            confirmButtonColor: '#fbbf24',
                            confirmButtonText: 'Süper!'
                        });
                        // Massive visual effect for premium reward
                        confetti({ particleCount: 300, spread: 120, origin: { y: 0.5 }, colors: ['#fbbf24', '#ef4444', '#22d3ee'] });
                    }
                } catch (e) {
                    console.error("HighScore sync failed:", e);
                }
            }

            // 🎮 GAME ENGINE CORE
            const canvas = document.getElementById("gameCanvas");
            const ctx = canvas.getContext("2d");
            canvas.width = 400; canvas.height = 400;

            let currentActiveGame = 'snake';
            let gameInterval = null;
            let currentScore = 0;

            // --- GAME SELECTION LOGIC ---
            document.querySelectorAll('.game-select-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.game-select-btn').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    currentActiveGame = this.getAttribute('data-game');
                    
                    if (gameInterval) clearInterval(gameInterval);
                    document.getElementById('gameUI').style.display = 'flex';
                    document.getElementById('scoreStats').style.display = 'none';

                    if (currentActiveGame === 'snake') {
                        document.getElementById('gameTitleDisplay').textContent = "FOCUS SNAKE";
                        document.getElementById('gameDescDisplay').innerHTML = "Her skor <b class='text-warning'>+25 XP</b> kazandırır.<br>Oyun bittiğinde puanın kaydedilir.";
                        document.getElementById('gameControlsDisplay').innerHTML = '<span class="badge border border-secondary px-2">W-A-S-D</span> <span class="text-muted">veya</span> <span class="badge border border-secondary px-2">Yön Tuşları</span>';
                        initSnake(); drawSnake();
                    } else if (currentActiveGame === 'pong') {
                        document.getElementById('gameTitleDisplay').textContent = "PING PONG";
                        document.getElementById('gameDescDisplay').innerHTML = "Rallilerde hedefe ulaştıkça <b class='text-warning'>+50 XP</b> kazandırır.";
                        document.getElementById('gameControlsDisplay').innerHTML = '<span class="badge border border-secondary px-2">W - S</span> <span class="text-muted">veya</span> <span class="badge border border-secondary px-2">Yön Tuşları</span>';
                        initPong(); drawPong();
                    }
                });
            });

            document.getElementById('startGameBtn').onclick = () => {
                document.getElementById('gameUI').style.display = 'none';
                if (gameInterval) clearInterval(gameInterval);
                if (currentActiveGame === 'snake') {
                    initSnake(); gameInterval = setInterval(drawSnake, snakeSpeed);
                } else {
                    initPong(); gameInterval = setInterval(drawPong, 1000/60); // 60 FPS
                }
            };

            function gameOver(score) {
                if(gameInterval) clearInterval(gameInterval);
                document.getElementById('lastScore').textContent = score;
                if (score > highScore) {
                    highScore = score;
                    syncHighScoreToDB(highScore);
                    confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 } });
                }
                document.getElementById('highScoreText').textContent = highScore;
                document.getElementById('scoreStats').style.display = 'block';
                document.getElementById('gameUI').style.display = 'flex';
            }

            // ==========================================
            // 🐍 FOCUS SNAKE LOGIC
            // ==========================================
            const box = 20;
            let snake = [], food = {}, d = null, snakeSpeed = 150;

            function initSnake() {
                snake = [{ x: 9 * box, y: 10 * box }];
                generateFood();
                d = null; currentScore = 0; snakeSpeed = 150;
            }

            function generateFood() {
                let overlap = true;
                while(overlap) {
                    food = { x: Math.floor(Math.random() * 20) * box, y: Math.floor(Math.random() * 20) * box };
                    overlap = snake.some(s => s.x === food.x && s.y === food.y);
                }
            }

            function drawSnake() {
                ctx.fillStyle = "#000"; ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.strokeStyle = "rgba(251,191,36,0.03)";
                for(let i=0; i<canvas.width; i+=box) {
                    ctx.beginPath(); ctx.moveTo(i,0); ctx.lineTo(i,canvas.height); ctx.stroke();
                    ctx.beginPath(); ctx.moveTo(0,i); ctx.lineTo(canvas.width,i); ctx.stroke();
                }

                const isFrenzy = document.body.classList.contains('frenzy-active');
                for (let i = 0; i < snake.length; i++) {
                    ctx.fillStyle = (i == 0) ? "#fbbf24" : (isFrenzy ? "rgba(239, 68, 68, 0.6)" : "rgba(251,191,36,0.3)");
                    if(i==0) { ctx.shadowBlur = isFrenzy ? 20 : 10; ctx.shadowColor = isFrenzy ? "#ef4444" : "#fbbf24"; }
                    ctx.fillRect(snake[i].x, snake[i].y, box, box);
                    ctx.shadowBlur = 0;
                }

                const pulse = Math.sin(Date.now() / 200) * 5;
                ctx.fillStyle = "#fff"; ctx.shadowBlur = 15 + pulse; ctx.shadowColor = "#fbbf24";
                ctx.beginPath(); ctx.arc(food.x + box/2, food.y + box/2, (box/2 - 2) + (pulse/4), 0, Math.PI * 2); ctx.fill();
                ctx.shadowBlur = 0;

                let snakeX = snake[0].x; let snakeY = snake[0].y;
                if (d == "LEFT") snakeX -= box; if (d == "UP") snakeY -= box;
                if (d == "RIGHT") snakeX += box; if (d == "DOWN") snakeY += box;

                if (snakeX == food.x && snakeY == food.y) {
                    currentScore++; updateXP(25); generateFood();
                    snakeSpeed = Math.max(40, 150 - (currentScore * 5));
                    clearInterval(gameInterval); gameInterval = setInterval(drawSnake, snakeSpeed);
                } else {
                    if(d) snake.pop();
                }

                if(d) {
                    let newHead = { x: snakeX, y: snakeY };
                    if (snakeX < 0 || snakeX >= canvas.width || snakeY < 0 || snakeY >= canvas.height || snake.some(s=> s.x===newHead.x && s.y===newHead.y)) {
                        gameOver(currentScore); return;
                    }
                    snake.unshift(newHead);
                }
            }

            // ==========================================
            // 🏓 PING PONG LOGIC
            // ==========================================
            let paddleY = 160, aiY = 160, ballX = 200, ballY = 200, ballDX = 4, ballDY = 4, pongScore = 0, rallyCount = 0;
            const paddleW = 10, paddleH = 80;

            function initPong() {
                paddleY = 160; aiY = 160; ballX = 200; ballY = 200;
                ballDX = 5; ballDY = 5; pongScore = 0; rallyCount = 0;
            }

            function drawPong() {
                ctx.fillStyle = "#000"; ctx.fillRect(0, 0, canvas.width, canvas.height);
                // Center line
                ctx.setLineDash([5, 15]); ctx.beginPath(); ctx.moveTo(200,0); ctx.lineTo(200,400); 
                ctx.strokeStyle="rgba(251,191,36,0.2)"; ctx.stroke(); ctx.setLineDash([]);

                // Paddles
                ctx.fillStyle = "#fbbf24"; ctx.shadowBlur = 10; ctx.shadowColor = "#fbbf24";
                ctx.fillRect(10, paddleY, paddleW, paddleH); // Player
                ctx.fillStyle = "#ef4444"; ctx.shadowColor = "#ef4444";
                ctx.fillRect(380, aiY, paddleW, paddleH); // AI
                ctx.shadowBlur = 0;

                // Ball
                ctx.fillStyle = "#fff"; ctx.beginPath(); ctx.arc(ballX, ballY, 8, 0, Math.PI*2); ctx.fill();

                // Ball movement
                ballX += ballDX; ballY += ballDY;

                // AI Logic
                aiY += (ballY - (aiY + paddleH/2)) * 0.1;

                // Wall collision
                if (ballY <= 0 || ballY >= canvas.height) ballDY *= -1;

                // Paddle collision
                if (ballX <= 20 && ballY >= paddleY && ballY <= paddleY + paddleH) {
                    ballDX *= -1.1; rallyCount++; 
                    if(rallyCount % 3 === 0) { pongScore++; updateXP(50); }
                }
                if (ballX >= 380 && ballY >= aiY && ballY <= aiY + paddleH) ballDX *= -1;

                // Score / Out of bounds
                if (ballX < 0) { gameOver(pongScore); return; } // Player lost
                if (ballX > 400) { ballX = 200; ballY = 200; ballDX = -5; ballDY = 5; } // AI missed (rare)
            }

            // --- CONTROLS ---
            document.addEventListener("keydown", (e) => {
                // Snake
                if (currentActiveGame === 'snake') {
                    if ((e.keyCode == 37 || e.key === 'a') && d != "RIGHT") { d = "LEFT"; e.preventDefault(); }
                    else if ((e.keyCode == 38 || e.key === 'w') && d != "DOWN") { d = "UP"; e.preventDefault(); }
                    else if ((e.keyCode == 39 || e.key === 'd') && d != "LEFT") { d = "RIGHT"; e.preventDefault(); }
                    else if ((e.keyCode == 40 || e.key === 's') && d != "UP") { d = "DOWN"; e.preventDefault(); }
                } 
                // Pong
                else if (currentActiveGame === 'pong') {
                    if (e.keyCode == 38 || e.key === 'w') { paddleY = Math.max(0, paddleY - 30); e.preventDefault(); }
                    if (e.keyCode == 40 || e.key === 's') { paddleY = Math.min(canvas.height - paddleH, paddleY + 30); e.preventDefault(); }
                }
            });

            // Start Initial Visual State
            initSnake(); drawSnake();

            // YOUTUBE SEARCH
            async function performSearch(q) {
                if(!q.trim()) return;
                const resEl = document.getElementById('zenYouTubeResults');
                const listEl = document.getElementById('zenYouTubeList');
                resEl.style.display = 'block';
                listEl.innerHTML = '<div class="text-center text-muted py-3 small"><i class="fa-solid fa-circle-notch fa-spin me-2"></i>Aranıyor...</div>';
                
                try {
                    const response = await fetch(`/api/YouTube/Search?query=${encodeURIComponent(q)}`);
                    if (response.ok) {
                        const videos = await response.json();
                        listEl.innerHTML = '';
                        if(videos.length === 0) listEl.innerHTML = '<div class="text-center text-muted py-2 small">Sonuç bulunamadı.</div>';
                        videos.forEach(v => {
                            const div = document.createElement('div');
                            div.className = 'd-flex align-items-center gap-2 p-2 rounded hover-bg';
                            div.style.cursor = 'pointer';
                            div.innerHTML = `<img src="${v.imageUrl}" style="width:50px; height:30px; object-fit:cover; border-radius:4px;"> <span class="small text-white text-truncate">${v.name}</span>`;
                            div.onclick = () => {
                                document.getElementById('zenYouTubeIframe').src = `https://www.youtube.com/embed/${v.id}?autoplay=1`;
                                resEl.style.display = 'none';
                                document.getElementById('zenYouTubeUrl').value = v.name;
                            };
                            listEl.appendChild(div);
                        });
                    }
                } catch(e) {
                    listEl.innerHTML = '<div class="text-center text-danger py-2 small">Hata oluştu.</div>';
                }
            }

            document.getElementById('zenYouTubeLoad').onclick = () => performSearch(document.getElementById('zenYouTubeUrl').value);
            document.getElementById('zenYouTubeUrl').onkeydown = (e) => { 
                if(e.key === 'Enter') performSearch(e.target.value); 
                else if(e.target.value.length > 2) {
                    // Quick debounce could go here
                }
            };
            
            // Close dropdown on click outside
            document.addEventListener('click', (e) => {
                if(!e.target.closest('.search-box')) document.getElementById('zenYouTubeResults').style.display = 'none';
            });

            // YOUTUBE PANEL RESIZE TOGGLE
            const btnToggleSize = document.getElementById('btnToggleYTSize');
            const mainGrid = document.querySelector('main');
            const ytPanel = document.getElementById('ytPanel');
            const gamePanel = document.getElementById('gamePanel');
            let isWide = false;

            btnToggleSize.onclick = () => {
                isWide = !isWide;
                if (isWide) {
                    mainGrid.style.gridTemplateColumns = "1fr 0.1fr";
                    gamePanel.style.opacity = "0.1";
                    gamePanel.style.pointerEvents = "none";
                    btnToggleSize.innerHTML = '<i class="fa-solid fa-compress"></i>';
                } else {
                    mainGrid.style.gridTemplateColumns = "1.2fr 1fr";
                    gamePanel.style.opacity = "1";
                    gamePanel.style.pointerEvents = "all";
                    btnToggleSize.innerHTML = '<i class="fa-solid fa-expand"></i>';
                }
            };
        });
    </script>
</body>
</html>
