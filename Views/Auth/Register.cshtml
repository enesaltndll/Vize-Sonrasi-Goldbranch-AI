@model GoldBranchAI.Models.AppUser
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr" data-bs-theme="dark" data-theme="gold-dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Katıl - GoldBranch AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        :root { --gb-gold: #fbbf24; --gb-dark: #0d1117; }
        body { background: var(--gb-dark); color: #c9d1d9; font-family: 'Inter', sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
        .register-box { width: 100%; max-width: 400px; padding: 40px; }
        .form-control { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); color: white; border-radius: 12px; padding: 12px 15px; }
        .form-control:focus { background: rgba(255,255,255,0.05); border-color: var(--gb-gold); color: white; box-shadow: none; }
        .btn-gold { background: var(--gb-gold); color: black; font-weight: 700; border-radius: 12px; padding: 12px; border: none; transition: all 0.3s; }
        .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(251, 191, 36, 0.3); }
        .btn-github { background: #24292f; color: white; border-radius: 12px; padding: 12px; border: 1px solid rgba(255,255,255,0.1); transition: all 0.3s; }
        .btn-github:hover { background: #2f363d; color: white; border-color: rgba(255,255,255,0.2); }
        .sep { display: flex; align-items: center; gap: 15px; margin: 25px 0; color: #484f58; font-size: 0.8rem; }
        .sep::before, .sep::after { content: ""; flex: 1; height: 1px; background: rgba(255,255,255,0.05); }
    </style>
</head>
<body>
    <div class="register-box">
        <div class="text-center mb-5">
            <i class="fa-solid fa-leaf text-warning fs-1 mb-3"></i>
            <h2 class="fw-bold text-white">Aramıza Katıl</h2>
            <p class="text-muted small">AI destekli verimlilik dünyasına ilk adımını at.</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert bg-danger bg-opacity-10 text-danger border-0 small mb-4">
                <i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.Error
            </div>
        }

        <a asp-action="GithubLogin" class="btn btn-github w-100 d-flex align-items-center justify-content-center gap-2 mb-4">
            <i class="fa-brands fa-github fs-5"></i> GitHub ile Hızlı Kayıt
        </a>

        <div class="sep">VEYA FORM İLE DEVAM ET</div>

        <form asp-controller="Auth" asp-action="Register" method="post" class="d-grid gap-3">
            <input asp-for="FullName" class="form-control" placeholder="Ad Soyad" required />
            <input asp-for="Email" type="email" class="form-control" placeholder="E-posta Adresi" required />
            <input asp-for="Password" type="password" class="form-control" placeholder="Şifre" required />
            
            <button type="submit" class="btn btn-gold mt-2">Kayıt Ol</button>
        </form>

        <p class="text-center mt-5 small text-muted">
            Zaten hesabın var mı? <a asp-action="Login" class="text-warning text-decoration-none fw-bold">Giriş Yap</a>
        </p>
    </div>
</body>
</html>
