@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr" data-bs-theme="dark" data-theme="gold-dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yeni Sifre - GoldBranch AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="gb-auth-shell">
    <div class="gb-auth-card">
        <h3 class="gb-auth-title"><i class="fa-solid fa-unlock-keyhole text-success me-2"></i>Yeni sifre olustur</h3>
        <p class="gb-auth-lead">Guclu bir sifre belirleyip girise devam et.</p>
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger mt-3 mb-0">@ViewBag.Error</div>
        }
        <form asp-action="ResetPassword" method="post" class="gb-stack mt-4">
            <input type="hidden" name="token" value="@ViewBag.Token" />
            <div><label class="form-label">Yeni sifre</label><input type="password" name="newPassword" class="form-control" required /></div>
            <div><label class="form-label">Sifre tekrar</label><input type="password" name="confirmPassword" class="form-control" required /></div>
            <button type="submit" class="btn btn-success fw-bold py-2">Sifreyi guncelle</button>
        </form>
    </div>
</body>
</html>
