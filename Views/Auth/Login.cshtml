@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr" data-bs-theme="dark" data-theme="gold-dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş - GoldBranch AI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="gb-auth-shell">
    <div class="gb-auth-card">
        <!-- Logo -->
        <div class="text-center mb-3">
            <div style="display:inline-flex;align-items:center;justify-content:center;width:64px;height:64px;border-radius:18px;background:linear-gradient(135deg,rgba(251,191,36,0.15),rgba(251,191,36,0.05));border:1px solid rgba(251,191,36,0.2);margin-bottom:12px;">
                <i class="fa-solid fa-leaf text-warning" style="font-size:1.8rem;filter:drop-shadow(0 0 10px rgba(251,191,36,0.5));"></i>
            </div>
        </div>

        <h1 class="gb-auth-title"><i class="fa-solid fa-leaf text-warning me-2" style="-webkit-text-fill-color:#fbbf24;"></i>GoldBranch AI</h1>
        <p class="gb-auth-lead">Hesabına giriş yap ve görev akışını kaldığın yerden sürdür.</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert border-0 rounded-3 mt-3 mb-0" style="background:rgba(239,68,68,0.12);color:#fca5a5;border:1px solid rgba(239,68,68,0.2) !important;">
                <i class="fa-solid fa-circle-exclamation me-1"></i> @ViewBag.Error
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert border-0 rounded-3 mt-3 mb-0" style="background:rgba(34,197,94,0.12);color:#86efac;border:1px solid rgba(34,197,94,0.2) !important;">
                <i class="fa-solid fa-check-circle me-1"></i> @TempData["Success"]
            </div>
        }

        <form asp-controller="Auth" asp-action="Login" method="post" class="gb-stack mt-4">
            <div>
                <label class="form-label">E-Posta</label>
                <div class="input-group">
                    <span class="input-group-text" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-right:0;border-radius:12px 0 0 12px;color:var(--gb-text-muted);"><i class="fa-solid fa-envelope"></i></span>
                    <input type="email" name="email" class="form-control" required autocomplete="email" placeholder="ornek@firma.com" style="border-radius:0 12px 12px 0;" />
                </div>
            </div>
            <div>
                <div class="d-flex justify-content-between">
                    <label class="form-label">Şifre</label>
                    <a asp-action="ForgotPassword" class="gb-inline-note text-warning text-decoration-none">Şifremi unuttum</a>
                </div>
                <div class="input-group">
                    <span class="input-group-text" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-right:0;border-radius:12px 0 0 12px;color:var(--gb-text-muted);"><i class="fa-solid fa-lock"></i></span>
                    <input type="password" name="password" class="form-control" required placeholder="••••••••" style="border-radius:0 12px 12px 0;" />
                </div>
            </div>
            <button type="submit" class="btn btn-warning fw-bold py-2">
                <i class="fa-solid fa-right-to-bracket me-2"></i>Giriş Yap
            </button>
        </form>

        <div class="d-flex align-items-center my-3" style="gap:12px;">
            <div style="flex:1;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.08),transparent);"></div>
            <span class="text-muted small" style="font-size:0.7rem;letter-spacing:1px;">VEYA</span>
            <div style="flex:1;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.08),transparent);"></div>
        </div>

        <a asp-action="GoogleLogin" class="btn btn-outline-light w-100 d-flex align-items-center justify-content-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Google ile giriş
        </a>

        <div class="text-center mt-4">
            <a asp-action="Register" class="text-decoration-none" style="color:var(--gb-text-secondary);transition:color 0.3s;">
                Hesabın yok mu? <span class="text-warning fw-bold">Kayıt ol</span>
            </a>
        </div>

        <!-- Trust indicators -->
        <div class="d-flex justify-content-center gap-3 mt-4 pt-3" style="border-top:1px solid rgba(255,255,255,0.04);">
            <span class="text-muted d-flex align-items-center gap-1" style="font-size:0.7rem;"><i class="fa-solid fa-shield-halved" style="color:#34d399;"></i> 256-bit SSL</span>
            <span class="text-muted d-flex align-items-center gap-1" style="font-size:0.7rem;"><i class="fa-solid fa-lock" style="color:#38bdf8;"></i> KVKK</span>
            <span class="text-muted d-flex align-items-center gap-1" style="font-size:0.7rem;"><i class="fa-solid fa-globe" style="color:#a78bfa;"></i> TR/EN</span>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
