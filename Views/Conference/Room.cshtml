@{
    Layout = "_Layout";
    ViewData["Title"] = "Toplantı Odası: " + ViewBag.RoomId;
}

<div class="gb-page h-100 d-flex flex-column" style="margin-top: -1rem;">
    <!-- HEADER -->
    <div class="d-flex align-items-center justify-content-between mb-3 px-2">
        <div>
            <span class="badge bg-danger pulse-danger me-2">CANLI TOPLANTI</span>
            <span class="fw-bold text-light">Oda: <span class="text-warning">@ViewBag.RoomId</span></span>
        </div>
        <div>
            <button onclick="copyRoomLink()" class="btn btn-outline-info btn-sm rounded-pill px-3 me-2">
                <i class="fa-solid fa-link me-1"></i>Linki Kopyala
            </button>
            <a asp-action="Index" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                <i class="fa-solid fa-phone-slash me-1"></i>Ayrıl
            </a>
        </div>
    </div>

    <!-- JITSI CONTAINER -->
    <div id="jitsi-container" class="flex-grow-1 rounded-4 shadow-lg border border-secondary overflow-hidden" style="background: #000; min-height: 70vh;"></div>
</div>

@section Scripts {
    <script src="https://meet.jit.si/external_api.js"></script>
    <script>
        window.onload = () => {
            const userRole = '@(ViewBag.UserRole)';
            const isModerator = (userRole === 'Admin' || userRole === 'Proje Sefi');

            const domain = "meet.jit.si";
            const options = {
                roomName: "GoldBranchAI_@ViewBag.RoomId",
                width: '100%',
                height: '100%',
                parentNode: document.querySelector('#jitsi-container'),
                userInfo: {
                    displayName: '@User.Identity.Name',
                    email: '@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value'
                },
                configOverwrite: {
                    startWithAudioMuted: true,
                    disableDeepLinking: true,
                    prejoinPageEnabled: false,
                    enableNoAudioDetection: true,
                    enableNoVideoDetection: true,
                    // Moderator features
                    remoteVideoMenu: {
                        disabled: !isModerator
                    },
                    disableRemoteMute: !isModerator
                },
                interfaceConfigOverwrite: {
                    TOOLBAR_BUTTONS: [
                        'microphone', 'camera', 'closedcaptions', 'desktop', 'embedmeeting', 'fullscreen',
                        'fodeviceselection', 'hangup', 'profile', 'chat', 'recording',
                        'livestreaming', 'etherpad', 'sharedvideo', 'settings', 'raisehand',
                        'videoquality', 'filmstrip', 'invite', 'feedback', 'stats', 'shortcuts',
                        'tileview', 'videobackgroundblur', 'download', 'help', 
                        isModerator ? 'mute-everyone' : null,
                        isModerator ? 'security' : null
                    ].filter(b => b !== null),
                    SETTINGS_SECTIONS: [ 'devices', 'language', 'moderator', 'profile', 'calendar' ],
                    SHOW_JITSI_WATERMARK: false,
                    GENERATE_ROOMNAMES_ON_WELCOME_PAGE: false,
                    DISPLAY_WELCOME_PAGE_CONTENT: false
                }
            };
            const api = new JitsiMeetExternalAPI(domain, options);
            
            if (isModerator) {
                api.addEventListener('videoConferenceJoined', () => {
                    // Force moderator UI state if possible on public instance
                    // Note: Full moderation usually requires Jitsi Token (JWT)
                    console.log("Moderator role active for @User.Identity.Name");
                });
            }

            api.addEventListener('videoConferenceLeft', () => {
                window.location.href = '/Conference/Index';
            });
        };

        function copyRoomLink() {
            const url = window.location.href;
            navigator.clipboard.writeText(url).then(() => {
                Swal.fire({
                    icon: 'success',
                    title: 'Bağlantı Kopyalandı!',
                    text: 'Oda linkini ekip arkadaşlarınıza gönderebilirsiniz.',
                    background: '#0d1117',
                    color: '#fff',
                    timer: 2000,
                    showConfirmButton: false
                });
            });
        }
    </script>
}
