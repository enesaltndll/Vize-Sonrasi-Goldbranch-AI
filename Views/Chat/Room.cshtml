@model IEnumerable<GoldBranchAI.Models.ChatMessage>

@{
    var targetUser = ViewBag.TargetUser as GoldBranchAI.Models.AppUser;
    var targetGroup = ViewBag.TargetGroup as GoldBranchAI.Models.ChatGroup;
    bool isGroup = (bool?)ViewBag.IsGroup ?? false;
    int currentUserId = (int?)ViewBag.CurrentUserId ?? 0;
    string userRole = (ViewBag.UserRole as string) ?? "";
    
    string title = isGroup ? (targetGroup?.GroupName ?? "Grup") : (targetUser?.FullName ?? "Kullanıcı");
    string subtitle = isGroup ? $"{(targetGroup?.Members?.Count ?? 0)} {L.Get("MembersCount")}" : L.Get("SystemConnected");
    string iconClass = isGroup ? "fa-users text-warning" : "fa-user-astronaut text-info";
    string groupEmoji = isGroup && !string.IsNullOrEmpty(targetGroup?.GroupAvatar) ? targetGroup.GroupAvatar : "";
    string iconBg = isGroup ? "rgba(251, 191, 36, 0.1)" : "rgba(34, 211, 238, 0.1)";

    Layout = null;

    // Group messages by date
    var messageList = Model.ToList();
    string lastDateStr = "";
}

<!DOCTYPE html>
<html data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/chat-room.css" asp-append-version="true" />
</head>
<body>
    <div class="chat-wrapper">
        <!-- HEADER -->
        <div class="chat-header">
            <div class="chat-header-avatar">
                @if (isGroup && !string.IsNullOrEmpty(groupEmoji))
                {
                    <span class="group-emoji">@groupEmoji</span>
                }
                else
                {
                    <i class="fa-solid @iconClass fs-5"></i>
                }
            </div>
            <div class="chat-header-info">
                <h6 class="mb-0 fw-bold text-light">@title</h6>
                <small class="@(isGroup ? "text-warning" : "text-success")" style="font-size:0.65rem; letter-spacing:0.5px; font-weight:600;">
                    <i class="fa-solid fa-circle me-1" style="font-size:0.35rem;vertical-align:middle;"></i> @subtitle
                </small>
            </div>
            @if (userRole == "Admin" && !isGroup)
            {
                <div class="ms-auto"><span class="badge bg-danger rounded-pill px-3 py-2" style="font-size:0.6rem;"><i class="fa-solid fa-satellite-dish me-1"></i> @L.Get("WatchMode")</span></div>
            }
            @if (isGroup && (userRole == "Admin" || userRole == "Proje Sefi"))
            {
                <div class="ms-auto">
                    <button class="btn btn-sm ai-summarize-btn" onclick="summarizeChat()" id="btnSummarize">
                        <i class="fa-solid fa-wand-magic-sparkles me-1 text-light"></i> @L.Get("AISummarize")
                    </button>
                </div>
            }
        </div>
        
        <!-- BODY -->
        <div class="chat-body" id="chatBox">
            @foreach (var msg in messageList)
            {
                // Date separator
                var dateStr = msg.SentAt.ToString("yyyy-MM-dd");
                if (dateStr != lastDateStr)
                {
                    lastDateStr = dateStr;
                    var isToday = msg.SentAt.Date == DateTime.Today;
                    var isYesterday = msg.SentAt.Date == DateTime.Today.AddDays(-1);
                    var dateLabel = isToday ? L.Get("Today") : (isYesterday ? L.Get("Yesterday") : msg.SentAt.ToString("dd MMMM yyyy"));
                    <div class="date-separator">
                        <span>@dateLabel</span>
                    </div>
                }

                bool isMine = msg.SenderId == currentUserId;
                var senderInitial = (msg.Sender?.FullName ?? "?").Substring(0, 1).ToUpper();
                
                <div class="msg-row @(isMine ? "msg-row-mine" : "msg-row-theirs")">
                    @if (!isMine)
                    {
                        <div class="msg-avatar" title="@msg.Sender?.FullName">@senderInitial</div>
                    }
                    <div class="msg-bubble @(isMine ? "msg-mine" : "msg-theirs")">
                        @if (!isMine && isGroup)
                        {
                            <span class="sender-name">@msg.Sender?.FullName</span>
                        }
                        <div class="msg-text">@msg.MessageText</div>
                        <span class="msg-time">@msg.SentAt.ToString("HH:mm") @(isMine ? "✓✓" : "")</span>
                    </div>
                    @if (userRole == "Admin" || userRole == "Proje Sefi")
                    {
                        <div class="ms-1 me-1 d-flex align-items-center">
                            <button onclick="deleteMessage(@msg.Id, this)" class="btn btn-sm btn-link text-danger p-0 border-0 bg-transparent" style="opacity:1 !important;" title="@L.Get("Delete")">
                                <i class="fa-solid fa-trash-can" style="font-size:0.85rem;"></i>
                            </button>
                        </div>
                    }
                </div>
            }
            @if (!messageList.Any())
            {
                <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted opacity-50">
                    <div style="width:60px;height:60px;border-radius:16px;background:rgba(255,255,255,0.03);display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
                        <i class="fa-solid fa-shield-halved fa-2x" style="opacity:0.4;"></i>
                    </div>
                    <p class="small mb-0">@L.Get("ChatEncrypted")</p>
                </div>
            }
        </div>
        
        <!-- FOOTER -->
        <div class="chat-footer">
            <form id="chatForm" onsubmit="submitMessage(event)" class="d-flex gap-2 align-items-center">
                <input type="hidden" id="receiverId" value="@(targetUser?.Id)" />
                <input type="hidden" id="groupId" value="@(targetGroup?.Id)" />
                <input type="text" id="messageText" class="form-control" placeholder="@L.Get("TypeMessagePlaceholder")" required autocomplete="off" />
                <button type="submit" class="send-button">
                    <i class="fa-solid fa-paper-plane"></i>
                </button>
            </form>
        </div>
    </div>

    <!-- SignalR for Chat -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        var currentUserIdStr = "@currentUserId";
        var isGroup = @(isGroup.ToString().ToLower());
        var targetGroupIdStr = "@(targetGroup?.Id)";
        var targetUserIdStr = "@(targetUser?.Id)";
        
        var chatBox = document.getElementById("chatBox");
        if(chatBox) chatBox.scrollTop = chatBox.scrollHeight;

        function appendMessage(isMine, senderName, msgText, timeStr) {
            let initial = (senderName || '?').charAt(0).toUpperCase();
            let avatarHtml = !isMine ? `<div class="msg-avatar" title="${senderName}">${initial}</div>` : '';
            let senderHtml = !isMine && isGroup ? `<span class="sender-name">${senderName}</span>` : '';
            let checkHtml = isMine ? '✓✓' : '';
            
            let html = `
                <div class="msg-row ${isMine ? 'msg-row-mine' : 'msg-row-theirs'} fade-in-up">
                    ${avatarHtml}
                    <div class="msg-bubble ${isMine ? 'msg-mine' : 'msg-theirs'}">
                        ${senderHtml}
                        <div class="msg-text">${msgText}</div>
                        <span class="msg-time">${timeStr} ${checkHtml}</span>
                    </div>
                </div>
            `;
            chatBox.insertAdjacentHTML("beforeend", html);
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        const chatConnection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();
            
        chatConnection.on("ReceiveGroupMessage", function(groupId, senderId, senderName, messageText, timeStr) {
            if(isGroup && groupId === targetGroupIdStr) {
                appendMessage(senderId === currentUserIdStr, senderName, messageText, timeStr);
            }
        });
        
        chatConnection.on("ReceivePrivateMessage", function(receiverId, senderId, senderName, messageText, timeStr) {
            if(!isGroup && (senderId === targetUserIdStr || (senderId === currentUserIdStr && receiverId === targetUserIdStr))) {
               appendMessage(senderId === currentUserIdStr, senderName, messageText, timeStr);
            }
        });

        chatConnection.start().catch(err => console.error("Chat Hub Error:", err));

        function submitMessage(e) {
            e.preventDefault();
            const btn = document.querySelector('.send-button');
            const receiverId = document.getElementById('receiverId').value;
            const groupId = document.getElementById('groupId').value;
            const msgInput = document.getElementById('messageText');
            const msg = msgInput.value;
            if(!msg.trim()) return;

            msgInput.disabled = true;
            btn.disabled = true;

            let body = 'messageText=' + encodeURIComponent(msg);
            if(receiverId) body += '&receiverId=' + receiverId;
            if(groupId) body += '&groupId=' + groupId;

            fetch('/Chat/SendMessage', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: body
            }).then(() => {
                msgInput.value = '';
                msgInput.disabled = false;
                btn.disabled = false;
                msgInput.focus();
            }).catch(() => {
                msgInput.disabled = false;
                btn.disabled = false;
            });
        }
        
        function summarizeChat() {
            var btn = document.getElementById('btnSummarize');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Özetleniyor...';
            btn.disabled = true;
            
            fetch('/Ai/SummarizeGroup', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ GroupId: parseInt(targetGroupIdStr) })
            })
            .then(res => res.json())
            .then(data => {
                btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles text-light"></i> AI Özetle';
                btn.disabled = false;
                if(data.success) {
                    alert("AI ÖZETİ:\n\n" + data.summary);
                } else {
                    alert("Hata: " + data.error);
                }
            }).catch(e => {
                alert("Sistem hatası.");
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles text-light"></i> AI Özetle';
            });
        }

        function deleteMessage(msgId, btnElement) {
            if(!confirm('@Html.Raw(L.Get("TaskDeleteConfirmation") ?? "Bu mesajı kalıcı olarak silmek istediğinize emin misiniz?")')) return;
            
            var formData = new FormData();
            formData.append("messageId", msgId);
            
            fetch('/Chat/DeleteMessage', {
                method: 'POST',
                body: formData
            }).then(res => res.json())
            .then(data => {
                if(data.success) {
                    var row = btnElement.closest('.msg-row');
                    if(row) row.remove();
                } else {
                    alert(data.message || "Mesaj silinemedi.");
                }
            }).catch(() => alert("Sistem hatası."));
        }
    </script>
</body>
</html>
