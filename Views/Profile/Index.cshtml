@model GoldBranchAI.Models.AppUser

@{
    ViewData["Title"] = L.Get("Profile");
    var percent = ViewBag.OverallTasks > 0 ? (ViewBag.CompletedTasks * 100) / ViewBag.OverallTasks : 0;
    bool isOwnProfile = ViewBag.IsOwnProfile ?? false;
}

<style>
    .gh-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; transition: all 0.3s; height: 100%; }
    .gh-card:hover { background: rgba(255,255,255,0.05); transform: translateY(-5px); border-color: #fbbf24; }
    .gh-lang { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 5px; }
    .profile-glass { background: linear-gradient(135deg, rgba(251, 191, 36, 0.1) 0%, rgba(13, 17, 23, 0.8) 100%); backdrop-filter: blur(20px); border: 1px solid rgba(251, 191, 36, 0.15); border-radius: 24px; }
</style>

<div class="gb-page fade-in-up" style="max-width: 1200px; margin: 0 auto;">
    
    <!-- HEADER CARD -->
    <div class="profile-glass p-4 mb-5 shadow-lg">
        <div class="row align-items-center">
            <div class="col-md-3 text-center">
                <div class="position-relative d-inline-block">
                    <img id="userAvatarImg" src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "https://ui-avatars.com/api/?name=" + Model.FullName + "&background=fbbf24&color=000" : Model.AvatarUrl)" 
                         class="rounded-circle border border-4 border-warning shadow" style="width: 160px; height: 160px; object-fit: cover;" />
                    @if(isOwnProfile) {
                        <button onclick="changeAvatar()" class="btn btn-sm btn-warning position-absolute bottom-0 end-0 rounded-circle shadow">
                            <i class="fa-solid fa-camera"></i>
                        </button>
                    }
                </div>
            </div>
            <div class="col-md-6">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <h1 class="fw-bold text-white mb-0">@Model.FullName</h1>
                    <span class="badge bg-warning text-dark fw-bold">@Model.Role</span>
                </div>
                <p class="text-muted mb-4">@Model.Bio</p>
                <div class="d-flex gap-4">
                    <div>
                        <h4 class="fw-bold text-warning mb-0">@ViewBag.CompletedTasks</h4>
                        <small class="text-muted text-uppercase">Tamamlanan</small>
                    </div>
                    <div class="border-start border-secondary ps-4">
                        <h4 class="fw-bold text-info mb-0">@Model.ExperiencePoints</h4>
                        <small class="text-muted text-uppercase">XP Puanı</small>
                    </div>
                    <div class="border-start border-secondary ps-4">
                        <h4 class="fw-bold text-success mb-0">@(Model.UserBadges?.Count ?? 0)</h4>
                        <small class="text-muted text-uppercase">Rozetler</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 text-end">
                @if(isOwnProfile) {
                    <a href="/Profile/Details/@Model.Id" class="btn btn-outline-warning rounded-pill px-4 mb-2 w-100">
                        <i class="fa-solid fa-share-nodes me-2"></i>Kamu Profili
                    </a>
                } else {
                    @if(ViewBag.FriendshipStatus == null) {
                        <button onclick="addFriend(@Model.Id)" class="btn btn-warning rounded-pill px-4 mb-2 w-100">
                            <i class="fa-solid fa-user-plus me-2"></i>Arkadaş Ekle
                        </button>
                    } else {
                        <button class="btn btn-success rounded-pill px-4 mb-2 w-100" disabled>
                            <i class="fa-solid fa-check me-2"></i>Arkadaşsınız
                        </button>
                    }
                }
                @if(!string.IsNullOrEmpty(Model.GithubUsername)) {
                    <a href="https://github.com/@Model.GithubUsername" target="_blank" class="btn btn-dark rounded-pill px-4 w-100 border-secondary">
                        <i class="fa-brands fa-github me-2"></i>GitHub Takip Et
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- LEFT: GITHUB STATS & REPOS -->
        <div class="col-lg-8">
            <h3 class="fw-bold text-white mb-4"><i class="fa-brands fa-github text-warning me-2"></i> GitHub Projesi & Başarımlar</h3>
            
            @if(ViewBag.GithubRepos != null) {
                <div class="row g-3">
                    @foreach (var repo in ViewBag.GithubRepos) {
                        <div class="col-md-6">
                            <div class="gh-card p-3 d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="fw-bold mb-0 text-info">
                                        <i class="fa-solid fa-book-bookmark me-2 opacity-50"></i>
                                        <a href="@repo.html_url" target="_blank" class="text-decoration-none text-info">@repo.name</a>
                                    </h6>
                                    <span class="badge bg-secondary opacity-50 small">@repo.visibility</span>
                                </div>
                                <p class="text-muted small mb-3 flex-grow-1">@(repo.description ?? "Açıklama belirtilmemiş.")</p>
                                <div class="d-flex align-items-center gap-3 mt-auto">
                                    @if(repo.language != null) {
                                        <span class="small text-muted"><span class="gh-lang" style="background:#fbbf24;"></span> @repo.language</span>
                                    }
                                    <span class="small text-muted"><i class="fa-regular fa-star me-1"></i> @repo.stargazers_count</span>
                                    <span class="small text-muted"><i class="fa-solid fa-code-fork me-1"></i> @repo.forks_count</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            } else if (!string.IsNullOrEmpty(Model.GithubUsername)) {
                <div class="alert bg-dark border-secondary text-center py-5 rounded-4">
                    <i class="fa-solid fa-spinner fa-spin fa-2x text-warning mb-3"></i>
                    <p class="mb-0">GitHub verileri yüklenemedi veya kullanıcı bulunamadı.</p>
                </div>
            } else {
                <div class="alert bg-dark border-secondary text-center py-5 rounded-4">
                    <i class="fa-brands fa-github fa-3x text-muted mb-3 opacity-25"></i>
                    <p class="mb-0 text-muted">GitHub hesabı henüz bağlanmamış.</p>
                </div>
            }
        </div>

        <!-- RIGHT: BADGES & RADAR -->
        <div class="col-lg-4">
            <h3 class="fw-bold text-white mb-4"><i class="fa-solid fa-medal text-warning me-2"></i> Başarı Vitrini</h3>
            <div class="d-flex flex-wrap gap-2">
                @if (Model.UserBadges != null && Model.UserBadges.Any()) {
                    foreach (var badge in Model.UserBadges) {
                        <div class="badge-item text-center p-2 rounded-3 mb-3" style="width: 45%; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);" title="@badge.Description">
                            <img src="@badge.IconUrl" style="width: 50px; height: 50px;" class="mb-2" />
                            <div class="small fw-bold text-white">@badge.BadgeName</div>
                        </div>
                    }
                } else {
                    <p class="text-muted italic">Henüz kazanılmış rozet bulunmuyor.</p>
                }
            </div>

            <!-- TASK RADAR MINI -->
            <div class="profile-glass p-4 mt-4">
                <h6 class="fw-bold text-warning text-uppercase small mb-3">Sistem Verimliliği</h6>
                <div class="progress mb-2" style="height: 10px; background: rgba(255,255,255,0.05);">
                    <div class="progress-bar bg-warning" style="width: @percent%;"></div>
                </div>
                <small class="text-muted">Proje Başarı Oranı: %@percent</small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeAvatar() {
            Swal.fire({
                title: 'Profil Resmini Güncelle',
                input: 'url',
                inputPlaceholder: 'Avatar URL adresi girin...',
                background: '#0d1117', color: '#fff',
                showCancelButton: true, confirmButtonColor: '#fbbf24', confirmButtonText: 'Kaydet'
            }).then((result) => {
                if (result.isConfirmed && result.value) {
                    fetch('/Profile/UpdateAvatar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: 'avatarUrl=' + encodeURIComponent(result.value)
                    }).then(res => res.json()).then(data => {
                        if(data.success) {
                            document.getElementById('userAvatarImg').src = result.value;
                            Swal.fire({ icon: 'success', title: 'Güncellendi!', background: '#0d1117', color: '#fbbf24', timer: 1500, showConfirmButton: false });
                        }
                    });
                }
            });
        }

        function addFriend(id) {
            fetch('/Profile/AddFriend?friendId=' + id, { method: 'POST' })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    Swal.fire({ icon: 'success', title: 'Eklendi!', text: 'Arkadaş listenize eklendi.', background: '#0d1117', color: '#fbbf24', timer: 2000, showConfirmButton: false })
                    .then(() => location.reload());
                } else {
                    Swal.fire({ icon: 'error', title: 'Hata', text: data.message, background: '#0d1117', color: '#f87171' });
                }
            });
        }
    </script>
}
