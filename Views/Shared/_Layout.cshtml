    <script>
        // 💚 SAĞLIK KORUMA SİSTEMİ (WELLNESS GUARDIAN)
        document.addEventListener("DOMContentLoaded", () => {
            // Bildirim izni iste (1 kez)
            if ('Notification' in window && Notification.permission === 'default') {
                Notification.requestPermission();
            }

            const W = {
                EYE_INTERVAL_MS: 45 * 1000,        // 45 saniye (Göz Molası)
                POSTURE_INTERVAL_MS: 90 * 1000,    // 1.5 dk (Kalk & Esne)
                LOCK_AFTER_MS: 150 * 1000,         // 2.5 dk (Zorunlu Mola)
                MIN_BREAK_MS: 30 * 1000,           // 30 saniye kilit süresi

                STORAGE: {
                    lastBreakAt: 'gb_wellness_last_break_at',
                    lastEyeAt: 'gb_wellness_last_eye_at',
                    lastPostureAt: 'gb_wellness_last_posture_at',
                    lockUntil: 'gb_wellness_lock_until',
                    lockActiveSince: 'gb_wellness_lock_active_since',
                    welcomeKey: 'gb_wellness_welcome_'
                }
            };

            const lockOverlay = document.getElementById('wellnessLockOverlay');
            const lockCountdown = document.getElementById('wellnessLockCountdown');
            const lockBar = document.getElementById('wellnessLockBar');
            const lockDoneBtn = document.getElementById('wellnessLockDoneBtn');
            const lockSnoozeBtn = document.getElementById('wellnessLockSnoozeBtn');

            function now() { return Date.now(); }
            function getNum(key, fallback = 0) {
                const n = parseInt(localStorage.getItem(key) || '');
                return Number.isFinite(n) ? n : fallback;
            }
            function setNum(key, value) { localStorage.setItem(key, String(value)); }

            async function sendSystemNotification(tip) {
                if (!('Notification' in window)) return;
                if (!('serviceWorker' in navigator)) return;
                if (Notification.permission !== 'granted') return;

                const title = 'GoldBranch AI - ' + tip.title;
                const body = (tip.message || '').replace(/<[^>]*>/g, '');
                const payload = {
                    type: 'WELLNESS_NOTIFICATION',
                    title,
                    body,
                    icon: 'https://cdn-icons-png.flaticon.com/512/9334/9334400.png',
                    tag: 'wellness-' + Date.now()
                };

                // Prefer SW controller messaging (shows up in OS notification center)
                if (navigator.serviceWorker.controller) {
                    navigator.serviceWorker.controller.postMessage(payload);
                    return;
                }

                // Fallback: showNotification via ready registration
                const registration = await navigator.serviceWorker.ready;
                await registration.showNotification(title, { body, icon: payload.icon, tag: payload.tag });
            }

            function markBreakTaken() {
                const t = now();
                setNum(W.STORAGE.lastBreakAt, t);
                setNum(W.STORAGE.lastEyeAt, t);
                setNum(W.STORAGE.lastPostureAt, t);
            }

            function isLocked() {
                const until = getNum(W.STORAGE.lockUntil, 0);
                return until > now();
            }

            function showLockOverlay() {
                if (!lockOverlay) return;
                lockOverlay.style.display = 'flex';
                document.body.style.overflow = 'hidden';
            }

            function hideLockOverlay() {
                if (!lockOverlay) return;
                lockOverlay.style.display = 'none';
                document.body.style.overflow = '';
            }

            function startLock(minMs) {
                const startAt = now();
                const until = startAt + Math.max(W.MIN_BREAK_MS, minMs);
                setNum(W.STORAGE.lockActiveSince, startAt);
                setNum(W.STORAGE.lockUntil, until);
                showLockOverlay();
            }

            function updateLockUI() {
                if (!lockOverlay || lockOverlay.style.display === 'none') return;
                const startAt = getNum(W.STORAGE.lockActiveSince, now());
                const until = getNum(W.STORAGE.lockUntil, now());
                const total = Math.max(1, until - startAt);
                const remaining = Math.max(0, until - now());
                const done = remaining === 0;

                const m = Math.floor(remaining / 60000).toString().padStart(2, '0');
                const s = Math.floor((remaining % 60000) / 1000).toString().padStart(2, '0');
                if (lockCountdown) lockCountdown.textContent = `${m}:${s}`;

                const pct = Math.min(100, Math.max(0, ((total - remaining) / total) * 100));
                if (lockBar) lockBar.style.width = pct + '%';

                if (lockDoneBtn) lockDoneBtn.disabled = !done;
            }

            // Hierarchical wellness engine (tek döngü)
            async function tick() {
                // Lock devam ediyorsa sadece UI güncelle
                if (isLocked()) {
                    showLockOverlay();
                    updateLockUI();
                    return;
                } else {
                    hideLockOverlay();
                }

                const t = now();
                const lastBreakAt = getNum(W.STORAGE.lastBreakAt, t);
                const lastEyeAt = getNum(W.STORAGE.lastEyeAt, lastBreakAt);
                const lastPostureAt = getNum(W.STORAGE.lastPostureAt, lastBreakAt);
                const sinceBreak = t - lastBreakAt;

                // En son aşama: 90 dk molasız → kilit
                if (sinceBreak >= W.LOCK_AFTER_MS) {
                    // Kullanıcı gerçekten mola vermeden devam etmiş demek
                    startLock(W.MIN_BREAK_MS);
                    await sendSystemNotification({
                        title: 'Zorunlu Mola',
                        message: '90 dakikadır mola vermedin. 3 dakikalık zorunlu mola başlatıldı.'
                    });
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'warning',
                            title: '🛑 Zorunlu Mola',
                            html: 'Sağlığın için ekranı kilitledim. <b>3 dakika</b> mola ver, sonra devam edebilirsin.',
                            background: '#0d1117',
                            color: '#f0f6fc',
                            confirmButtonText: 'Tamam',
                            confirmButtonColor: '#fbbf24'
                        });
                    }
                    return;
                }

                // 60 dk: postür/kalk uyarısı (gösterilmediyse)
                if (sinceBreak >= W.POSTURE_INTERVAL_MS && (t - lastPostureAt) >= W.POSTURE_INTERVAL_MS) {
                    setNum(W.STORAGE.lastPostureAt, t);
                    await sendSystemNotification({
                        title: 'Kalk & Postür',
                        message: '1 saattir ekrandasın. Ayağa kalk, omuzlarını gevşet, 45 sn esne.'
                    });

                    if (!document.hidden && typeof Swal !== 'undefined') {
                        const res = await Swal.fire({
                            icon: 'info',
                            title: '🧍 1 Saat Oldu',
                            html: 'Ayağa kalk ve <b>45 saniye</b> esne. Duruşunu düzelt, omuzlarını gevşet.',
                            background: '#0d1117',
                            color: '#f0f6fc',
                            showCancelButton: true,
                            confirmButtonText: 'Mola verdim',
                            cancelButtonText: 'Sonra',
                            confirmButtonColor: '#34d399',
                            cancelButtonColor: '#64748b',
                            timer: 15000,
                            timerProgressBar: true
                        });
                        if (res.isConfirmed) {
                            markBreakTaken();
                        }
                    }
                    return;
                }

                // 30 dk: göz uyarısı (gösterilmediyse)
                if (sinceBreak >= W.EYE_INTERVAL_MS && (t - lastEyeAt) >= W.EYE_INTERVAL_MS) {
                    setNum(W.STORAGE.lastEyeAt, t);
                    await sendSystemNotification({
                        title: 'Göz Molası',
                        message: '20-20-20: 20 sn boyunca uzağa bak.'
                    });

                    if (!document.hidden && typeof Swal !== 'undefined') {
                        const res = await Swal.fire({
                            icon: 'warning',
                            title: '👁️ 30 Dakika Oldu',
                            html: '<b>20-20-20</b> kuralı: 20 saniye boyunca uzağa bak.',
                            background: '#0d1117',
                            color: '#f0f6fc',
                            showCancelButton: true,
                            confirmButtonText: 'Yaptım',
                            cancelButtonText: 'Sonra',
                            confirmButtonColor: '#38bdf8',
                            cancelButtonColor: '#64748b',
                            timer: 12000,
                            timerProgressBar: true
                        });
                        if (res.isConfirmed) {
                            // göz molası sayalım ama break'i resetlemeyelim (mikro mola)
                            // kullanıcı isterse 60dk zinciri bozulmasın; sadece göz uyarısını ertele.
                            setNum(W.STORAGE.lastEyeAt, now());
                        }
                    }
                }
            }

            // Lock overlay butonları
            if (lockDoneBtn) {
                lockDoneBtn.addEventListener('click', () => {
                    if (isLocked()) return;
                    markBreakTaken();
                    localStorage.removeItem(W.STORAGE.lockUntil);
                    localStorage.removeItem(W.STORAGE.lockActiveSince);
                    hideLockOverlay();
                });
            }
            if (lockSnoozeBtn) {
                lockSnoozeBtn.addEventListener('click', () => {
                    const until = getNum(W.STORAGE.lockUntil, now());
                    setNum(W.STORAGE.lockUntil, until + (2 * 60 * 1000));
                    updateLockUI();
                });
            }

            // İlk kurulum veya eski session (4 saati geçmişse) sıfırla ki girişte hemen uyarmasın
            const lastBrk = getNum(W.STORAGE.lastBreakAt, 0);
            if (!lastBrk || (now() - lastBrk > 4 * 60 * 60 * 1000)) {
                markBreakTaken();
                // Kilitli kalmışsa kilidi de kaldır
                if (isLocked()) {
                    localStorage.removeItem(W.STORAGE.lockUntil);
                    localStorage.removeItem(W.STORAGE.lockActiveSince);
                }
            }

            // Sayfa yenilense bile kilit sürsün
            if (isLocked()) showLockOverlay();
            updateLockUI();

            // Tek interval: Her saniye kontrol et
            setInterval(updateLockUI, 1000);
            setInterval(tick, 1000);
            tick();

            // İlk kurulum veya session sıfırlamasından sonra hoşgeldin bildirimi
            const todayKey = "gb_wellness_welcome_v2_" + new Date().toISOString().slice(0, 10);
            if (!localStorage.getItem(todayKey)) {
                localStorage.setItem(todayKey, "1");
                setTimeout(() => {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            toast: true,
                            position: 'bottom-start',
                            icon: 'success',
                            title: '🛡️ Wellness Guardian Aktif',
                            text: 'Gözlerinizi ve duruşunuzu korumak için mola sistemi devrede.',
                            showConfirmButton: false,
                            timer: 5000,
                            background: '#0d1117',
                            color: '#10b981'
                        });
                    }
                }, 5000);
            }
        });
    </script>

    <script>
        // ZEN MODU VE POMODORO MANTIĞI (ENHANCED)
        document.addEventListener("DOMContentLoaded", () => {
            const zenBtn = document.getElementById('zenModeBtn');
            const zenOverlay = document.getElementById('zenModeOverlay');
            const zenCloseBtn = document.getElementById('zenCloseBtn');
            
            let isZen = false;

            // Motivational Quotes
            const zenQuotes = [
                '"Odaklanma enerjinin yoğunlaşmasıdır." — Tony Robbins',
                '"Büyük işler, küçük adımların toplamıdır."',
                '"Flow halinde zaman durur, verimlilik patlar."',
                '"Dikkat dağınıklığı değil, odağını seç."',
                '"Her pomodoro bir zafer, her mola bir ödül."',
                '"Derinlere dal, yüzeyde kalanlar sıradan kalır."',
                '"Sessizlikte üretilen, gürültüde asla yapılamaz."',
                '"Şu an, hayatının en verimli anı olabilir."',
                '"Bir seferde bir görev. Basit ama güçlü."',
                '"Odaklan, uygula, tekrarla. Başarı formülü bu."'
            ];

            // Breathing text cycle
            const breathTexts = ['Nefes Al', 'Tut...', 'Nefes Ver', 'Bekle...'];
            let breathIdx = 0;
            setInterval(() => {
                const el = document.getElementById('zenBreathText');
                if (el && isZen) {
                    breathIdx = (breathIdx + 1) % breathTexts.length;
                    el.textContent = breathTexts[breathIdx];
                }
            }, 2000);

            // Session tracking
            const todayKey = 'gb_zen_sessions_' + new Date().toISOString().slice(0, 10);
            function getSessions() { return parseInt(localStorage.getItem(todayKey)) || 0; }
            function addSession() {
                const s = getSessions() + 1;
                localStorage.setItem(todayKey, s);
                updateSessionUI(s);
            }
            function updateSessionUI(s) {
                const el = document.getElementById('zenSessionCount');
                if (el) el.textContent = s + ' seans';
                const prog = document.getElementById('zenDailyProgress');
                if (prog) prog.textContent = s + ' / 4 seans';
                const bar = document.getElementById('zenDailyBar');
                if (bar) bar.style.width = Math.min(100, (s / 4) * 100) + '%';
            }
            updateSessionUI(getSessions());

            // Quote rotation
            function showRandomQuote() {
                const el = document.getElementById('zenQuote');
                if (!el) return;
                const q = zenQuotes[Math.floor(Math.random() * zenQuotes.length)];
                const p = el.querySelector('p');
                if (p) { p.style.opacity = '0'; setTimeout(() => { p.textContent = q; p.style.opacity = '1'; }, 300); }
            }

            // Generate stars
            function generateStars() {
                const container = document.getElementById('zenStars');
                if (!container || container.children.length > 0) return;
                for (let i = 0; i < 60; i++) {
                    const star = document.createElement('div');
                    star.style.cssText = `position:absolute;width:${Math.random()*2+1}px;height:${Math.random()*2+1}px;background:white;border-radius:50%;top:${Math.random()*100}%;left:${Math.random()*100}%;opacity:${Math.random()*0.5+0.1};animation:zenStarTwinkle ${Math.random()*4+2}s ${Math.random()*3}s ease-in-out infinite;`;
                    container.appendChild(star);
                }
            }

            function openZen() {
                generateStars();
                showRandomQuote();
                zenOverlay.style.display = 'flex';
                setTimeout(() => { zenOverlay.style.opacity = '1'; }, 10);
                isZen = true;
                document.addEventListener('keydown', handleEscape);
            }

            function closeZen() {
                zenOverlay.style.opacity = '0';
                setTimeout(() => { zenOverlay.style.display = 'none'; }, 1000);
                isZen = false;
                document.removeEventListener('keydown', handleEscape);
                // Stop all ambient sounds when closing
                if (typeof stopAllSounds === 'function') stopAllSounds();
            }

            zenBtn.addEventListener('click', () => { if (!isZen) openZen(); });
            if (zenCloseBtn) zenCloseBtn.addEventListener('click', closeZen);

            function handleEscape(e) {
                if (e.key === "Escape") closeZen();
            }

            // Quote rotation interval
            setInterval(() => { if (isZen) showRandomQuote(); }, 15000);

            // ========== WEB AUDIO API — PROCEDURAL AMBIENT SOUNDS ==========
            let audioCtx = null;
            const activeSounds = {};

            function getAudioCtx() {
                if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                return audioCtx;
            }

            function createNoiseBuffer(ctx, duration) {
                const sr = ctx.sampleRate;
                const buf = ctx.createBuffer(2, sr * duration, sr);
                for (let ch = 0; ch < 2; ch++) {
                    const d = buf.getChannelData(ch);
                    for (let i = 0; i < d.length; i++) d[i] = Math.random() * 2 - 1;
                }
                return buf;
            }

            function startSound(type, volume) {
                if (activeSounds[type]) return;
                const ctx = getAudioCtx();
                const gain = ctx.createGain();
                gain.gain.value = volume;
                gain.connect(ctx.destination);
                const nodes = { gain };

                if (type === 'rain') {
                    // Rain: filtered white noise (highpass + lowpass combo)
                    const src = ctx.createBufferSource();
                    src.buffer = createNoiseBuffer(ctx, 4);
                    src.loop = true;
                    const hp = ctx.createBiquadFilter(); hp.type = 'highpass'; hp.frequency.value = 400;
                    const lp = ctx.createBiquadFilter(); lp.type = 'lowpass'; lp.frequency.value = 8000;
                    src.connect(hp); hp.connect(lp); lp.connect(gain);
                    src.start(); nodes.src = src;
                }
                else if (type === 'forest') {
                    // Forest: very soft filtered noise + periodic chirps
                    const src = ctx.createBufferSource();
                    src.buffer = createNoiseBuffer(ctx, 4);
                    src.loop = true;
                    const bp = ctx.createBiquadFilter(); bp.type = 'bandpass'; bp.frequency.value = 2000; bp.Q.value = 0.5;
                    const subGain = ctx.createGain(); subGain.gain.value = 0.3;
                    src.connect(bp); bp.connect(subGain); subGain.connect(gain);
                    src.start(); nodes.src = src;
                    // Bird chirps
                    nodes.chirpInterval = setInterval(() => {
                        if (!activeSounds[type]) return;
                        const osc = ctx.createOscillator();
                        const cGain = ctx.createGain();
                        osc.type = 'sine';
                        osc.frequency.value = 2000 + Math.random() * 3000;
                        cGain.gain.setValueAtTime(0, ctx.currentTime);
                        cGain.gain.linearRampToValueAtTime(volume * 0.15, ctx.currentTime + 0.05);
                        cGain.gain.linearRampToValueAtTime(0, ctx.currentTime + 0.15);
                        osc.connect(cGain); cGain.connect(ctx.destination);
                        osc.start(); osc.stop(ctx.currentTime + 0.2);
                    }, 2000 + Math.random() * 4000);
                }
                else if (type === 'cafe') {
                    // Cafe: brown noise (integrated white noise)
                    const bufLen = ctx.sampleRate * 4;
                    const buf = ctx.createBuffer(2, bufLen, ctx.sampleRate);
                    for (let ch = 0; ch < 2; ch++) {
                        const d = buf.getChannelData(ch);
                        let last = 0;
                        for (let i = 0; i < bufLen; i++) {
                            const white = Math.random() * 2 - 1;
                            d[i] = (last + (0.02 * white)) / 1.02;
                            last = d[i]; d[i] *= 3.5;
                        }
                    }
                    const src = ctx.createBufferSource();
                    src.buffer = buf; src.loop = true;
                    src.connect(gain); src.start(); nodes.src = src;
                }
                else if (type === 'waves') {
                    // Waves: modulated filtered noise
                    const src = ctx.createBufferSource();
                    src.buffer = createNoiseBuffer(ctx, 6);
                    src.loop = true;
                    const lp = ctx.createBiquadFilter(); lp.type = 'lowpass'; lp.frequency.value = 500;
                    const modGain = ctx.createGain();
                    // LFO for wave movement
                    const lfo = ctx.createOscillator();
                    const lfoGain = ctx.createGain();
                    lfo.type = 'sine'; lfo.frequency.value = 0.1;
                    lfoGain.gain.value = volume * 0.4;
                    lfo.connect(lfoGain); lfoGain.connect(modGain.gain);
                    modGain.gain.value = volume * 0.6;
                    src.connect(lp); lp.connect(modGain); modGain.connect(ctx.destination);
                    src.start(); lfo.start();
                    nodes.src = src; nodes.lfo = lfo; nodes.modGain = modGain;
                }

                activeSounds[type] = nodes;
            }

            function stopSound(type) {
                const nodes = activeSounds[type];
                if (!nodes) return;
                try { nodes.src?.stop(); } catch(e) {}
                try { nodes.lfo?.stop(); } catch(e) {}
                if (nodes.chirpInterval) clearInterval(nodes.chirpInterval);
                delete activeSounds[type];
            }

            function stopAllSounds() {
                Object.keys(activeSounds).forEach(stopSound);
                document.querySelectorAll('.zen-sound-btn').forEach(b => b.classList.remove('active'));
            }

            // Sound button click handlers
            document.querySelectorAll('.zen-sound-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const type = btn.dataset.sound;
                    if (activeSounds[type]) {
                        stopSound(type);
                        btn.classList.remove('active');
                    } else {
                        const slider = document.querySelector(`.zen-volume[data-sound="${type}"]`);
                        const vol = slider ? slider.value / 100 : 0.5;
                        startSound(type, vol);
                        btn.classList.add('active');
                    }
                });
            });

            // Volume sliders
            document.querySelectorAll('.zen-volume').forEach(slider => {
                slider.addEventListener('input', () => {
                    const type = slider.dataset.sound;
                    const nodes = activeSounds[type];
                    if (nodes?.gain) {
                        nodes.gain.gain.value = slider.value / 100;
                    }
                    if (nodes?.modGain) {
                        nodes.modGain.gain.value = (slider.value / 100) * 0.6;
                    }
                });
            });

            // Stop all button
            const stopAllBtn = document.getElementById('zenStopAllSounds');
            if (stopAllBtn) stopAllBtn.addEventListener('click', stopAllSounds);

            // ========== SPOTIFY CUSTOM URL ==========
            const spotifyUrlInput = document.getElementById('zenSpotifyUrl');
            const spotifyLoadBtn = document.getElementById('zenSpotifyLoad');
            const spotifyIframe = document.getElementById('zenSpotifyIframe');

            function loadSpotifyUrl() {
                const url = (spotifyUrlInput?.value || '').trim();
                if (!url) return;
                // Parse Spotify URL: https://open.spotify.com/track/xxx or /playlist/xxx etc
                const match = url.match(/open\.spotify\.com\/(track|playlist|album|episode|show)\/([a-zA-Z0-9]+)/);
                if (match) {
                    const type = match[1], id = match[2];
                    spotifyIframe.src = `https://open.spotify.com/embed/${type}/${id}?utm_source=generator&theme=0`;
                    // Save to localStorage
                    localStorage.setItem('gb_zen_spotify', url);
                } else {
                    // Try direct paste of URI like spotify:track:xxx
                    const uriMatch = url.match(/spotify:(track|playlist|album):([a-zA-Z0-9]+)/);
                    if (uriMatch) {
                        spotifyIframe.src = `https://open.spotify.com/embed/${uriMatch[1]}/${uriMatch[2]}?utm_source=generator&theme=0`;
                        localStorage.setItem('gb_zen_spotify', url);
                    }
                }
            }

            if (spotifyLoadBtn) spotifyLoadBtn.addEventListener('click', loadSpotifyUrl);
            if (spotifyUrlInput) spotifyUrlInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') loadSpotifyUrl(); });

            // Restore saved Spotify
            const savedSpotify = localStorage.getItem('gb_zen_spotify');
            if (savedSpotify && spotifyUrlInput) {
                spotifyUrlInput.value = savedSpotify;
                // Auto-load on zen open (only parse, don't auto-play)
                const match = savedSpotify.match(/open\.spotify\.com\/(track|playlist|album|episode|show)\/([a-zA-Z0-9]+)/);
                if (match && spotifyIframe) {
                    spotifyIframe.src = `https://open.spotify.com/embed/${match[1]}/${match[2]}?utm_source=generator&theme=0`;
                }
            }

            // Pomodoro Counter
            let pTimer;
            let pTime = 25 * 60;
            const pDisplay = document.getElementById('pomodoroTimer');
            let isRunning = false;

            function updateDisplay() {
                const m = Math.floor(pTime / 60).toString().padStart(2, '0');
                const s = (pTime % 60).toString().padStart(2, '0');
                pDisplay.innerText = `${m}:${s}`;
            }

            document.getElementById('startPomodoro').addEventListener('click', () => {
                if(isRunning) return;
                isRunning = true;
                pTimer = setInterval(() => {
                    if(pTime > 0) { pTime--; updateDisplay(); }
                    else { 
                        clearInterval(pTimer); 
                        isRunning = false; 
                        document.getElementById('pomodoroMessage').style.display = 'block';
                        addSession();
                    }
                }, 1000);
            });

            document.getElementById('pausePomodoro').addEventListener('click', () => {
                clearInterval(pTimer);
                isRunning = false;
            });

            document.getElementById('resetPomodoro').addEventListener('click', () => {
                clearInterval(pTimer);
                isRunning = false;
                pTime = 25 * 60;
                updateDisplay();
                document.getElementById('pomodoroMessage').style.display = 'none';
            });
        });
    </script>




