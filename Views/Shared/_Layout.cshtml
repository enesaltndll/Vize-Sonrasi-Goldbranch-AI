    <style>
        /* 🛡️ GHOST MODE STYLES */
        body.ghost-mode-active .gb-task-title,
        body.ghost-mode-active .gb-user-name,
        body.ghost-mode-active .gb-email,
        body.ghost-mode-active .gb-price,
        body.ghost-mode-active .cert-user-name {
            filter: blur(5px);
            user-select: none;
            pointer-events: none;
            transition: filter 0.3s ease;
        }
        body.ghost-mode-active #btnGhostMode {
            background: #ef4444 !important;
            color: white !important;
            opacity: 1 !important;
            box-shadow: 0 0 15px rgba(239, 68, 68, 0.5);
        }

        .gb-soundscape-mini { 
            position: fixed; left: 80px; bottom: 20px; z-index: 9999; 
            background: rgba(13, 17, 23, 0.8); backdrop-filter: blur(10px);
            padding: 5px 12px; border-radius: 20px; border: 1px solid rgba(251, 191, 36, 0.1);
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }
        
        /* 🎙️ JARVIS 2.0 HOLOGRAPHIC OVERLAY */
        #jarvisHUD.premium {
            background: radial-gradient(circle at center, rgba(251, 191, 36, 0.05) 0%, rgba(13, 17, 23, 0.98) 100%);
        }
        .holo-ring {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 300px; height: 300px; border: 2px solid var(--gb-gold); border-radius: 50%;
            box-shadow: 0 0 50px var(--gb-gold-glow), inset 0 0 50px var(--gb-gold-glow);
            animation: holoSpin 10s linear infinite;
        }
        .holo-ring::after {
            content: ''; position: absolute; inset: -15px; border: 1px dashed var(--gb-gold);
            border-radius: 50%; animation: holoSpinRev 15s linear infinite; opacity: 0.5;
        }
        @@keyframes holoSpin { from { transform: translate(-50%, -50%) rotate(0deg); } to { transform: translate(-50%, -50%) rotate(360deg); } }
        @@keyframes holoSpinRev { from { transform: rotate(360deg); } to { transform: rotate(0deg); } }
        
        .voice-wave-premium {
            display: flex; align-items: center; gap: 5px; height: 60px;
        }
        .v-bar {
            width: 4px; height: 10px; background: var(--gb-gold); border-radius: 2px;
            animation: vWave 1s ease-in-out infinite;
        }
        @@keyframes vWave { 0%, 100% { height: 10px; opacity: 0.5; } 50% { height: 50px; opacity: 1; } }
    </style>

    <script>
        // --- GHOST MODE ---
        document.getElementById('btnGhostMode').onclick = () => {
            document.body.classList.toggle('ghost-mode-active');
            const isActive = document.body.classList.contains('ghost-mode-active');
            localStorage.setItem('ghost-mode', isActive);
        };
        if (localStorage.getItem('ghost-mode') === 'true') document.body.classList.add('ghost-mode-active');

        // --- AI DAILY BRIEFING ---
        document.getElementById('btnDailyBriefing').onclick = async () => {
            const btn = document.getElementById('btnDailyBriefing');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
            btn.disabled = true;

            // Generate Summary Text (In a real app, this would fetch from server)
            const userName = "@currentUserFullName";
            const summary = `Merhaba ${userName}, GoldBranch AI günlük brifingine hoş geldin. Bugün senin için seçtiğim 3 kritik önceliğin var. Birincisi, bekleyen onay süreçlerini tamamlamak. İkincisi, veritabanı optimizasyonu üzerine çalışmak. Ve üçüncüsü, haftalık raporu hazırlamak. Şu anki nöral yükün %72 seviyesinde, öğleden sonra kısa bir mola vermeni öneririm. İyi çalışmalar!`;

            const utterance = new SpeechSynthesisUtterance(summary);
            utterance.lang = 'tr-TR';
            utterance.rate = 0.9;
            utterance.pitch = 1.1;

            window.speechSynthesis.speak(utterance);

            utterance.onend = () => {
                btn.innerHTML = '<i class="fa-solid fa-microphone-lines"></i> <span class="d-none d-md-inline">GÜNE BAŞLA</span>';
                btn.disabled = false;
            };
        };

        // --- SOUNDSCAPE LOGIC ---
        const ambientAudio = document.getElementById('ambientAudio');
        const soundSelect = document.getElementById('soundSelect');
        const soundUrls = {
            rain: 'https://www.soundjay.com/nature/rain-07.mp3',
            forest: 'https://www.soundjay.com/nature/forest-wind-1.mp3',
            space: 'https://www.soundjay.com/misc/sounds/space-ambient-1.mp3',
            cafe: 'https://www.soundjay.com/misc/sounds/coffee-shop-1.mp3'
        };

        soundSelect.onchange = (e) => {
            const val = e.target.value;
            if (val === 'none') {
                ambientAudio.pause();
            } else {
                ambientAudio.src = soundUrls[val];
                ambientAudio.play();
            }
        };

        // --- JARVIS 2.0 TOGGLE (CTRL+K) ---
        document.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.key === 'k') {
                e.preventDefault();
                toggleJarvisPremium();
            }
        });

        function toggleJarvisPremium() {
            let hud = document.getElementById('jarvisPremiumHUD');
            if (!hud) {
                hud = document.createElement('div');
                hud.id = 'jarvisPremiumHUD';
                hud.className = 'fixed-top w-100 h-100 d-flex flex-column align-items-center justify-content-center';
                hud.style.zIndex = '10000';
                hud.style.background = 'rgba(13, 17, 23, 0.95)';
                hud.style.backdropFilter = 'blur(15px)';
                hud.innerHTML = `
                    <div class="holo-ring"></div>
                    <div class="text-center" style="z-index: 10001;">
                        <i class="fa-solid fa-microchip text-warning mb-3 fs-1 animate-pulse"></i>
                        <h2 class="text-warning fw-bold letter-spacing-5 mb-4">NEURAL INTERFACE ACTIVE</h2>
                        <div class="voice-wave-premium mb-4">
                            ${Array(15).fill('<div class="v-bar"></div>').join('')}
                        </div>
                        <p class="text-muted small">Sizi dinliyorum... "Bugünkü işlerimi özetle" veya "Zen moduna geç" diyebilirsiniz.</p>
                        <button class="btn btn-outline-warning rounded-pill mt-4" onclick="this.parentElement.parentElement.remove()">BAĞLANTIYI KES</button>
                    </div>
                `;
                document.body.appendChild(hud);
                hud.querySelectorAll('.v-bar').forEach((bar, i) => {
                    bar.style.animationDelay = `${i * 0.1}s`;
                });
            } else {
                hud.remove();
            }
        }

        function toggleSupport() {
            const panel = document.getElementById('gbSupportPanel');
            const isVisible = panel.style.display === 'flex';
            panel.style.display = isVisible ? 'none' : 'flex';
        }

        function sendSupportMsg() {
            const input = document.getElementById('gbSupportInput');
            const chat = document.getElementById('gbSupportChat');
            const msg = input.value.trim();
            if (!msg) return;

            const userDiv = document.createElement('div');
            userDiv.className = 'gb-chat-msg user';
            userDiv.textContent = msg;
            chat.appendChild(userDiv);
            input.value = '';
            chat.scrollTop = chat.scrollHeight;

            setTimeout(() => {
                const botDiv = document.createElement('div');
                botDiv.className = 'gb-chat-msg bot';
                botDiv.textContent = "Mesajınız alındı! Teknik bir temsilci en kısa sürede size geri dönüş yapacaktır.";
                chat.appendChild(botDiv);
                chat.scrollTop = chat.scrollHeight;
            }, 1000);
        }
    </script>
</body>
</html>
