@inject GoldBranchAI.Services.BillingService Billing
@using Microsoft.Extensions.DependencyInjection
@{
    string currentLang = Context.Request.Cookies["lang_pref"] ?? "tr";
    // Get billing state for navbar badge
    string navPlanBadge = "FREE";
    string navPlanColor = "#8b949e";
    string currentUserFullName = "Kullanıcı";
    string currentUserRole = "";
    string navPlanKey = "free";
    if (User?.Identity?.IsAuthenticated == true)
    {
        var navEmail = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value;
        if (!string.IsNullOrEmpty(navEmail))
        {
            var navDbContext = Context.RequestServices.GetService<GoldBranchAI.Data.AppDbContext>();
            var navUser = navDbContext?.Users.FirstOrDefault(u => u.Email == navEmail);
            if (navUser != null)
            {
                currentUserFullName = navUser.FullName;
                currentUserRole = navUser.Role;
                var navState = Billing.GetUserState(navUser.Id, navUser.Email);
                navPlanBadge = Billing.GetPlanBadge(navState);
                navPlanColor = Billing.GetEffectivePlan(navState).Color;
                navPlanKey = navState.PlanKey;
                ViewBag.CurrentUserAvatar = navUser.AvatarUrl;
            }
        }
    }
}
<!DOCTYPE html>
<html lang="@currentLang" data-bs-theme="dark" data-theme="gold-dark">
<head>
    <script>
        // Init theme before render to avoid flash
        const savedTheme = localStorage.getItem('gb-theme') || 'gold-dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GoldBranch AI</title>
    <meta name="description" content="GoldBranch AI - Akilli Gorev Yonetim Sistemi" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="manifest" href="~/manifest.json">
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js');
        }
    </script>
    <!-- PWA & Mobile Meta Tags -->
    <meta name="theme-color" content="#0d1117">
    <link rel="apple-touch-icon" href="https://cdn-icons-png.flaticon.com/512/9334/9334400.png">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
</head>
<body class="bg-dark text-light tier-@navPlanKey">

    <!-- QUANTUM TRANSITION SCANNER -->
    <div id="gbQuantumScanner" class="gb-quantum-overlay">
        <div class="gb-q-laser"></div>
        <div class="gb-q-logo">
            <i class="fa-solid fa-leaf text-warning" style="font-size:3rem;filter:drop-shadow(0 0 20px #fbbf24);"></i>
            <div class="gb-q-text">SYSTEM INITIALIZING...</div>
        </div>
    </div>

    <!-- Animated Particle Canvas -->
    <canvas id="particleCanvas" style="position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:-1;opacity:0.4;"></canvas>
    <div class="gb-app-container">
        @if (User?.Identity?.IsAuthenticated == true)
        {
            <aside class="gb-sidebar" id="gbSidebar">
                <a class="gb-sidebar-logo" asp-controller="Task" asp-action="Index" title="GoldBranch AI">
                    <i class="fa-solid fa-leaf gb-heartbeat"></i>
                </a>

                <ul class="gb-nav-list">
                    <!-- 🛰️ RADAR -->
                    <li>
                        <a class="gb-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Radar" ? "active" : "")" asp-controller="Task" asp-action="Radar" title="Stratejik Radar">
                            <i class="fa-solid fa-satellite-dish"></i>
                        </a>
                    </li>
                    
                    <!-- 🛰️ OLD RADAR (Operational) -->
                    <li>
                        <a class="gb-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Task" asp-action="Dashboard" title="@L.Get("OperationalRadar")">
                            <i class="fa-solid fa-rocket"></i>
                        </a>
                    </li>

                    <!-- 📋 SPRINT BOARD -->
                    <li>
                        <a class="gb-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Task" ? "active" : "")" asp-controller="Task" asp-action="Index" title="@L.Get("SprintBoard")">
                            <i class="fa-solid fa-columns"></i>
                        </a>
                    </li>

                    <!-- 💬 CHAT -->
                    <li>
                        <a class="gb-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Chat" ? "active" : "")" asp-controller="Chat" asp-action="Index" title="@L.Get("ChatRoom")">
                            <i class="fa-solid fa-comments"></i>
                        </a>
                    </li>

                    <!-- 📹 CONFERENCE / MEETING -->
                    <li>
                        <a class="gb-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Conference" ? "active" : "")" asp-controller="Conference" asp-action="Index" title="İşbirliği Merkezi (Video/Ekran Paylaşımı)">
                            <i class="fa-solid fa-video"></i>
                        </a>
                    </li>

                    <!-- ⚙️ SETTINGS -->
                    <li>
                        <a class="gb-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Settings" ? "active" : "")" asp-controller="Settings" asp-action="Index" title="Profil Ayarları">
                            <i class="fa-solid fa-user-gear"></i>
                        </a>
                    </li>

                    <!-- 💎 BILLING -->
                    <li>
                        <a class="gb-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Billing" ? "active" : "")" asp-controller="Billing" asp-action="Index" title="@L.Get("SaasCenter")">
                            <i class="fa-solid fa-gem" style="color: @navPlanColor;"></i>
                        </a>
                    </li>

                    <!-- 🧠 AI AGENTS (Hiyerarşik) -->
                    @if (User?.Claims?.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value == "Proje Sefi" ||
                         User?.Claims?.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value == "Admin")
                    {
                        <li>
                            <a class="gb-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Breakdown" ? "active" : "")" asp-controller="Ai" asp-action="Breakdown" title="@L.Get("AjanMerkezi")" style="color:var(--gb-accent-violet);">
                                <i class="fa-solid fa-brain"></i>
                            </a>
                        </li>
                    }
                    else if (User?.Claims?.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value == "Gelistirici")
                    {
                        <li>
                            <a class="gb-nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Research" ? "active" : "")" asp-controller="Ai" asp-action="Research" title="@L.Get("CodeLab")" style="color:var(--gb-accent-cyan);">
                                <i class="fa-solid fa-code"></i>
                            </a>
                        </li>
                    }


                    @if (User?.Claims?.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value == "Admin")
                    {
                        <!-- 📊 Admin: İş Raporları -->
                        <li>
                            <a class="gb-nav-link text-warning @(ViewContext.RouteData.Values["Action"]?.ToString() == "WorkReports" ? "active" : "")" asp-controller="Admin" asp-action="WorkReports" title="İş Raporları">
                                <i class="fa-solid fa-chart-line"></i>
                            </a>
                        </li>
                        <!-- 🖥️ Admin: Sistem Kayıtları -->
                        <li>
                            <a class="gb-nav-link text-info @(ViewContext.RouteData.Values["Action"]?.ToString() == "SystemLogs" ? "active" : "")" asp-controller="Admin" asp-action="SystemLogs" title="Sistem Kayıtları">
                                <i class="fa-solid fa-server"></i>
                            </a>
                        </li>
                    }
                </ul>

                <!-- SIDEBAR FOOTER (User Section) -->
                <div class="gb-sidebar-footer d-flex flex-column align-items-center gap-3">
                    <a asp-controller="Settings" asp-action="Index" class="position-relative" title="Profil Ayarları">
                        <div class="gb-avatar-mini" style="width:40px; height:40px; border-radius:50%; overflow:hidden; border:2px solid var(--gb-gold);">
                            <img src="@(string.IsNullOrEmpty(ViewBag.CurrentUserAvatar as string) ? "https://cdn-icons-png.flaticon.com/512/9334/9334400.png" : ViewBag.CurrentUserAvatar)" 
                                 style="width:100%; height:100%; object-fit:cover;" />
                        </div>
                        <span class="position-absolute bottom-0 end-0 bg-success border border-2 border-dark rounded-circle" style="width:12px; height:12px;"></span>
                    </a>
                    
                    <a asp-controller="Auth" asp-action="Logout" class="text-danger opacity-50 hover-opacity-100" title="Çıkış Yap" style="font-size:1.1rem;">
                        <i class="fa-solid fa-power-off"></i>
                    </a>
                </div>
            </aside>

            <!-- 🔧 TOP-RIGHT TOOLBAR (Ghost Mode + AI Briefing + Timer + Lang Toggle) -->
            <div class="gb-top-toolbar d-flex align-items-center gap-2">
                <button id="btnGhostMode" class="btn btn-outline-secondary btn-sm rounded-pill px-2 border-0 opacity-50 hover-opacity-100" title="Ghost Mode (Hassas Verileri Gizle)">
                    <i class="fa-solid fa-ghost"></i>
                </button>
                <button id="btnDailyBriefing" class="btn btn-outline-warning btn-sm rounded-pill px-3 fw-bold" title="Güne AI Sesli Özetle Başla">
                    <i class="fa-solid fa-microphone-lines"></i> <span class="d-none d-md-inline">GÜNE BAŞLA</span>
                </button>
                <span id="screenTimer" class="gb-timer">
                    <i class="fa-solid fa-stopwatch me-1"></i>00:00:00
                </span>
                <button id="globalVoiceCmdBtn" class="gb-lang-toggle text-warning" style="border: 1px solid rgba(251,191,36,0.5); background: rgba(251,191,36,0.1); width: 34px; padding: 0;" title="Sesli Komut İle Görev Ekle">
                    <i class="fa-solid fa-microphone"></i>
                </button>
                <a href="/Lang/Switch?lang=@(currentLang == "tr" ? "en" : "tr")&returnUrl=@Context.Request.Path" class="gb-lang-toggle" title="@(currentLang == "tr" ? "Switch to English" : "Türkçe'ye Geç")">
                    @(currentLang == "tr" ? "EN" : "TR")
                </a>
            </div>
        }




        <main class="gb-main-wrapper">
            <!-- Mobile Top Bar (Hidden on Desktop) -->
            @if (User?.Identity?.IsAuthenticated == true)
            {
                <div class="d-lg-none d-flex align-items-center justify-content-between mb-4 pb-2 border-bottom border-secondary">
                    <button class="btn btn-link text-warning p-0" onclick="document.getElementById('gbSidebar').classList.toggle('active')">
                        <i class="fa-solid fa-bars-staggered fs-4"></i>
                    </button>
                    <a class="navbar-brand fw-bold text-warning" asp-controller="Task" asp-action="Index">GoldBranch</a>
                    <div class="position-relative">
                         <i class="fa-solid fa-bell text-warning fs-5"></i>
                         <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="notificationBadge" style="display:none; font-size: 0.5rem;">0</span>
                    </div>
                </div>
            }


            <!-- 🎰 LIVE ACHIEVEMENT TICKER BAR -->
            @if (User?.Identity?.IsAuthenticated == true)
            {
                <div id="gbTickerBar" class="gb-ticker-bar">
                    <div class="gb-ticker-label">
                        <i class="fa-solid fa-trophy"></i> CANLI
                    </div>
                    <div class="gb-ticker-track">
                        <div class="gb-ticker-content" id="gbTickerContent">
                            <span class="gb-ticker-item"><span class="gb-ticker-icon">🚀</span> GoldBranch AI Live Feed yükleniyor...</span>
                        </div>
                    </div>
                </div>
            }

            <div id="gbScrollProgressBar" style="position:fixed; top:0; left:0; width:0%; height:3px; background:linear-gradient(90deg, #fbbf24, #22d3ee); z-index:2000; transition: width 0.1s;"></div>
            
            
            <div class="fade-in">
                @RenderBody()
            </div>
        </main>
