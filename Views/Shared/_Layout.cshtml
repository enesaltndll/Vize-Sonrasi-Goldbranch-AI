    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // 🗣️ DİNAMİK SESLİ ASİSTAN (Hoşgeldin Karşılaması)
            const userName = "@currentUserFullName";
            const greetingKey = "gb_wow_welcome_" + new Date().toISOString().slice(0, 10);
            
            if (!localStorage.getItem(greetingKey)) {
                localStorage.setItem(greetingKey, "1");
                setTimeout(() => {
                    const hour = new Date().getHours();
                    let msg = "";
                    let isNight = false;

                    if (hour >= 5 && hour < 12) msg = `Günaydın ${userName}, GoldBranch'e hoş geldin, iyi çalışmalar dilerim.`;
                    else if (hour >= 12 && hour < 18) msg = `İyi öğlenler ${userName}, GoldBranch'e hoş geldin, iyi çalışmalar dilerim.`;
                    else if (hour >= 18 && hour < 24) msg = `İyi akşamlar ${userName}, GoldBranch'e hoş geldin, iyi çalışmalar dilerim.`;
                    else {
                        msg = `İyi mesailer ${userName}, Gece Muhafızı senin için hazır.`;
                        isNight = true;
                    }

                    if (window.speechSynthesis) {
                        const utterance = new SpeechSynthesisUtterance(msg);
                        utterance.lang = 'tr-TR';
                        window.speechSynthesis.speak(utterance);
                    }

                    Swal.fire({
                        toast: true, position: 'bottom-start', 
                        icon: 'success', iconColor: '#fbbf24',
                        title: isNight ? '🦉 Gece Muhafızı Aktif' : '☀️ GoldBranch Asistanı',
                        text: msg,
                        showConfirmButton: false, timer: 10000, 
                        background: '#0d1117', color: '#fbbf24'
                    });
                }, 3000);
            }
        });
    </script>

