    <!-- GLOBAL PAGE LOADER & ERROR HANDLER -->
    <script>
        // Page Loader: hide when fully loaded
        window.addEventListener('load', () => {
            const loader = document.getElementById('pageLoader');
            if(loader) { setTimeout(() => { loader.classList.remove('active'); }, 400); }
        });

        // Show loader on navigation
        document.querySelectorAll('a[href]:not([target="_blank"]):not([href^="#"]):not([href^="javascript"])').forEach(link => {
            link.addEventListener('click', () => {
                const loader = document.getElementById('pageLoader');
                if(loader) loader.classList.add('active');
            });
        });

        // Global JS Error Handler
        window.onerror = function(msg, source, line, col, error) {
            console.error('[GoldBranch Hata Yakalayıcı]', { msg, source, line, col });
            return false;
        };

        // --- A to Z ELEGANT TOUCHES --- //
        // 1. Dynamic Tab Title (Attention Grabber)
        const originalDocTitle = document.title;
        document.addEventListener("visibilitychange", function() {
            if (document.hidden) {
                document.title = "🚀 Geri Dön Şef! Sistem Bekliyor...";
            } else {
                document.title = originalDocTitle;
            }
        });

        // 2. Ambient Mouse Aura (Follows cursor with Gold/Cyan pulse)
        if (window.innerWidth > 992) {
            const aura = document.createElement('div');
            aura.style.cssText = 'position:fixed; top:0; left:0; width:400px; height:400px; background:radial-gradient(circle, rgba(251,191,36,0.08) 0%, transparent 60%); border-radius:50%; transform:translate(-50%, -50%); pointer-events:none; z-index:9999; transition:width 0.3s, height 0.3s, background 0.3s; mix-blend-mode: screen;';
            document.body.appendChild(aura);

            document.addEventListener('mousemove', (e) => {
                aura.style.left = e.clientX + 'px';
                aura.style.top = e.clientY + 'px';
            });
            document.addEventListener('mousedown', () => { 
                aura.style.width = '250px'; aura.style.height = '250px'; 
                aura.style.background = 'radial-gradient(circle, rgba(34,211,238,0.15) 0%, transparent 60%)'; 
            });
            document.addEventListener('mouseup', () => { 
                aura.style.width = '400px'; aura.style.height = '400px'; 
                aura.style.background = 'radial-gradient(circle, rgba(251,191,36,0.08) 0%, transparent 60%)'; 
            });
        }
        
        // 3. Smooth Body Fade-In on Page Load
        document.body.style.animation = "bodyFadeIn 0.8s ease forwards";
        
        // 4. Parallax 3D Hologram Effect for Cards
        document.querySelectorAll('.card.bg-dark, .compact-task, .welcome-banner').forEach(el => {
            el.addEventListener('mousemove', (e) => {
                // Ignore for very small screens or nested elements that might glitch
                if(window.innerWidth < 768) return;
                const rect = el.getBoundingClientRect();
                const x = e.clientX - rect.left - (rect.width/2);
                const y = e.clientY - rect.top - (rect.height/2);
                const tiltX = -(y / rect.height) * 10; // Max 10 deg
                const tiltY = (x / rect.width) * 10;
                
                el.style.transform = `perspective(1000px) rotateX(${tiltX}deg) rotateY(${tiltY}deg) scale3d(1.02, 1.02, 1.02)`;
                el.style.transition = 'none';
                el.style.zIndex = '10';
            });
            el.addEventListener('mouseleave', () => {
                el.style.transform = '';
                el.style.transition = 'transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
                el.style.zIndex = '1';
            });
        });

        // 5. Liquid Click Ripple for Buttons
        document.querySelectorAll('.btn').forEach(btn => {
            btn.addEventListener('mousedown', function(e) {
                const rect = this.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                const ripple = document.createElement('span');
                ripple.style.cssText = `position:absolute; width:2px; height:2px; background:rgba(255,255,255,0.4); left:${x}px; top:${y}px; border-radius:50%; transform:translate(-50%, -50%); pointer-events:none; animation:liquidRipple 0.6s linear forwards;`;
                
                if(window.getComputedStyle(this).position === 'static'){
                    this.style.position = 'relative';
                }
                this.style.overflow = 'hidden';
                this.appendChild(ripple);
                
                setTimeout(() => ripple.remove(), 600);
            });
        });

        // 6. Cinematic Scroll Reveal Observer (Fade Up on Scroll)
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if(entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0) scale(1)';
                    // remove observer after reveal
                    revealObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        // Wait a tiny bit for render
        setTimeout(() => {
            document.querySelectorAll('.card.bg-dark, .gb-section, .kanban-lane').forEach(el => {
                if (!el.classList.contains('no-reveal')) {
                    el.style.opacity = '0';
                    el.style.transform = 'translateY(40px) scale(0.98)';
                    el.style.transition = 'opacity 0.8s ease, transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1)';
                    revealObserver.observe(el);
                }
            });
        }, 100);

        if(!document.querySelector('#bodyFadeStyle')){
            const style = document.createElement('style');
            style.id = 'bodyFadeStyle';
            style.innerHTML = `
                @@keyframes bodyFadeIn { from { opacity: 0; transform: scale(0.99); } to { opacity: 1; transform: scale(1); } }
                @@keyframes liquidRipple { 0% { transform: scale(0); opacity: 1; } 100% { transform: scale(200); opacity: 0; } }
                .neural-card { position: relative; }
                .neural-card::before {
                    content: ""; position: absolute; top:0; left:0; width:100%; height:100%;
                    background: radial-gradient(400px circle at var(--mx) var(--my), rgba(34,211,238,0.15), transparent 40%);
                    z-index: 1; opacity: 0; transition: opacity 0.3s; pointer-events: none; mix-blend-mode: screen; border-radius: inherit;
                }
                .neural-card:hover::before { opacity: 1; }
            `;
            document.head.appendChild(style);
        }

        // 7. Cybernetic Scroll Progress Bar
        window.addEventListener('scroll', () => {
            const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scrolled = (winScroll / height) * 100;
            const bar = document.getElementById("gbScrollProgressBar");
            if (bar) bar.style.width = scrolled + "%";
        });

        // 8. Neural Card Active Lighting (Hologram Surface Lighting)
        document.querySelectorAll('.card.bg-dark, .compact-task, .welcome-banner').forEach(card => {
            card.classList.add('neural-card');
            card.addEventListener('mousemove', e => {
                const rect = card.getBoundingClientRect();
                card.style.setProperty('--mx', (e.clientX - rect.left) + 'px');
                card.style.setProperty('--my', (e.clientY - rect.top) + 'px');
            });
        });

        // 9. Magnetic Floating Action Bar (Pulls towards mouse)
        const fabDock = document.getElementById('gbFabDock');
        if (fabDock && window.innerWidth > 768) {
            fabDock.addEventListener('mousemove', e => {
                const rect = fabDock.getBoundingClientRect();
                const x = e.clientX - rect.left - rect.width / 2;
                const y = e.clientY - rect.top - rect.height / 2;
                fabDock.style.transform = `translate(${x * 0.4}px, ${y * 0.4}px)`;
            });
            fabDock.addEventListener('mouseleave', () => {
                fabDock.style.transform = 'translate(0px, 0px)';
            });
            fabDock.style.transition = 'transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
        }

        // 10. Matrix/Hacker Decode Effect on Brand Logo Hover
        const brandLogo = document.querySelector('.navbar-brand');
        if(brandLogo) {
            const originalHtml = brandLogo.innerHTML;
            const originalText = "GoldBranch AI";
            const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@@#$%^&*";
            let glitchInterval = null;
            brandLogo.addEventListener('mouseover', () => {
                let iteration = 0;
                clearInterval(glitchInterval);
                glitchInterval = setInterval(() => {
                    const iconHtml = '<i class="fa-solid fa-leaf text-warning" style="-webkit-text-fill-color: #fbbf24;"></i> ';
                    const scrambled = originalText.split("").map((letter, index) => {
                        if(index < iteration) return originalText[index];
                        return letters[Math.floor(Math.random() * letters.length)];
                    }).join("");
                    brandLogo.innerHTML = iconHtml + scrambled;
                    if(iteration >= originalText.length) clearInterval(glitchInterval);
                    iteration += 1 / 3;
                }, 30);
            });
            brandLogo.addEventListener('mouseleave', () => {
                clearInterval(glitchInterval);
                brandLogo.innerHTML = originalHtml;
            });
        }
    </script>

    <!-- ================================================================ -->
    <!-- 🛸 SUPREME JARVIS: THE INTELLIGENT GUARDIAN (PHASE 3 ULTIMATE) -->
    <!-- ================================================================ -->
    <script>
    document.addEventListener("DOMContentLoaded", () => {

        // ─── 🔊 CYBERNETIC AUDIO ENGINE (WebAudio API) ───
        const JarvisAudio = {
            ctx: null,
            getCtx() {
                if (!this.ctx) this.ctx = new (window.AudioContext || window.webkitAudioContext)();
                return this.ctx;
            },
            playTone(freq, duration, type = 'sine', vol = 0.15) {
                try {
                    const c = this.getCtx();
                    const o = c.createOscillator();
                    const g = c.createGain();
                    o.type = type;
                    o.frequency.setValueAtTime(freq, c.currentTime);
                    o.frequency.exponentialRampToValueAtTime(freq * 1.5, c.currentTime + duration * 0.3);
                    o.frequency.exponentialRampToValueAtTime(freq * 0.8, c.currentTime + duration);
                    g.gain.setValueAtTime(vol, c.currentTime);
                    g.gain.exponentialRampToValueAtTime(0.001, c.currentTime + duration);
                    o.connect(g); g.connect(c.destination);
                    o.start(c.currentTime); o.stop(c.currentTime + duration);
                } catch(e) {}
            },
            playActivation() {
                this.playTone(880, 0.15, 'sine', 0.12);
                setTimeout(() => this.playTone(1320, 0.15, 'sine', 0.1), 100);
                setTimeout(() => this.playTone(1760, 0.2, 'triangle', 0.08), 200);
            },
            playDeactivation() {
                this.playTone(1200, 0.1, 'sine', 0.08);
                setTimeout(() => this.playTone(800, 0.15, 'sine', 0.06), 80);
            },
            playSuccess() {
                this.playTone(523, 0.12, 'triangle', 0.1);
                setTimeout(() => this.playTone(659, 0.12, 'triangle', 0.1), 120);
                setTimeout(() => this.playTone(784, 0.18, 'triangle', 0.08), 240);
            },
            playError() {
                this.playTone(200, 0.3, 'sawtooth', 0.06);
            },
            playAchievement() {
                [523, 659, 784, 1047].forEach((f, i) => {
                    setTimeout(() => this.playTone(f, 0.2, 'triangle', 0.1), i * 150);
                });
            }
        };

        // ─── 🎖️ BADGE CHECK ───
        const earnedBadge = '@TempData["EarnedBadge"]';
        const earnedIcon = '@TempData["EarnedBadgeIcon"]';
        if (earnedBadge && earnedBadge !== '') {
            setTimeout(() => {
                triggerAchievementSplash(earnedBadge, "Görevi başarıyla tamamlayarak bu rozeti kazandın!", earnedIcon || "🏆");
            }, 2000);
        }

        // ─── 🛸 HOLOGRAPHIC HUD ───
        function createJarvisHUD() {
            if (document.getElementById('jarvisHUD')) return;
            const hud = document.createElement('div');
            hud.id = 'jarvisHUD';
            hud.innerHTML = `
                <div class="jarvis-hud-backdrop"></div>
                <div class="jarvis-hud-container">
                    <div class="jarvis-ring ring-outer"></div>
                    <div class="jarvis-ring ring-inner"></div>
                    <div class="jarvis-core">
                        <div class="jarvis-core-pulse"></div>
                        <i class="fa-solid fa-microphone jarvis-mic-icon"></i>
                        <svg class="jarvis-volume-svg" viewBox="0 0 100 100">
                            <circle class="jarvis-volume-meter" cx="50" cy="50" r="48"></circle>
                        </svg>
                    </div>
                    <div class="jarvis-scanline"></div>
                    <div class="jarvis-status">
                        <div class="jarvis-status-text">SİSTEM AKTİF</div>
                        <div class="jarvis-status-sub">Dinliyorum...</div>
                    </div>
                    <div class="jarvis-transcript" id="jarvisTranscript"></div>
                    <div class="jarvis-error-popup" id="jarvisErrorPopup"></div>
                </div>
            `;
            document.body.appendChild(hud);
        }

        function showJarvisHUD(active, transcript = '') {
            let hud = document.getElementById('jarvisHUD');
            if (!hud) { createJarvisHUD(); hud = document.getElementById('jarvisHUD'); }
            
            if (active) {
                hud.classList.add('active');
                hud.style.display = 'flex';
                const statusText = hud.querySelector('.jarvis-status-text');
                const statusSub = hud.querySelector('.jarvis-status-sub');
                statusText.textContent = 'SİSTEM AKTİF';
                statusSub.textContent = 'Dinliyorum...';
            } else {
                hud.classList.remove('active');
                setTimeout(() => { if (!hud.classList.contains('active')) hud.style.display = 'none'; }, 600);
            }

            if (transcript) {
                const tEl = document.getElementById('jarvisTranscript');
                if (tEl) tEl.textContent = `"${transcript}"`;
            }
        }

        function showJarvisResponse(text) {
            const hud = document.getElementById('jarvisHUD');
            if (!hud) return;
            const statusText = hud.querySelector('.jarvis-status-text');
            const statusSub = hud.querySelector('.jarvis-status-sub');
            if (statusText) statusText.textContent = 'İŞLENİYOR';
            if (statusSub) statusSub.textContent = text.substring(0, 60) + (text.length > 60 ? '...' : '');
        }

        // ─── 🗣️ SUPREME JARVIS ENGINE ───
        const Jarvis = {
            recognition: null,
            isListening: false,
            audioStream: null,
            analyser: null,
            dataArray: null,
            animationFrame: null,
            
            async init() {
                const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
                if (!SR) { console.warn("Jarvis: Speech Recognition not supported."); return; }
                
                this.recognition = new SR();
                this.recognition.continuous = false;
                this.recognition.interimResults = false;
                this.recognition.lang = '@(currentLang == "tr" ? "tr-TR" : "en-US")';
                
                this.recognition.onstart = () => { 
                    this.isListening = true;
                    JarvisAudio.playActivation();
                    showJarvisHUD(true);
                    this.startVisualizer();
                };
                
                this.recognition.onend = () => { 
                    this.isListening = false;
                    this.stopVisualizer();
                    JarvisAudio.playDeactivation();
                    setTimeout(() => showJarvisHUD(false), 2500);
                };
                
                this.recognition.onresult = (event) => {
                    const transcript = event.results[0][0].transcript;
                    showJarvisHUD(true, transcript);
                    processSupremeCommand(transcript.toLowerCase(), transcript);
                };

                this.recognition.onerror = (event) => {
                    console.error("Jarvis Error:", event.error);
                    JarvisAudio.playError();
                    this.handleSpeechError(event.error);
                };
            },

            handleSpeechError(err) {
                const errMap = {
                    'no-speech': '@(currentLang == "tr" ? "Ses algılanmadı. Lütfen tekrar deneyin." : "No speech detected. Please try again.")',
                    'audio-capture': '@(currentLang == "tr" ? "Mikrofon bulunamadı." : "Microphone not found.")',
                    'not-allowed': '@(currentLang == "tr" ? "Mikrofon izni reddedildi!" : "Microphone permission denied!")',
                    'network': '@(currentLang == "tr" ? "Ağ hatası: Ses tanıma servisine ulaşılamıyor." : "Network error: Cannot reach speech service.")'
                };
                const msg = errMap[err] || `Hata: ${err}`;
                const popup = document.getElementById('jarvisErrorPopup');
                if (popup) {
                    popup.textContent = msg;
                    popup.classList.add('show');
                    setTimeout(() => popup.classList.remove('show'), 4000);
                }
                const sub = document.getElementById('jarvisHUD')?.querySelector('.jarvis-status-sub');
                if (sub) sub.textContent = msg;
            },

            async startVisualizer() {
                try {
                    if (!this.audioStream) {
                        this.audioStream = await navigator.mediaDevices.getUserMedia({ audio: true });
                    }
                    const ctx = JarvisAudio.getCtx();
                    const source = ctx.createMediaStreamSource(this.audioStream);
                    this.analyser = ctx.createAnalyser();
                    this.analyser.fftSize = 64;
                    source.connect(this.analyser);
                    
                    this.dataArray = new Uint8Array(this.analyser.frequencyBinCount);
                    const meter = document.querySelector('.jarvis-volume-meter');
                    
                    const draw = () => {
                        if (!this.isListening) return;
                        this.animationFrame = requestAnimationFrame(draw);
                        this.analyser.getByteFrequencyData(this.dataArray);
                        
                        let sum = 0;
                        for(let i=0; i<this.dataArray.length; i++) sum += this.dataArray[i];
                        let average = sum / this.dataArray.length;
                        let volume = Math.min(100, average * 1.5);
                        
                        if (meter) {
                           const circumference = 2 * Math.PI * 48;
                           const offset = circumference - (volume / 100) * circumference;
                           meter.style.strokeDasharray = `${circumference} ${circumference}`;
                           meter.style.strokeDashoffset = offset;
                           const core = document.querySelector('.jarvis-core-pulse');
                           if (core) core.style.transform = `scale(${1 + (volume/200)})`;
                        }
                    };
                    draw();
                } catch(e) { console.error("Visualizer error:", e); }
            },

            stopVisualizer() {
                if (this.animationFrame) cancelAnimationFrame(this.animationFrame);
                const meter = document.querySelector('.jarvis-volume-meter');
                if (meter) meter.style.strokeDashoffset = 2 * Math.PI * 48;
            },
            
            toggle() {
                if (!this.recognition) { this.init().then(() => this.toggle()); return; }
                if (this.isListening) {
                    this.recognition.stop();
                } else {
                    try { this.recognition.start(); } catch(e) { console.error("Jarvis start:", e); }
                }
            }
        };

        // ─── 🧠 HYBRID COMMAND PROCESSOR ───
        async function processSupremeCommand(cmd, rawTranscript) {
            console.log("Jarvis Duydu:", rawTranscript);
            const statusSub = document.getElementById('jarvisHUD')?.querySelector('.jarvis-status-sub');

            // LOCAL FAST PATH (instant navigation)
            if (cmd.includes("görev") && (cmd.includes("oku") || cmd.includes("listele") || cmd.includes("neler") || cmd.includes("panel"))) {
                JarvisAudio.playSuccess();
                if (statusSub) statusSub.textContent = "Görev Paneli Açılıyor...";
                showJarvisResponse("Görev paneline yönlendiriyorum...");
                speak("Görev panelini açıyorum. İşte güncel hedeflerin.");
                setTimeout(() => window.location.href = "/Task/Index", 2500);
                return;
            }
            if (cmd.includes("dashboard") || cmd.includes("rapor") || cmd.includes("analiz") || cmd.includes("performans")) {
                JarvisAudio.playSuccess();
                if (statusSub) statusSub.textContent = "Dashboard Hazırlanıyor...";
                showJarvisResponse("Dashboard açılıyor...");
                speak("Performans panelini açıyorum.");
                setTimeout(() => window.location.href = "/Task/Dashboard", 2500);
                return;
            }
            if (cmd.includes("sohbet") || cmd.includes("chat") || cmd.includes("mesaj") || cmd.includes("ekip")) {
                JarvisAudio.playSuccess();
                if (statusSub) statusSub.textContent = "Sohbet Paneli Açılıyor...";
                showJarvisResponse("Sohbet panelini açıyorum...");
                speak("Takım sohbetine yönlendiriyorum.");
                setTimeout(() => window.location.href = "/Chat", 2500);
                return;
            }
            if (cmd.includes("selam") || cmd.includes("merhaba") || cmd.includes("nasılsın")) {
                JarvisAudio.playSuccess();
                speak("Merhaba efendim. Tüm sistemler hazır ve emrinizdedir. Bugün ne yapalım?");
                showJarvisResponse("Tüm sistemler hazır.");
                return;
            }
            if (cmd.includes("teşekkür") || cmd.includes("sağ ol")) {
                JarvisAudio.playSuccess();
                speak("Her zaman emirlerinize amadeyim. İyi çalışmalar.");
                showJarvisResponse("Hizmetinizdeyim.");
                return;
            }

            // AI DEEP PATH (complex commands → backend)
            if (cmd.includes("görev") && (cmd.includes("oluştur") || cmd.includes("ata") || cmd.includes("yaz") || cmd.includes("ekle"))) {
                JarvisAudio.playSuccess();
                if (statusSub) statusSub.textContent = "AI Görev Analizi Yapıyor...";
                showJarvisResponse("AI işliyor: " + rawTranscript.substring(0,40) + "...");
                speak("Komutu işliyorum. Yapay zeka görevi oluşturuyor.");
                try {
                    const resp = await fetch('/Ai/ProcessVoiceCommand', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ command: rawTranscript })
                    });
                    const data = await resp.json();
                    if (data.success) {
                        JarvisAudio.playAchievement();
                        speak(`Görev başarıyla oluşturuldu: ${data.message}`);
                        showJarvisResponse("✅ " + data.message);
                    } else {
                        JarvisAudio.playError();
                        speak("Üzgünüm, görev oluşturulamadı. " + (data.message || ""));
                        showJarvisResponse("❌ Başarısız");
                    }
                } catch(e) {
                    JarvisAudio.playError();
                    speak("Bağlantı hatası oluştu. Lütfen tekrar deneyin.");
                }
                return;
            }

            // FALLBACK
            JarvisAudio.playSuccess();
            speak("Komutu anladım ama tam eşleşme bulamadım. Görevler, mola, yılan oyunu veya dashboard demeyi deneyin.");
            showJarvisResponse("Komut tanınmadı");
        }

        // Keyboard Shortcut: Ctrl + Space
        window.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.code === 'Space') {
                e.preventDefault();
                Jarvis.toggle();
            }
        });


        // ─── 🌞 PROACTIVE MORNING BRIEFING ───
        (function morningBriefing() {
            const today = new Date().toDateString();
            const briefKey = 'gb_jarvis_briefing_' + today;
            if (localStorage.getItem(briefKey)) return;
            localStorage.setItem(briefKey, '1');

            setTimeout(() => {
                const userName = '@(currentUserFullName ?? "Kullanıcı")';
                const h = new Date().getHours();
                let greeting = '';
                if (h >= 5 && h < 12) greeting = `Günaydın ${userName}.`;
                else if (h >= 12 && h < 18) greeting = `İyi öğlenler ${userName}.`;
                else if (h >= 18 && h < 24) greeting = `İyi akşamlar ${userName}.`;
                else greeting = `Gece nöbetine hoş geldin ${userName}.`;

                speak(`${greeting} Tüm sistemler hazır ve emrinizdedir. Bugün harika işler başaracağız. Jarvis, her zaman hizmetinizde.`);
            }, 4000);
        })();

        // ─── 🎊 SUPREME ACHIEVEMENT CELEBRATION ───
        window.triggerAchievementSplash = function(title, sub, icon = "🏆") {
            JarvisAudio.playAchievement();

            const splash = document.createElement('div');
            splash.className = 'achievement-splash-overlay';
            splash.innerHTML = `
                <div class="achievement-card">
                    <div class="achievement-glow"></div>
                    <div class="achievement-icon-wrapper">
                        <span class="achievement-icon-main">${icon}</span>
                    </div>
                    <h2 class="achievement-title">${title}</h2>
                    <p class="achievement-sub">${sub}</p>
                    <div class="achievement-xp-badge">+100 XP KAZANILDI</div>
                    <button class="achievement-dismiss" onclick="this.closest('.achievement-splash-overlay').remove()">Devam Et →</button>
                </div>
            `;
            document.body.appendChild(splash);
            
            if (typeof confetti !== 'undefined') {
                confetti({ particleCount: 100, spread: 70, origin: { y: 0.6 }, colors: ['#fbbf24', '#fff', '#22d3ee'] });
                setTimeout(() => confetti({ particleCount: 80, spread: 100, origin: { y: 0.4 }, colors: ['#fbbf24', '#a78bfa'] }), 500);
                setTimeout(() => confetti({ particleCount: 60, spread: 120, origin: { y: 0.7 }, colors: ['#34d399', '#fbbf24'] }), 1000);
            }

            speak(`Tebrikler! ${title} başarısını kilitledin. Harika gidiyorsun.`);

            setTimeout(() => {
                splash.classList.add('fade-out');
                setTimeout(() => splash.remove(), 1000);
            }, 8000);
        };

        // ─── 🌌 ATMOSPHERIC UI (TIME-BASED PARTICLES) ───
        const pCanvas = document.getElementById('particleCanvas');
        if (pCanvas) {
            const pCtx = pCanvas.getContext('2d');
            const atmo = (() => {
                const h = new Date().getHours();
                if (h >= 5 && h < 12) return { c1: "#fbbf24", c2: "#f59e0b", op: 0.3, sp: 0.4, name: "dawn" };
                if (h >= 12 && h < 18) return { c1: "#22d3ee", c2: "#06b6d4", op: 0.25, sp: 0.6, name: "day" };
                if (h >= 18 && h < 24) return { c1: "#818cf8", c2: "#6366f1", op: 0.25, sp: 0.35, name: "twilight" };
                return { c1: "#475569", c2: "#334155", op: 0.15, sp: 0.2, name: "night" };
            })();

            let pts = [];
            function pInit() {
                pCanvas.width = window.innerWidth;
                pCanvas.height = window.innerHeight;
                pts = [];
                for(let i = 0; i < 70; i++) {
                    pts.push({
                        x: Math.random() * pCanvas.width,
                        y: Math.random() * pCanvas.height,
                        r: Math.random() * 2 + 0.5,
                        dx: (Math.random() - 0.5) * atmo.sp,
                        dy: (Math.random() - 0.5) * atmo.sp,
                        a: Math.random() * atmo.op + 0.05,
                        color: Math.random() > 0.5 ? atmo.c1 : atmo.c2
                    });
                }
            }
            function pLoop() {
                pCtx.clearRect(0, 0, pCanvas.width, pCanvas.height);
                pts.forEach(p => {
                    p.x += p.dx; p.y += p.dy;
                    if (p.x < 0 || p.x > pCanvas.width) p.dx *= -1;
                    if (p.y < 0 || p.y > pCanvas.height) p.dy *= -1;
                    pCtx.beginPath();
                    pCtx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                    const hex = p.color;
                    const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
                    pCtx.fillStyle = `rgba(${r},${g},${b},${p.a})`;
                    pCtx.fill();
                });

                // Draw connections between nearby particles
                for (let i = 0; i < pts.length; i++) {
                    for (let j = i + 1; j < pts.length; j++) {
                        const dx = pts[i].x - pts[j].x;
                        const dy = pts[i].y - pts[j].y;
                        const dist = Math.sqrt(dx*dx + dy*dy);
                        if (dist < 120) {
                            pCtx.beginPath();
                            pCtx.strokeStyle = `rgba(251,191,36,${0.06 * (1 - dist/120)})`;
                            pCtx.lineWidth = 0.5;
                            pCtx.moveTo(pts[i].x, pts[i].y);
                            pCtx.lineTo(pts[j].x, pts[j].y);
                            pCtx.stroke();
                        }
                    }
                }
                requestAnimationFrame(pLoop);
            }
            pInit(); pLoop();
            window.addEventListener('resize', pInit);
        }
    });


    </script>

