    <!-- GLOBAL FOOTER -->
    <footer class="text-center pb-4 text-muted" style="font-size: 0.8rem; margin-bottom: 60px;">
        <span style="letter-spacing: 1px;">Tüm hakları <span class="text-warning fw-bold">GOLDBRANCH AI</span> tarafından saklıdır © 2026</span>
    </footer>

    <!-- 📱 MOBİL BOTTOM NAVIGATION (Sadece küçük ekranda) -->
    @if (User?.Identity?.IsAuthenticated == true)
    {
        <nav class="navbar fixed-bottom d-md-none bg-dark border-top border-secondary" style="background: rgba(13, 17, 23, 0.95) !important; padding: 10px 0; z-index: 1040; backdrop-filter: blur(10px);">
            <div class="container-fluid d-flex justify-content-around">
                <a asp-controller="Task" asp-action="Dashboard" class="text-center text-light text-decoration-none" style="flex:1;">
                    <i class="fa-solid fa-rocket fs-5 mb-1 d-block" style="color: #cbd5e1;"></i>
                    <small style="font-size: 0.65rem;">@L.Get("Radar")</small>
                </a>
                <a asp-controller="Task" asp-action="Index" class="text-center text-light text-decoration-none" style="flex:1;">
                    <i class="fa-solid fa-columns fs-5 mb-1 d-block" style="color: #cbd5e1;"></i>
                    <small style="font-size: 0.65rem;">@L.Get("Kanban")</small>
                </a>
                <a asp-controller="Profile" asp-action="Index" class="text-center text-light text-decoration-none position-relative" style="flex:1;">
                    <div style="background: linear-gradient(135deg, #a855f7, #6366f1); border-radius: 50%; width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; margin: 0 auto; margin-top: -20px; box-shadow: 0 5px 15px rgba(168, 85, 247, 0.4);">
                        <i class="fa-solid fa-user-astronaut fs-5 text-white"></i>
                    </div>
                </a>
                <a asp-controller="Chat" asp-action="Index" class="text-center text-light text-decoration-none" style="flex:1;">
                    <i class="fa-solid fa-comments fs-5 mb-1 d-block" style="color: #cbd5e1;"></i>
                    <small style="font-size: 0.65rem;">@L.Get("BotNavChat")</small>
                </a>
                <a asp-controller="Notification" asp-action="Index" class="text-center text-light text-decoration-none" style="flex:1;">
                    <i class="fa-solid fa-bell fs-5 mb-1 d-block text-warning" style="color: #cbd5e1;"></i>
                    <small style="font-size: 0.65rem;">@L.Get("BotNavNotif")</small>
                </a>
            </div>
        </nav>
    }

    <!-- Admin Offcanvas Sidebar -->
    @if (User?.Claims?.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value == "Admin")
    {
        <div class="offcanvas offcanvas-start bg-dark text-light shadow-lg" tabindex="-1" id="adminSidebarOffcanvas" style="border-right: 1px solid rgba(251,191,36,0.2); width: 340px; background: rgba(13, 17, 23, 0.98) !important;">
            <div class="offcanvas-header pb-2" style="border-bottom: 1px solid rgba(255,255,255,0.05); background: linear-gradient(135deg, rgba(251,191,36,0.05) 0%, transparent 100%);">
                <h5 class="offcanvas-title fw-bold text-warning font-monospace d-flex align-items-center">
                    <i class="fa-solid fa-crown me-2"></i> @L.Get("CommandPanel")
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body p-0 d-flex flex-column" style="background-image: radial-gradient(rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 20px 20px;">
                <div class="list-group list-group-flush mt-3" style="background: transparent;">
                    <a asp-controller="Admin" asp-action="Roadmap" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-3 hover-glass d-flex align-items-center mb-1">
                        <span class="bg-success bg-opacity-10 text-success rounded d-flex align-items-center justify-content-center me-3" style="width:40px;height:40px;"><i class="fa-solid fa-map-location-dot fa-lg"></i></span>
                        <div>
                            <span class="fw-bold d-block" style="letter-spacing:1px;font-family:'JetBrains Mono',monospace;">@L.Get("Roadmap")</span>
                            <small class="text-muted" style="font-size:0.75rem;">@L.Get("RoadmapDesc")</small>
                        </div>
                    </a>
                    
                    <a asp-controller="Admin" asp-action="Users" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-3 hover-glass d-flex align-items-center mb-1">
                        <span class="bg-info bg-opacity-10 text-info rounded d-flex align-items-center justify-content-center me-3" style="width:40px;height:40px;"><i class="fa-solid fa-users-viewfinder fa-lg"></i></span>
                        <div>
                            <span class="fw-bold d-block">@L.Get("TeamMgmt")</span>
                            <small class="text-muted" style="font-size:0.75rem;">@L.Get("TeamMgmtDesc")</small>
                        </div>
                    </a>

                    <a asp-controller="Admin" asp-action="WorkReports" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-3 hover-glass d-flex align-items-center mb-1">
                        <span class="bg-warning bg-opacity-10 text-warning rounded d-flex align-items-center justify-content-center me-3" style="width:40px;height:40px;"><i class="fa-solid fa-file-invoice fa-lg"></i></span>
                        <div>
                            <span class="fw-bold d-block">@L.Get("ZReport")</span>
                            <small class="text-muted" style="font-size:0.75rem;">@L.Get("ZReportDesc")</small>
                        </div>
                    </a>

                    <a asp-controller="Admin" asp-action="Leaderboard" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-3 hover-glass d-flex align-items-center mb-1">
                        <span class="bg-primary bg-opacity-10 text-primary rounded d-flex align-items-center justify-content-center me-3" style="width:40px;height:40px;"><i class="fa-solid fa-trophy fa-lg"></i></span>
                        <div>
                            <span class="fw-bold d-block">@L.Get("PerformanceLeague")</span>
                            <small class="text-muted" style="font-size:0.75rem;">@L.Get("LeaderboardDesc")</small>
                        </div>
                    </a>

                    <a asp-controller="Admin" asp-action="BurnoutMap" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-3 hover-glass d-flex align-items-center mb-1">
                        <span class="bg-danger bg-opacity-10 text-danger rounded d-flex align-items-center justify-content-center me-3" style="width:40px;height:40px;"><i class="fa-solid fa-fire-flame-curved fa-lg"></i></span>
                        <div>
                            <span class="fw-bold d-block">@L.Get("HeatMapSidebar")</span>
                            <small class="text-muted" style="font-size:0.75rem;">@L.Get("HeatMapSidebarDesc")</small>
                        </div>
                    </a>

                    <a asp-controller="Admin" asp-action="Index" class="list-group-item list-group-item-action bg-transparent text-light border-0 py-3 hover-glass d-flex align-items-center mb-1">
                        <span class="bg-secondary bg-opacity-10 text-secondary rounded d-flex align-items-center justify-content-center me-3" style="width:40px;height:40px;"><i class="fa-solid fa-gauge fa-lg"></i></span>
                        <div>
                            <span class="fw-bold d-block">Admin Dashboard</span>
                            <small class="text-muted" style="font-size:0.75rem;">Sistem Geneli Özet</small>
                        </div>
                    </a>
                </div>

                <div class="mt-auto p-4" style="border-top:1px solid rgba(255,255,255,0.05);">
                    <a asp-controller="Admin" asp-action="SystemLogs" class="btn w-100 fw-bold rounded-pill p-3 shadow-lg d-flex justify-content-center align-items-center position-relative overflow-hidden" style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.4); color: #10b981;">
                        <span style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,#10b981,transparent);animation:dashboardShimmer 3s infinite;"></span>
                        <i class="fa-solid fa-satellite-dish me-2" style="animation: pulse 2s infinite;"></i> @L.Get("SystemRadar")
                    </a>
                    <div class="text-center mt-3 text-muted small" style="font-family:'JetBrains Mono',monospace; opacity:0.5; font-size: 0.70rem;">
                        [ @L.Get("CoreVersion") ]
                    </div>
                </div>
            </div>
        </div>
    }

    @if (User?.Identity?.IsAuthenticated == true)
    {
        <script>
            const timerElement = document.getElementById("screenTimer");
            const todayStr = new Date().toISOString().split('T')[0];
            const rawUserName = "@(User?.Identity?.Name ?? "User")";
            const safeUserName = rawUserName.replace(/\s+/g, '_');
            const storageKey = "gb_time_" + safeUserName + "_" + todayStr;

            let totalSeconds = parseInt(localStorage.getItem(storageKey)) || 0;

            fetch('/TimeTracker/GetTodayTime')
                .then(response => response.json())
                .then(data => {
                    totalSeconds = Math.max(totalSeconds, data.minutes * 60);
                    setInterval(() => {
                        totalSeconds++;
                        localStorage.setItem(storageKey, totalSeconds);
                        if (timerElement) {
                            let h = Math.floor(totalSeconds / 3600), m = Math.floor((totalSeconds % 3600) / 60), s = totalSeconds % 60;
                            let timeStr = (h < 10 ? "0" + h : h) + ":" + (m < 10 ? "0" + m : m) + ":" + (s < 10 ? "0" + s : s);
                            timerElement.textContent = timeStr;
                            
                            const timerWidget = document.getElementById('globalTimerWidget');
                            if (timerWidget) {
                                if (h >= 8) {
                                    timerWidget.style.borderColor = "rgba(239, 68, 68, 0.5)";
                                    timerWidget.style.background = "rgba(239, 68, 68, 0.1)";
                                    timerElement.className = "fw-bold text-danger";
                                    timerWidget.querySelector('i').className = "fa-solid fa-fire text-danger me-2";
                                } else if (h >= 6) {
                                    timerWidget.style.borderColor = "rgba(251, 146, 60, 0.5)";
                                    timerWidget.style.background = "rgba(251, 146, 60, 0.1)";
                                    timerElement.className = "fw-bold text-warning";
                                }
                            }
                        }
                    }, 1000);
                });

            setInterval(() => { fetch('/TimeTracker/PingTime', { method: 'POST' }); }, 60000);
        </script>
        
        <!-- SignalR and Global Notification Logic -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const badge = document.getElementById("notificationBadge");
                const list = document.getElementById("notificationList");
                const noText = document.getElementById("noNotificationText");
                
                let unreadCount = 0;
                
                // SignalR Connection for Global Notifications
                const notificationConnection = new signalR.HubConnectionBuilder()
                    .withUrl("/notificationHub")
                    .withAutomaticReconnect()
                    .build();
                
                notificationConnection.on("ReceiveNotification", function(message, link) {
                    // Update Badge
                    unreadCount++;
                    badge.innerText = unreadCount;
                    badge.style.display = "block";
                    
                    if(noText) noText.style.display = "none";
                    
                    // Add to dropdown list
                    const li = document.createElement("li");
                    const a = document.createElement("a");
                    a.className = "dropdown-item text-light border-bottom border-secondary py-2 hover-glass";
                    a.href = link || "#";
                    a.innerHTML = `<small class="d-block text-wrap">${message}</small><small class="text-muted" style="font-size:0.7rem;"><i class="fa-regular fa-clock"></i> Simdi</small>`;
                    
                    // Insert after header (index 1)
                    list.insertBefore(li, list.children[1]);
                    li.appendChild(a);
                    
                    // Play sound (optional) or flash title
                    document.title = "(1) " + document.title;
                });
                
                notificationConnection.start().catch(err => console.error("Notification Hub Error:", err));
                
                // Fetch existing unread notifications on load
                fetch('/Notification/GetMyNotifications')
                    .then(response => response.json())
                    .then(res => {
                        if(res.success && res.count > 0) {
                            unreadCount = res.count;
                            badge.innerText = unreadCount;
                            badge.style.display = "block";
                            if(noText) noText.style.display = "none";
                            
                            res.data.reverse().forEach(n => {
                                const li = document.createElement("li");
                                const a = document.createElement("a");
                                a.className = "dropdown-item text-light border-bottom border-secondary py-2 hover-glass";
                                a.href = n.link || "#";
                                a.innerHTML = `<small class="d-block text-wrap">${n.message}</small><small class="text-muted" style="font-size:0.7rem;"><i class="fa-regular fa-clock"></i> ${n.time}</small>`;
                                list.insertBefore(li, list.children[1]);
                                li.appendChild(a);
                            });
                        }
                    });
                    
                // Mark as read when clicking the bell
                document.getElementById('notificationDropdown').addEventListener('click', function() {
                    if (unreadCount > 0) {
                        fetch('/Notification/MarkAsRead', { method: 'POST' }).then(() => {
                            badge.style.display = "none";
                            unreadCount = 0;
                        });
                    }
                });
            });
        </script>
    }

