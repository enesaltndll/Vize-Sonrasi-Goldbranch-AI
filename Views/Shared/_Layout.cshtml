    <script>
        // 💚 SAĞLIK KORUMA SİSTEMİ (WELLNESS GUARDIAN)
        document.addEventListener("DOMContentLoaded", () => {
            // Bildirim izni iste (1 kez)
            if ('Notification' in window && Notification.permission === 'default') {
                Notification.requestPermission();
            }

            const W = {
                EYE_INTERVAL_MS: 20 * 60 * 1000,       // 20 dk (20-20-20 kuralı)
                POSTURE_INTERVAL_MS: 60 * 60 * 1000,   // 60 dk (Postür uyarısı)
                LOCK_AFTER_MS: 120 * 60 * 1000,        // 120 dk (Zorunlu Mola - Uyku Kalkanı)
                MIN_BREAK_MS: 5 * 60 * 1000,           // 5 dk zorunlu dinlenme süresi

                STORAGE: {
                    lastBreakAt: 'gb_wellness_last_break_at',
                    lastEyeAt: 'gb_wellness_last_eye_at',
                    lastPostureAt: 'gb_wellness_last_posture_at',
                    lockUntil: 'gb_wellness_lock_until',
                    lockActiveSince: 'gb_wellness_lock_active_since',
                    welcomeKey: 'gb_wellness_welcome_'
                }
            };

            const lockOverlay = document.getElementById('wellnessLockOverlay');
            const lockCountdown = document.getElementById('wellnessLockCountdown');
            const lockBar = document.getElementById('wellnessLockBar');
            const lockDoneBtn = document.getElementById('wellnessLockDoneBtn');
            const lockSnoozeBtn = document.getElementById('wellnessLockSnoozeBtn');

            function now() { return Date.now(); }
            function getNum(key, fallback = 0) {
                const n = parseInt(localStorage.getItem(key) || '');
                return Number.isFinite(n) ? n : fallback;
            }
            function setNum(key, value) { localStorage.setItem(key, String(value)); }

            async function sendSystemNotification(tip) {
                if (!('Notification' in window)) return;
                if (!('serviceWorker' in navigator)) return;
                if (Notification.permission !== 'granted') return;

                const title = 'GoldBranch AI - ' + tip.title;
                const body = (tip.message || '').replace(/<[^>]*>/g, '');
                const payload = {
                    type: 'WELLNESS_NOTIFICATION',
                    title,
                    body,
                    icon: 'https://cdn-icons-png.flaticon.com/512/9334/9334400.png',
                    tag: 'wellness-' + Date.now()
                };

                // Prefer SW controller messaging (shows up in OS notification center)
                if (navigator.serviceWorker.controller) {
                    navigator.serviceWorker.controller.postMessage(payload);
                    return;
                }

                // Fallback: showNotification via ready registration
                const registration = await navigator.serviceWorker.ready;
                await registration.showNotification(title, { body, icon: payload.icon, tag: payload.tag });
            }

            function markBreakTaken() {
                const t = now();
                setNum(W.STORAGE.lastBreakAt, t);
                setNum(W.STORAGE.lastEyeAt, t);
                setNum(W.STORAGE.lastPostureAt, t);
            }

            function isLocked() {
                const until = getNum(W.STORAGE.lockUntil, 0);
                return until > now();
            }

            function showLockOverlay() {
                if (!lockOverlay) return;
                lockOverlay.style.display = 'flex';
                document.body.style.overflow = 'hidden';
            }

            function hideLockOverlay() {
                if (!lockOverlay) return;
                lockOverlay.style.display = 'none';
                document.body.style.overflow = '';
            }

            function startLock(minMs) {
                const startAt = now();
                const until = startAt + Math.max(W.MIN_BREAK_MS, minMs);
                setNum(W.STORAGE.lockActiveSince, startAt);
                setNum(W.STORAGE.lockUntil, until);
                showLockOverlay();
            }

            function updateLockUI() {
                if (!lockOverlay || lockOverlay.style.display === 'none') return;
                const startAt = getNum(W.STORAGE.lockActiveSince, now());
                const until = getNum(W.STORAGE.lockUntil, now());
                const total = Math.max(1, until - startAt);
                const remaining = Math.max(0, until - now());
                const done = remaining === 0;

                const m = Math.floor(remaining / 60000).toString().padStart(2, '0');
                const s = Math.floor((remaining % 60000) / 1000).toString().padStart(2, '0');
                if (lockCountdown) lockCountdown.textContent = `${m}:${s}`;

                const pct = Math.min(100, Math.max(0, ((total - remaining) / total) * 100));
                if (lockBar) lockBar.style.width = pct + '%';

                if (lockDoneBtn) lockDoneBtn.disabled = !done;
            }

            // Hierarchical wellness engine (tek döngü)
            async function tick() {
                // Lock devam ediyorsa sadece UI güncelle
                if (isLocked()) {
                    showLockOverlay();
                    updateLockUI();
                    return;
                } else {
                    hideLockOverlay();
                }

                const t = now();
                const lastBreakAt = getNum(W.STORAGE.lastBreakAt, t);
                const lastEyeAt = getNum(W.STORAGE.lastEyeAt, lastBreakAt);
                const lastPostureAt = getNum(W.STORAGE.lastPostureAt, lastBreakAt);
                const sinceBreak = t - lastBreakAt;

                // En son aşama: 90 dk molasız → kilit yerine AUTO-ZEN
                if (sinceBreak >= W.LOCK_AFTER_MS) {
                    setNum(W.STORAGE.lastBreakAt, t);
                    setNum(W.STORAGE.lastEyeAt, t);
                    setNum(W.STORAGE.lastPostureAt, t);
                    
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            icon: 'warning',
                            title: '🛑 Sistemsel Kilit (Zen Modu)',
                            html: 'Dikkatini toplayabilmen için <b>3 dakikalık</b> mola merkezine yönlendiriliyorsun.',
                            background: '#0d1117',
                            color: '#f0f6fc',
                            confirmButtonText: 'Zen Modunu Başlat',
                            confirmButtonColor: '#fbbf24',
                            allowOutsideClick: false
                        }).then(() => {
                            window.location.href = '/Zen?duration=3';
                        });
                    }
                    return;
                }

                // 60 dk: postür/kalk uyarısı (gösterilmediyse)
                if (sinceBreak >= W.POSTURE_INTERVAL_MS && (t - lastPostureAt) >= W.POSTURE_INTERVAL_MS) {
                    setNum(W.STORAGE.lastPostureAt, t);
                    await sendSystemNotification({
                        title: 'Kalk & Postür (Şimdi Zen Zamanı)',
                        message: '1 saattir ekrandasın. 5 dakika dik durma ve meditasyon sırası.'
                    });

                    if (!document.hidden && typeof Swal !== 'undefined') {
                        const res = await Swal.fire({
                            icon: 'info',
                            title: '🧍 1 Saat Oldu',
                            html: 'Ayağa kalk, esne ve <b>5 dakikalık</b> mola paneline geç.',
                            background: '#0d1117',
                            color: '#f0f6fc',
                            showCancelButton: true,
                            confirmButtonText: 'Zen Moduna Geç',
                            cancelButtonText: 'Sonra',
                            confirmButtonColor: '#34d399',
                            cancelButtonColor: '#64748b',
                            timer: 15000,
                            timerProgressBar: true
                        });
                        if (res.isConfirmed) {
                            markBreakTaken();
                            window.location.href = '/Zen?duration=5';
                        }
                    }
                    return;
                }

                // 20 dk: göz kırpma/uzağa bakma (gösterilmediyse)
                if (sinceBreak >= W.EYE_INTERVAL_MS && (t - lastEyeAt) >= W.EYE_INTERVAL_MS) {
                    setNum(W.STORAGE.lastEyeAt, t);
                    await sendSystemNotification({
                        title: 'Gözlerini Dinlendir',
                        message: '20 dakikadır ekrana bakıyorsun. 1 dakikalık hızlı şarj zamanı.'
                    });

                    if (!document.hidden && typeof Swal !== 'undefined') {
                        const res = await Swal.fire({
                            icon: 'warning',
                            title: '👁️ 20 Dakika Oldu',
                            html: '<b>20-20-20</b> kuralı: 1 Dakikalık Çok Kısa Zen.',
                            background: '#0d1117',
                            color: '#f0f6fc',
                            showCancelButton: true,
                            confirmButtonText: 'Odaklanmaya Ara Ver',
                            cancelButtonText: 'Sonra',
                            confirmButtonColor: '#38bdf8',
                            cancelButtonColor: '#64748b'
                        });
                        if (res.isConfirmed) {
                            window.location.href = '/Zen?duration=1';
                        } else {
                            setNum(W.STORAGE.lastEyeAt, now());
                        }
                    }
                }
            }

            // Lock overlay butonları
            if (lockDoneBtn) {
                lockDoneBtn.addEventListener('click', () => {
                    if (isLocked()) return;
                    markBreakTaken();
                    localStorage.removeItem(W.STORAGE.lockUntil);
                    localStorage.removeItem(W.STORAGE.lockActiveSince);
                    hideLockOverlay();
                });
            }
            if (lockSnoozeBtn) {
                lockSnoozeBtn.addEventListener('click', () => {
                    const until = getNum(W.STORAGE.lockUntil, now());
                    setNum(W.STORAGE.lockUntil, until + (2 * 60 * 1000));
                    updateLockUI();
                });
            }

            // İlk kurulum veya eski session (4 saati geçmişse) sıfırla ki girişte hemen uyarmasın
            const lastBrk = getNum(W.STORAGE.lastBreakAt, 0);
            if (!lastBrk || (now() - lastBrk > 4 * 60 * 60 * 1000)) {
                markBreakTaken();
                // Kilitli kalmışsa kilidi de kaldır
                if (isLocked()) {
                    localStorage.removeItem(W.STORAGE.lockUntil);
                    localStorage.removeItem(W.STORAGE.lockActiveSince);
                }
            }

            // Sayfa yenilense bile kilit sürsün
            if (isLocked()) showLockOverlay();
            updateLockUI();

            // Tek interval: 1 dakikada bir kontrol + lock countdown için 1sn UI
            // setInterval(tick, 10000); // DEMO MODU TEST İÇİN            // DEVREYE ALINAN YENİ WELLNESS AUTOPILOT
            setInterval(tick, 1000); // Otomatik Zen Modu denetleyicisi

            // İlk 5 sn sonra hoşgeldin bildirimi
            const todayKey = "gb_wellness_welcome_" + new Date().toISOString().slice(0, 10);
            if (!localStorage.getItem(todayKey)) {
                localStorage.setItem(todayKey, "1");
                setTimeout(() => {
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            toast: true,
                            position: 'bottom-start',
                            icon: 'success',
                            title: '🔇 Sağlık Sistemi Geçici Kapatıldı',
                            text: 'Test sürecini rahatça yapabilmen için mola uyarıları donduruldu.',
                            showConfirmButton: false,
                            timer: 3500,
                            background: '#0d1117',
                            color: '#34d399'
                        });
                    }
                }, 5000);
            }
        });
    </script>





    <script>
        document.addEventListener("DOMContentLoaded", () => {
            document.querySelectorAll('.theme-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    const theme = btn.getAttribute('data-theme');
                    document.documentElement.setAttribute('data-theme', theme);
                    localStorage.setItem('gb-theme', theme);
                });
            });
        });

        (function() {
            const canvas = document.getElementById('particleCanvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            let w, h, particles = [];

            function resize() {
                w = canvas.width = window.innerWidth;
                h = canvas.height = window.innerHeight;
            }
            resize();
            window.addEventListener('resize', resize);
            
            let mouse = { x: null, y: null, radius: 150 };
            window.addEventListener('mousemove', (e) => { mouse.x = e.x; mouse.y = e.y; });
            window.addEventListener('mouseout', () => { mouse.x = null; mouse.y = null; });


            class Particle {
                constructor() { this.reset(); }
                reset() {
                    this.x = Math.random() * w;
                    this.y = Math.random() * h;
                    this.size = Math.random() * 2 + 0.5;
                    this.speedX = (Math.random() - 0.5) * 0.3;
                    this.speedY = (Math.random() - 0.5) * 0.3;
                    this.opacity = Math.random() * 0.5 + 0.1;
                    this.color = Math.random() > 0.7 ? '251,191,36' : (Math.random() > 0.5 ? '34,211,238' : '167,139,250');
                }
                update() {
                    if (mouse.x != null && mouse.y != null) {
                        let dx = mouse.x - this.x;
                        let dy = mouse.y - this.y;
                        let dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < mouse.radius) {
                            const forceDirX = dx / dist;
                            const forceDirY = dy / dist;
                            const force = (mouse.radius - dist) / mouse.radius;
                            this.x -= forceDirX * force * 5;
                            this.y -= forceDirY * force * 5;
                        }
                    }
                    this.x += this.speedX;
                    this.y += this.speedY;
                    if (this.x < 0 || this.x > w || this.y < 0 || this.y > h) this.reset();
                }
                draw() {
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    ctx.fillStyle = 'rgba(' + this.color + ',' + this.opacity + ')';
                    ctx.fill();
                }
            }

            for (let i = 0; i < 60; i++) particles.push(new Particle());

            function animate() {
                ctx.clearRect(0, 0, w, h);
                particles.forEach(p => { p.update(); p.draw(); });

                // Draw connections
                for (let i = 0; i < particles.length; i++) {
                    if (mouse.x != null && mouse.y != null) {
                        const mdx = particles[i].x - mouse.x;
                        const mdy = particles[i].y - mouse.y;
                        const mDist = Math.sqrt(mdx * mdx + mdy * mdy);
                        if (mDist < 180) {
                            ctx.beginPath();
                            ctx.strokeStyle = 'rgba(34,211,238,' + (0.2 * (1 - mDist / 180)) + ')';
                            ctx.lineWidth = 1.2;
                            ctx.moveTo(particles[i].x, particles[i].y);
                            ctx.lineTo(mouse.x, mouse.y);
                            ctx.stroke();
                        }
                    }
                    for (let j = i + 1; j < particles.length; j++) {
                        const dx = particles[i].x - particles[j].x;
                        const dy = particles[i].y - particles[j].y;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < 120) {
                            ctx.beginPath();
                            ctx.strokeStyle = 'rgba(251,191,36,' + (0.06 * (1 - dist / 120)) + ')';
                            ctx.lineWidth = 0.5;
                            ctx.moveTo(particles[i].x, particles[i].y);
                            ctx.lineTo(particles[j].x, particles[j].y);
                            ctx.stroke();
                        }
                    }
                }
                requestAnimationFrame(animate);
            }
            animate();
        })();
    </script>
    <script>
        // Service Worker & Notifications API
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').then(reg => {
                    console.log('SW Registered!', reg);
                }).catch(err => console.log('SW Registration failed', err));
            });
        }
        
        // Push Notification Request On Login
        document.addEventListener('DOMContentLoaded', () => {
            if ("Notification" in window) {
                if (Notification.permission !== "granted" && Notification.permission !== "denied") {
                    Notification.requestPermission().then(permission => {
                        if (permission === 'granted') {
                            new Notification("GoldBranch AI", { 
                                body: "Sistem bildirimleri aktif edildi! Yeni görevlerde haberdar olacaksınız.",
                                icon: "https://cdn-icons-png.flaticon.com/512/9334/9334400.png"
                            });
                        }
                    });
                }
            }
        });
    </script>

    <!-- GLOBAL PAGE LOADER & ERROR HANDLER -->
    <script>
        // Page Loader: hide when fully loaded
        window.addEventListener('load', () => {
            const loader = document.getElementById('pageLoader');
            if(loader) { setTimeout(() => { loader.classList.remove('active'); }, 400); }
        });

        // Show loader on navigation
        document.querySelectorAll('a[href]:not([target="_blank"]):not([href^="#"]):not([href^="javascript"])').forEach(link => {
            link.addEventListener('click', () => {
                const loader = document.getElementById('pageLoader');
                if(loader) loader.classList.add('active');
            });
        });

        // Global JS Error Handler
        window.onerror = function(msg, source, line, col, error) {
            console.error('[GoldBranch Hata Yakalayıcı]', { msg, source, line, col });
            return false;
        };

        // --- A to Z ELEGANT TOUCHES --- //
        // 1. Dynamic Tab Title (Attention Grabber)
        const originalDocTitle = document.title;
        document.addEventListener("visibilitychange", function() {
            if (document.hidden) {
                document.title = "🚀 Geri Dön Şef! Sistem Bekliyor...";
            } else {
                document.title = originalDocTitle;
            }
        });

        // 2. Ambient Mouse Aura (Follows cursor with Gold/Cyan pulse)
        if (window.innerWidth > 992) {
            const aura = document.createElement('div');
            aura.style.cssText = 'position:fixed; top:0; left:0; width:400px; height:400px; background:radial-gradient(circle, rgba(251,191,36,0.08) 0%, transparent 60%); border-radius:50%; transform:translate(-50%, -50%); pointer-events:none; z-index:9999; transition:width 0.3s, height 0.3s, background 0.3s; mix-blend-mode: screen;';
            document.body.appendChild(aura);

            document.addEventListener('mousemove', (e) => {
                aura.style.left = e.clientX + 'px';
                aura.style.top = e.clientY + 'px';
            });
            document.addEventListener('mousedown', () => { 
                aura.style.width = '250px'; aura.style.height = '250px'; 
                aura.style.background = 'radial-gradient(circle, rgba(34,211,238,0.15) 0%, transparent 60%)'; 
            });
            document.addEventListener('mouseup', () => { 
                aura.style.width = '400px'; aura.style.height = '400px'; 
                aura.style.background = 'radial-gradient(circle, rgba(251,191,36,0.08) 0%, transparent 60%)'; 
            });
        }
        
        // 3. Smooth Body Fade-In on Page Load
        document.body.style.animation = "bodyFadeIn 0.8s ease forwards";
        
        // 4. Parallax 3D Hologram Effect for Cards
        document.querySelectorAll('.card.bg-dark, .compact-task, .welcome-banner').forEach(el => {
            el.addEventListener('mousemove', (e) => {
                // Ignore for very small screens or nested elements that might glitch
                if(window.innerWidth < 768) return;
                const rect = el.getBoundingClientRect();
                const x = e.clientX - rect.left - (rect.width/2);
                const y = e.clientY - rect.top - (rect.height/2);
                const tiltX = -(y / rect.height) * 10; // Max 10 deg
                const tiltY = (x / rect.width) * 10;
                
                el.style.transform = `perspective(1000px) rotateX(${tiltX}deg) rotateY(${tiltY}deg) scale3d(1.02, 1.02, 1.02)`;
                el.style.transition = 'none';
                el.style.zIndex = '10';
            });
            el.addEventListener('mouseleave', () => {
                el.style.transform = '';
                el.style.transition = 'transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
                el.style.zIndex = '1';
            });
        });

        // 5. Liquid Click Ripple for Buttons
        document.querySelectorAll('.btn').forEach(btn => {
            btn.addEventListener('mousedown', function(e) {
                const rect = this.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                const ripple = document.createElement('span');
                ripple.style.cssText = `position:absolute; width:2px; height:2px; background:rgba(255,255,255,0.4); left:${x}px; top:${y}px; border-radius:50%; transform:translate(-50%, -50%); pointer-events:none; animation:liquidRipple 0.6s linear forwards;`;
                
                if(window.getComputedStyle(this).position === 'static'){
                    this.style.position = 'relative';
                }
                this.style.overflow = 'hidden';
                this.appendChild(ripple);
                
                setTimeout(() => ripple.remove(), 600);
            });
        });

        // 6. Cinematic Scroll Reveal Observer (Fade Up on Scroll)
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if(entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0) scale(1)';
                    // remove observer after reveal
                    revealObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });

        // Wait a tiny bit for render
        setTimeout(() => {
            document.querySelectorAll('.card.bg-dark, .gb-section, .kanban-lane').forEach(el => {
                if (!el.classList.contains('no-reveal')) {
                    el.style.opacity = '0';
                    el.style.transform = 'translateY(40px) scale(0.98)';
                    el.style.transition = 'opacity 0.8s ease, transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1)';
                    revealObserver.observe(el);
                }
            });
        }, 100);

        if(!document.querySelector('#bodyFadeStyle')){
            const style = document.createElement('style');
            style.id = 'bodyFadeStyle';
            style.innerHTML = `
                @@keyframes bodyFadeIn { from { opacity: 0; transform: scale(0.99); } to { opacity: 1; transform: scale(1); } }
                @@keyframes liquidRipple { 0% { transform: scale(0); opacity: 1; } 100% { transform: scale(200); opacity: 0; } }
                .neural-card { position: relative; }
                .neural-card::before {
                    content: ""; position: absolute; top:0; left:0; width:100%; height:100%;
                    background: radial-gradient(400px circle at var(--mx) var(--my), rgba(34,211,238,0.15), transparent 40%);
                    z-index: 1; opacity: 0; transition: opacity 0.3s; pointer-events: none; mix-blend-mode: screen; border-radius: inherit;
                }
                .neural-card:hover::before { opacity: 1; }
            `;
            document.head.appendChild(style);
        }

        // 7. Cybernetic Scroll Progress Bar
        window.addEventListener('scroll', () => {
            const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scrolled = (winScroll / height) * 100;
            const bar = document.getElementById("gbScrollProgressBar");
            if (bar) bar.style.width = scrolled + "%";
        });

        // 8. Neural Card Active Lighting (Hologram Surface Lighting)
        document.querySelectorAll('.card.bg-dark, .compact-task, .welcome-banner').forEach(card => {
            card.classList.add('neural-card');
            card.addEventListener('mousemove', e => {
                const rect = card.getBoundingClientRect();
                card.style.setProperty('--mx', (e.clientX - rect.left) + 'px');
                card.style.setProperty('--my', (e.clientY - rect.top) + 'px');
            });
        });

        // 9. Magnetic Floating Action Bar (Pulls towards mouse)
        const fabDock = document.getElementById('gbFabDock');
        if (fabDock && window.innerWidth > 768) {
            fabDock.addEventListener('mousemove', e => {
                const rect = fabDock.getBoundingClientRect();
                const x = e.clientX - rect.left - rect.width / 2;
                const y = e.clientY - rect.top - rect.height / 2;
                fabDock.style.transform = `translate(${x * 0.4}px, ${y * 0.4}px)`;
            });
            fabDock.addEventListener('mouseleave', () => {
                fabDock.style.transform = 'translate(0px, 0px)';
            });
            fabDock.style.transition = 'transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
        }

        // 10. Matrix/Hacker Decode Effect on Brand Logo Hover
        const brandLogo = document.querySelector('.navbar-brand');
        if(brandLogo) {
            const originalHtml = brandLogo.innerHTML;
            const originalText = "GoldBranch AI";
            const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@@#$%^&*";
            let glitchInterval = null;
            brandLogo.addEventListener('mouseover', () => {
                let iteration = 0;
                clearInterval(glitchInterval);
                glitchInterval = setInterval(() => {
                    const iconHtml = '<i class="fa-solid fa-leaf text-warning" style="-webkit-text-fill-color: #fbbf24;"></i> ';
                    const scrambled = originalText.split("").map((letter, index) => {
                        if(index < iteration) return originalText[index];
                        return letters[Math.floor(Math.random() * letters.length)];
                    }).join("");
                    brandLogo.innerHTML = iconHtml + scrambled;
                    if(iteration >= originalText.length) clearInterval(glitchInterval);
                    iteration += 1 / 3;
                }, 30);
            });
            brandLogo.addEventListener('mouseleave', () => {
                clearInterval(glitchInterval);
                brandLogo.innerHTML = originalHtml;
            });
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
