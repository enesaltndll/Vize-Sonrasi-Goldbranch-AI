    <!-- 🎙️ HAFTA 6: GLOBAL VOICE COMMAND (Web Speech API) & HAFTA 8: SERVICE WORKER -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // Jarvis Initialization
            Jarvis.init();

            // Service Worker Registration
            if ('serviceWorker' in navigator) {
                navigator.serviceWorker.register('/sw.js').then(reg => {
                    console.log('Enterprise Service Worker registered.');
                }).catch(err => console.log('SW Error:', err));
            }
            // Request Notification Permission on first load
            if ("Notification" in window && Notification.permission === "default") {
                Notification.requestPermission();
            }

            // Global Voice Command Setup
            const voiceBtn = document.getElementById('globalVoiceCmdBtn');
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            
            if (voiceBtn && SpeechRecognition) {
                const recognition = new SpeechRecognition();
                recognition.lang = 'tr-TR';
                recognition.continuous = false;
                recognition.interimResults = false;

                voiceBtn.addEventListener('click', () => {
                    recognition.start();
                    voiceBtn.innerHTML = '<i class="fa-solid fa-microphone-lines fa-fade"></i>';
                    voiceBtn.classList.replace('text-warning', 'text-danger');
                    
                    Swal.fire({
                        title: 'Dinleniyor...',
                        text: "Lütfen komutunuzu söyleyin (Örn: 'Görev ekle yeni modül tasarımı')",
                        icon: 'info',
                        toast: true, position: 'top-end', showConfirmButton: false, timer: 3000
                    });
                });

                recognition.onresult = (e) => {
                    const text = e.results[0][0].transcript;
                    Swal.fire({
                        title: 'Sesli Komut Algılandı',
                        text: `"${text}"`,
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonText: 'Hemen Ekle',
                        cancelButtonText: 'İptal',
                        background: '#0d1117', color: '#fbbf24'
                    }).then((result) => {
                        if(result.isConfirmed) {
                            window.location.href = `/Task/Create?title=${encodeURIComponent(text)}`;
                        }
                    });
                };

                recognition.onend = () => {
                    voiceBtn.innerHTML = '<i class="fa-solid fa-microphone"></i>';
                    voiceBtn.classList.replace('text-danger', 'text-warning');
                };
                recognition.onerror = () => {
                    voiceBtn.innerHTML = '<i class="fa-solid fa-microphone"></i>';
                    voiceBtn.classList.replace('text-danger', 'text-warning');
                    Swal.fire({toast: true, position: 'top-end', icon: 'error', title: 'Mikrofon algılanamadı veya kapatıldı.'});
                };
            } else if (voiceBtn) {
                voiceBtn.style.display = 'none'; // Tarayıcı desteklemiyorsa gizle
            }
        });
    </script>

    <!-- 🎰 LIVE ACHIEVEMENT TICKER ENGINE -->
    <script>
        (function() {
            const tickerEl = document.getElementById('gbTickerContent');
            if (!tickerEl) return;

            async function loadTickerFeed() {
                try {
                    const res = await fetch('/Zen/LiveFeed');
                    if (!res.ok) return;
                    const items = await res.json();
                    if (!items || items.length === 0) return;

                    // Shuffle items for variety
                    for (let i = items.length - 1; i > 0; i--) {
                        const j = Math.floor(Math.random() * (i + 1));
                        [items[i], items[j]] = [items[j], items[i]];
                    }

                    // Build ticker HTML
                    let html = '';
                    items.forEach(item => {
                        const iconColor = item.type === 'badge' ? '#fbbf24' : 
                                         item.type === 'highscore' ? '#22d3ee' :
                                         item.type === 'discount' ? '#10b981' : '#a78bfa';
                        html += `<span class="gb-ticker-item">
                            <span class="gb-ticker-icon">${item.icon}</span>
                            <span style="color:${iconColor}">${item.text}</span>
                        </span>`;
                    });

                    // Duplicate content for seamless infinite loop
                    tickerEl.innerHTML = html + html;

                    // Calculate scroll duration based on content width
                    requestAnimationFrame(() => {
                        const contentWidth = tickerEl.scrollWidth / 2;
                        const speed = 60; // pixels per second
                        const duration = contentWidth / speed;
                        tickerEl.style.setProperty('--ticker-duration', duration + 's');
                    });

                } catch(e) {
                    console.log('Ticker feed error:', e);
                }
            }

            // Load immediately and refresh every 2 minutes
            loadTickerFeed();
            setInterval(loadTickerFeed, 120000);
        })();
    </script>

