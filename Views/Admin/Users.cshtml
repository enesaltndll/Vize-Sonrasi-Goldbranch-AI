@model IEnumerable<GoldBranchAI.Models.AppUser>
@{
    ViewData["Title"] = "Kullanici Yonetimi";
}

<div class="row mb-4 align-items-center fade-in-up">
    <div class="col-md-8">
        <div class="d-flex align-items-center gap-3 mb-2">
            <span style="display:inline-flex;align-items:center;justify-content:center;width:52px;height:52px;border-radius:16px;background:linear-gradient(135deg,rgba(34,211,238,0.15),rgba(34,211,238,0.05));border:1px solid rgba(34,211,238,0.2);">
                <i class="fa-solid fa-users-gear text-info" style="font-size:1.3rem;"></i>
            </span>
            <div>
                <h2 class="text-light fw-bold mb-0">Ekip Yonetimi</h2>
                <p class="text-muted mb-0 small">Proje Sefi atamalarini buradan yapabilirsiniz.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 text-end">
        <span class="badge bg-secondary px-3 py-2" style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;">
            <i class="fa-solid fa-users me-1"></i> Toplam: @Model.Count() kisi
        </span>
    </div>
</div>

<div class="d-flex flex-column gap-3 mt-4 fade-in-up" style="animation-delay: 0.1s;">
    @foreach (var user in Model)
    {
        string roleColor = user.Role == "Admin" ? "var(--gb-accent-rose)" : (user.Role == "Proje Sefi" ? "var(--gb-gold)" : "var(--gb-text-secondary)");
        string roleBg = user.Role == "Admin" ? "rgba(251,113,133,0.1)" : (user.Role == "Proje Sefi" ? "rgba(251,191,36,0.1)" : "rgba(139,148,158,0.1)");
        string roleIcon = user.Role == "Admin" ? "fa-crown" : (user.Role == "Proje Sefi" ? "fa-star" : "fa-code");

        <div class="p-3 px-4 rounded-4 d-flex flex-column flex-md-row justify-content-between align-items-center shadow-sm position-relative overflow-hidden" 
             style="background: var(--gb-bg-card); border: 1px solid var(--gb-border); transition: var(--gb-transition-smooth); gap: 15px;">
             
             <!-- Hover Glow Line -->
             <div class="position-absolute top-0 start-0 w-100 h-100 pointer-events-none opacity-0" 
                  style="background: radial-gradient(800px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(255,255,255,0.06), transparent 40%); transition: opacity 0.3s;"
                  onmousemove="this.style.setProperty('--mouse-x', event.offsetX + 'px'); this.style.setProperty('--mouse-y', event.offsetY + 'px');"
                  onmouseenter="this.style.opacity = '1';" onmouseleave="this.style.opacity = '0';">
             </div>

            <div class="d-flex align-items-center w-100 w-md-auto z-1" style="flex: 1;">
                <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,rgba(255,255,255,0.05),transparent);display:flex;align-items:center;justify-content:center;margin-right:16px;border:1px solid rgba(255,255,255,0.08); box-shadow: 0 4px 15px rgba(0,0,0,0.2);">
                    <i class="fa-solid fa-user text-muted" style="font-size:1.1rem;"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-1 text-light" style="letter-spacing:0.5px;">@user.FullName</h5>
                    <div class="text-muted d-flex align-items-center gap-2" style="font-size:0.85rem; font-family:'JetBrains Mono',monospace;">
                        <i class="fa-solid fa-envelope" style="opacity:0.5;"></i> @user.Email
                    </div>
                </div>
            </div>

            <div class="d-flex align-items-center w-100 w-md-auto justify-content-between z-1" style="flex: 1.5;">
                <div class="d-flex flex-column gap-1 me-4">
                    <span class="text-muted small text-uppercase" style="font-size:0.65rem; letter-spacing:1px; opacity:0.7;">Mevcut Rol</span>
                    <span class="badge px-3 py-2 rounded-pill d-flex align-items-center gap-2" style="background: @roleBg; color: @roleColor; border: 1px solid @roleColor; font-size:0.8rem;">
                        <i class="fa-solid @roleIcon"></i> @user.Role
                    </span>
                </div>

                <div class="d-flex align-items-center gap-2">
                    @if (user.Role != "Admin")
                    {
                        <form asp-action="ChangeRole" method="post" class="d-inline-flex gap-2 align-items-center bg-dark bg-opacity-50 p-1 rounded-pill border border-secondary" style="border-color: rgba(255,255,255,0.05) !important;">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <select name="newRole" class="form-select form-select-sm bg-transparent text-light border-0 shadow-none ps-3 pe-4 fw-bold" style="width: 140px; cursor:pointer;" onchange="this.style.color='var(--gb-accent-cyan)'">
                                <option value="Gelistirici" style="background: #0d1117; color:white;" selected="@(user.Role == "Gelistirici" ? "selected" : null)">Geliştirici</option>
                                <option value="Proje Sefi" style="background: #0d1117; color:white;" selected="@(user.Role == "Proje Sefi" ? "selected" : null)">Proje Şefi</option>
                            </select>
                            <button type="submit" class="btn btn-sm rounded-pill px-3" style="background: var(--gb-accent-cyan); color: #000; font-weight:600; transition:0.3s; transform:scale(0.95);">
                                <i class="fa-solid fa-bolt me-1"></i> Yetkilendir
                            </button>
                        </form>

                        <form asp-action="DeleteUser" method="post" class="d-inline ms-2" onsubmit="return confirm('@user.FullName adlı kullanıcıyı sistemden TAMAMEN silmek istediğinize emin misiniz? Bu işlem geri alınamaz!')">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-outline-danger rounded-circle p-2 d-flex align-items-center justify-content-center" style="width:38px; height:38px; transition:0.3s;" title="Kullanıcıyı Sil">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="d-inline-flex align-items-center px-4 py-2 rounded-pill" style="background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.1);">
                            <i class="fa-solid fa-lock text-muted me-2"></i>
                            <span class="text-muted small fst-italic fw-medium">Sistem Yöneticisi Korunuyor</span>
                        </div>
                    }
                </div>
            </div>
            
        </div>
    }
</div>

<style>
    /* Add hover lift to cards */
    .fade-in-up > div:hover {
        transform: translateY(-3px);
        border-color: rgba(255,255,255,0.2) !important;
        box-shadow: 0 10px 40px rgba(0,0,0,0.4), var(--gb-shadow-glow-cyan);
    }
</style>
