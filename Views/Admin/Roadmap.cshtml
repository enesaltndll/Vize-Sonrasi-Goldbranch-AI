@{
    ViewData["Title"] = "GOLDBRANCH_AI_CORE - YOL HARITASI";
}

<style>
    .roadmap-page {
        font-family: 'Inter', sans-serif;
        color: #e2e8f0;
    }
    
    .holo-card {
        background: rgba(15, 23, 42, 0.95);
        border: 1px solid rgba(56, 189, 248, 0.2);
        box-shadow: 0 10px 40px rgba(0,0,0,0.5), inset 0 0 20px rgba(56, 189, 248, 0.05);
        border-radius: 20px;
        position: relative;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .holo-card::before {
        content: ''; position: absolute; top:0; left:0; right:0; height:1px;
        background: linear-gradient(90deg, transparent, rgba(56, 189, 248, 0.8), transparent);
    }
    
    .holo-card:hover {
        transform: translateY(-5px);
        border-color: rgba(56, 189, 248, 0.5);
        box-shadow: 0 20px 50px rgba(0,0,0,0.7), inset 0 0 30px rgba(56, 189, 248, 0.1);
    }

    .hero-glitch {
        font-family: 'JetBrains Mono', monospace;
        font-size: 3.5rem;
        font-weight: 900;
        letter-spacing: -2px;
        background: linear-gradient(135deg, #fff, #38bdf8, #818cf8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        position: relative;
    }

    .timeline-container { position: relative; padding-left: 50px; }
    .timeline-container::before {
        content: '';
        position: absolute; left: 24px; top: 0; bottom: 0; width: 2px;
        background: linear-gradient(to bottom, #38bdf8, #818cf8, #fbbf24, #ef4444, transparent);
    }

    .timeline-step { position: relative; margin-bottom: 40px; }
    .timeline-step::before {
        content: '';
        position: absolute; left: -34px; top: 5px; width: 18px; height: 18px;
        border-radius: 50%; background: #0f172a; border: 3px solid #38bdf8;
        box-shadow: 0 0 15px #38bdf8; z-index: 2;
        transition: all 0.3s ease;
        display: flex; align-items: center; justify-content: center;
    }
    .timeline-step:hover::before { transform: scale(1.3); background: #38bdf8; }
    
    .timeline-step.completed::before {
        content: '\f00c';
        font-family: 'Font Awesome 6 Free';
        font-weight: 900;
        font-size: 10px;
        color: #10b981;
        border-color: #10b981;
        box-shadow: 0 0 15px rgba(16, 185, 129, 0.5);
    }
    .timeline-step.completed:hover::before {
        background: #10b981;
        color: #fff;
    }

    .stat-ring { width: 100px; height: 100px; border-radius: 50%; border: 4px solid #38bdf8; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.5rem; text-shadow: 0 0 10px #38bdf8; box-shadow: 0 0 20px rgba(56, 189, 248, 0.3), inset 0 0 20px rgba(56, 189, 248, 0.3); }

    .glow-text { text-shadow: 0 0 15px currentColor; }
</style>

