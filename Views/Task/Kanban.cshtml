@model IEnumerable<GoldBranchAI.Models.TodoTask>
@inject GoldBranchAI.Services.LocalizationService L
@{
    ViewData["Title"] = L.Get("KanbanBoardTitle");
}

<style>
    .kanban-board {
        display: flex;
        gap: 20px;
        overflow-x: auto;
        padding-bottom: 20px;
        min-height: 70vh;
    }
    .kanban-column {
        flex: 1;
        min-width: 300px;
        background: rgba(13, 17, 23, 0.9);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: var(--gb-radius-lg);
        padding: 15px;
        display: flex;
        flex-direction: column;
    }
    .kanban-header {
        font-weight: 800;
        font-family: 'JetBrains Mono', monospace;
        letter-spacing: 1px;
        margin-bottom: 15px;
        padding-bottom: 15px;
        border-bottom: 2px solid;
    }
    .kanban-item {
        background: rgba(22, 27, 34, 0.9);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: var(--gb-radius-md);
        padding: 15px;
        margin-bottom: 10px;
        cursor: grab;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .kanban-item:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }
    .kanban-item:active { cursor: grabbing; opacity: 0.8; }
    
    /* Professional Card Additions */
    .avatar-circle {
        width: 24px; height: 24px;
        background: linear-gradient(135deg, #fbbf24, #d97706);
        color: #000; font-weight: bold; font-size: 0.7rem;
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        flex-shrink: 0; border: 1px solid rgba(0,0,0,0.5);
    }
</style>

<div class="mb-4 d-flex justify-content-between align-items-center fade-in-up">
    <div>
        <h2 class="fw-bold mb-1"><i class="fa-solid fa-chess-board text-warning"></i> @L.Get("KanbanRadarTitle")</h2>
        <p class="text-muted mb-0">@L.Get("KanbanRadarDesc")</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <div class="input-group" style="width: 300px;">
            <span class="input-group-text bg-transparent border-0 pe-0" style="color: var(--gb-text-secondary);">
                <i class="fa-solid fa-magnifying-glass"></i>
            </span>
            <input id="kanbanSearchInput" class="form-control gb-input bg-transparent text-light border-secondary" style="border-radius:20px;" type="search" placeholder="Görev veya kişi ara..." autocomplete="off" />
        </div>
        <a asp-controller="Task" asp-action="Index" class="btn btn-outline-secondary rounded-pill fw-bold text-nowrap">
            <i class="fa-solid fa-table me-2"></i> @L.Get("ListViewBtn")
        </a>
    </div>
</div>

<div class="kanban-board fade-in-up" id="kanbanBoard">
    <!-- Bekleyen / Yapılacaklar -->
    <div class="kanban-column" id="col-todo" data-status="Bekliyor">
        <div class="kanban-header text-info" style="border-color: rgba(56,189,248,0.3);">
            @L.Get("KanbanTodo") <span class="badge bg-secondary ms-2">@Model.Count(t => !t.IsCompleted && t.Status != "Devam Ediyor")</span>
        </div>
        <div class="kanban-items" style="min-height: 100px;">
            @foreach(var t in Model.Where(t => !t.IsCompleted && t.Status != "Devam Ediyor" && t.Status != "Onay Bekliyor"))
            {
                bool isLocked = t.DependsOnTask != null && !t.DependsOnTask.IsCompleted;
                <div class="kanban-item" draggable="@(isLocked ? "false" : "true")" style="border-left: 3px solid var(--bs-@t.AuraColor); @(isLocked ? "opacity:0.6; cursor:not-allowed;" : "")" data-id="@t.Id">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div class="fw-bold text-light" style="font-size: 0.95rem; line-height: 1.3;">@t.Title</div>
                        <div class="avatar-circle" title="@t.AppUser?.FullName">@(t.AppUser?.FullName?.Substring(0,1).ToUpper() ?? "U")</div>
                    </div>
                    
                    @if(isLocked)
                    {
                        <div class="mb-2"><span class="badge bg-danger bg-opacity-10 border border-danger text-danger w-100 text-start" style="font-size:0.7rem;"><i class="fa-solid fa-lock"></i> Kilit: @t.DependsOnTask.Title</span></div>
                    }

                    <div class="d-flex justify-content-between align-items-end mt-3">
                        <div class="d-flex flex-wrap gap-1">
                            <span class="badge bg-@t.AuraColor bg-opacity-25 text-@t.AuraColor" style="font-size:0.65rem;"><i class="fa-regular fa-clock"></i> @t.DueDate.ToString("dd MMM")</span>
                            @if(t.EstimatedTimeHours > 0) {
                                <span class="badge bg-secondary bg-opacity-25 text-light" style="font-size:0.65rem;"><i class="fa-solid fa-hourglass-half"></i> @t.EstimatedTimeHours sa</span>
                            }
                        </div>
                        <span class="badge bg-dark border border-secondary text-info" style="font-size:0.65rem;">@L.Get("KanbanWaiting")</span>
                    </div>
                    <a href="/Task/Details/@t.Id" class="stretched-link"></a>
                </div>
            }
        </div>
    </div>

    <!-- Devam Edenler -->
    <div class="kanban-column" id="col-progress" data-status="Devam Ediyor">
        <div class="kanban-header text-warning" style="border-color: rgba(251,191,36,0.3);">
            @L.Get("KanbanInProgress") <span class="badge bg-secondary ms-2">@Model.Count(t => t.Status == "Devam Ediyor")</span>
        </div>
        <div class="kanban-items" style="min-height: 100px;">
            @foreach(var t in Model.Where(t => t.Status == "Devam Ediyor"))
            {
                bool isLocked = t.DependsOnTask != null && !t.DependsOnTask.IsCompleted;
                <div class="kanban-item" draggable="@(isLocked ? "false" : "true")" style="border-left: 3px solid var(--bs-warning); @(isLocked ? "opacity:0.6; cursor:not-allowed;" : "")" data-id="@t.Id">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div class="fw-bold text-light" style="font-size: 0.95rem; line-height: 1.3;">@t.Title</div>
                        <div class="avatar-circle" title="@t.AppUser?.FullName">@(t.AppUser?.FullName?.Substring(0,1).ToUpper() ?? "U")</div>
                    </div>
                    
                    @if(isLocked)
                    {
                        <div class="mb-2"><span class="badge bg-danger bg-opacity-10 border border-danger text-danger w-100 text-start" style="font-size:0.7rem;"><i class="fa-solid fa-lock"></i> Kilit: @t.DependsOnTask.Title</span></div>
                    }

                    <div class="d-flex justify-content-between align-items-end mt-3">
                        <div class="d-flex flex-wrap gap-1">
                            <span class="badge bg-@t.AuraColor bg-opacity-25 text-@t.AuraColor" style="font-size:0.65rem;"><i class="fa-regular fa-clock"></i> @t.DueDate.ToString("dd MMM")</span>
                            @if(t.EstimatedTimeHours > 0) {
                                <span class="badge bg-secondary bg-opacity-25 text-light" style="font-size:0.65rem;"><i class="fa-solid fa-hourglass-half"></i> @t.EstimatedTimeHours sa</span>
                            }
                        </div>
                        <span class="badge bg-warning bg-opacity-10 border border-warning text-warning" style="font-size:0.65rem;"><i class="fa-solid fa-spinner fa-spin me-1"></i>Çalışılıyor</span>
                    </div>
                    <a href="/Task/Details/@t.Id" class="stretched-link"></a>
                </div>
            }
        </div>
    </div>

    <!-- Onay Bekleyenler -->
    <div class="kanban-column" id="col-review" data-status="Onay Bekliyor">
        <div class="kanban-header" style="color: #c084fc; border-color: rgba(192,132,252,0.3);">
            @L.Get("KanbanReview") <span class="badge bg-secondary ms-2">@Model.Count(t => t.Status == "Onay Bekliyor")</span>
        </div>
        <div class="kanban-items" style="min-height: 100px;">
            @foreach(var t in Model.Where(t => t.Status == "Onay Bekliyor" && !t.IsCompleted))
            {
                <div class="kanban-item" draggable="true" style="border-left: 3px solid #c084fc;" data-id="@t.Id">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div class="fw-bold text-light" style="font-size: 0.95rem; line-height: 1.3;">@t.Title</div>
                        <div class="avatar-circle" title="@t.AppUser?.FullName" style="background: linear-gradient(135deg, #c084fc, #9333ea); color:#fff;">@(t.AppUser?.FullName?.Substring(0,1).ToUpper() ?? "U")</div>
                    </div>

                    <div class="d-flex justify-content-between align-items-end mt-3">
                        <div class="d-flex flex-wrap gap-1">
                            <span class="badge bg-secondary bg-opacity-25 text-light" style="font-size:0.65rem;">Code Review</span>
                        </div>
                        <span class="badge" style="background: rgba(192,132,252,0.15); color: #c084fc; border: 1px solid rgba(192,132,252,0.3); font-size:0.65rem;">@L.Get("KanbanLeadWait")</span>
                    </div>
                    <a href="/Task/Details/@t.Id" class="stretched-link"></a>
                </div>
            }
        </div>
    </div>

    <!-- Tamamlananlar -->
    <div class="kanban-column" id="col-done" data-status="Tamamlandı">
        <div class="kanban-header text-success" style="border-color: rgba(16,185,129,0.3);">
            @L.Get("KanbanDone") <span class="badge bg-secondary ms-2">@Model.Count(t => t.IsCompleted)</span>
        </div>
        <div class="kanban-items" style="min-height: 100px;">
            @foreach(var t in Model.Where(t => t.IsCompleted))
            {
                <div class="kanban-item" draggable="true" style="border-left: 3px solid #10b981; opacity: 0.7;" data-id="@t.Id">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div class="fw-bold text-success text-decoration-line-through" style="font-size: 0.95rem; line-height: 1.3;">@t.Title</div>
                        <div class="avatar-circle" title="@t.AppUser?.FullName" style="background: linear-gradient(135deg, #10b981, #059669); color:#fff;">@(t.AppUser?.FullName?.Substring(0,1).ToUpper() ?? "U")</div>
                    </div>

                    <div class="d-flex justify-content-between align-items-end mt-3">
                        <div class="d-flex flex-wrap gap-1">
                            <span class="badge bg-secondary bg-opacity-25 text-light" style="font-size:0.65rem;">Production</span>
                        </div>
                        <span class="badge bg-success bg-opacity-25 text-success border border-success" style="font-size:0.65rem;"><i class="fa-solid fa-check-double me-1"></i>@L.Get("KanbanFinished")</span>
                    </div>
                    <a href="/Task/Details/@t.Id" class="stretched-link"></a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Basit Sürükle Bırak Animasyon Scripti (Front-End Simülasyonu)
        const items = document.querySelectorAll('.kanban-item');
        const columns = document.querySelectorAll('.kanban-column');

        items.forEach(item => {
            item.addEventListener('dragstart', () => {
                item.classList.add('dragging');
                item.style.opacity = '0.5';
                item.dataset.origParent = item.closest('.kanban-column').id;
            });
            item.addEventListener('dragend', () => {
                item.classList.remove('dragging');
                item.style.opacity = '1';
                item.removeAttribute('data-origParent');
            });
        });

        columns.forEach(column => {
            column.addEventListener('dragover', e => {
                e.preventDefault();
                const dragging = document.querySelector('.dragging');
                if (dragging) {
                    column.querySelector('.kanban-items').appendChild(dragging);
                }
            });
            
            column.addEventListener('drop', e => {
                e.preventDefault();
                const dragging = document.querySelector('.dragging[data-origParent]');
                if (!dragging) return;
                
                const origParentId = dragging.dataset.origParent;
                const newColId = column.id;
                
                // Fetch to update status (POST)
                const taskId = dragging.getAttribute('data-id');
                const newStatus = column.getAttribute('data-status');
                
                const formData = new FormData();
                formData.append('id', taskId);
                formData.append('newStatus', newStatus);

                fetch(`/Task/UpdateStatus`, {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                }).then(async res => {
                    if (!res.ok) {
                        const errMsg = await res.text();
                        throw new Error(errMsg || "Durum güncellenemedi.");
                    }
                    if (window.GB && typeof window.GB.toast === 'function') {
                        window.GB.toast({ icon: 'success', title: 'Durum güncellendi: ' + newStatus });
                    }
                    // Optional: Refresh page to update counters and markers
                    setTimeout(() => location.reload(), 800);
                }).catch(err => {
                    // Revert UI to original parent
                    const origCol = document.getElementById(origParentId);
                    if(origCol) origCol.querySelector('.kanban-items').appendChild(dragging);
                    
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({ icon: 'error', title: 'HATA', text: err.message, background: '#161b22', color: '#f0f6fc' });
                    } else {
                        alert(err.message);
                    }
                });
            });
        });

        // Search / Filter Logic
        const kanbanSearch = document.getElementById('kanbanSearchInput');
        if (kanbanSearch) {
            kanbanSearch.addEventListener('input', function() {
                const q = this.value.toLowerCase().trim();
                document.querySelectorAll('.kanban-item').forEach(item => {
                    const text = item.textContent.toLowerCase();
                    if (text.includes(q)) {
                        item.style.display = '';
                    } else {
                        item.style.display = 'none';
                    }
                });
            });
        }
    </script>
}
