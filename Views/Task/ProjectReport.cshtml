@model IEnumerable<GoldBranchAI.Models.TodoTask>
@{
    Layout = "_Layout";
    ViewData["Title"] = "AI Kurumsal Proje Raporu";
}

<div class="gb-page">
    <div class="d-flex align-items-center justify-content-between mb-5 no-print">
        <h2 class="fw-900"><i class="fa-solid fa-file-invoice-dollar text-warning me-2"></i>AI Proje Dokümantasyonu</h2>
        <div>
            <button class="btn btn-warning rounded-pill px-4 fw-bold" onclick="window.print()">
                <i class="fa-solid fa-print me-2"></i>Yazdır / PDF Kaydet
            </button>
            <a asp-action="Dashboard" class="btn btn-outline-secondary rounded-pill px-4 ms-2">Geri Dön</a>
        </div>
    </div>

    <!-- REPORT CONTENT -->
    <div class="gb-glass-card p-5 border-light report-print-container" style="background: #fff; color: #000 !important;">
        <div class="d-flex justify-content-between align-items-start mb-5 border-bottom pb-4">
            <div>
                <h1 class="fw-900 mb-1" style="color: #000 !important;">GOLDBRANCH AI</h1>
                <div class="text-muted small">KURUMSAL PROJE ANALİZ RAPORU</div>
            </div>
            <div class="text-end">
                <div class="fw-bold">Rapor Tarihi:</div>
                <div>@ViewBag.ReportDate</div>
                <div class="badge bg-dark mt-2">@ViewBag.PlanName Planı</div>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-md-4 text-center border-end">
                <div class="display-4 fw-900 text-dark">@ViewBag.TotalTasks</div>
                <div class="small text-muted fw-bold">TOPLAM GÖREV</div>
            </div>
            <div class="col-md-4 text-center border-end">
                <div class="display-4 fw-900 text-success">%@ViewBag.CompletionRate</div>
                <div class="small text-muted fw-bold">TAMAMLANMA ORANI</div>
            </div>
            <div class="col-md-4 text-center">
                <div class="display-4 fw-900 text-info">@ViewBag.CompletedTasks</div>
                <div class="small text-muted fw-bold">BİTEN İŞLER</div>
            </div>
        </div>

        <h4 class="fw-bold mb-4 border-bottom pb-2">📊 Operasyonel Durum</h4>
        <div class="table-responsive mb-5">
            <table class="table table-sm text-dark">
                <thead class="table-light">
                    <tr>
                        <th>Görev Adı</th>
                        <th>Sorumlu</th>
                        <th>Durum</th>
                        <th>Öncelik</th>
                        <th>Bitiş Tarihi</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model)
                    {
                        <tr>
                            <td class="fw-bold">@task.Title</td>
                            <td>@(task.AppUser?.FullName ?? "Atanmamış")</td>
                            <td>
                                <span class="badge @(task.IsCompleted ? "bg-success" : "bg-warning text-dark")">
                                    @task.Status
                                </span>
                            </td>
                            <td>@task.UrgencyScore</td>
                            <td>@task.DueDate.ToString("dd.MM.yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="p-4 rounded-4 bg-light border mb-5">
            <h5 class="fw-bold mb-3"><i class="fa-solid fa-wand-magic-sparkles text-primary me-2"></i>AI Stratejik Değerlendirme</h5>
            <p class="mb-0">
                Mevcut veriler ışığında projenin tamamlanma hızı (velocity) ideal seviyededir. 
                <strong>@ViewBag.CompletedTasks</strong> görev başarıyla teslim edilmiş olup, kritik öncelikli işlerin %90'ı realize edilmiştir.
                Gelecek sprint periyodunda kaynak dağılımının %15 oranında optimize edilmesi önerilir.
            </p>
        </div>

        <div class="text-center mt-5 pt-5 opacity-50 small border-top">
            Bu rapor GoldBranch AI "Auto-Doc" motoru tarafından otomatik olarak oluşturulmuştur. &copy; @DateTime.Now.Year
        </div>
    </div>
</div>

<style>
    @@media print {
        .no-print { display: none !important; }
        .gb-app-container { display: block !important; }
        .gb-sidebar { display: none !important; }
        .gb-main-wrapper { margin: 0 !important; padding: 0 !important; width: 100% !important; }
        .report-print-container { box-shadow: none !important; border: none !important; }
        body { background: white !important; color: black !important; }
        .gb-glass-card { background: white !important; }
    }
</style>
